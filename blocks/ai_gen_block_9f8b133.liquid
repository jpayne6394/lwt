  }

  .ai-company-bio-image-wrapper-{{ ai_gen_id }}::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg,
      rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.08) 0%,
      transparent 40%,
      rgba({{ block.settings.secondary_accent | color_extract: 'red' }}, {{ block.settings.secondary_accent | color_extract: 'green' }}, {{ block.settings.secondary_accent | color_extract: 'blue' }}, 0.05) 100%);
    z-index: 1; pointer-events: none;
  }

  .ai-company-bio-image-{{ ai_gen_id }} {
    width: 100%; height: 100%; object-fit: cover;
    filter: contrast(1.05) saturate(1.1) brightness(1.02);
  }

  .ai-company-bio-image-placeholder-{{ ai_gen_id }} {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, {{ block.settings.card_background }} 0%, rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.03) 100%);
    position: relative;
  }

  .ai-company-bio-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%; height: 50%; opacity: 0.15; color: {{ block.settings.accent_color }};
  }

  .ai-company-bio-empty-state-{{ ai_gen_id }} {
    position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
    padding: 16px 24px;
    background: rgba({{ block.settings.card_background | color_extract: 'red' }}, {{ block.settings.card_background | color_extract: 'green' }}, {{ block.settings.card_background | color_extract: 'blue' }}, 0.95);
