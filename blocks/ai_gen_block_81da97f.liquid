{% doc %}
  @prompt
    Connect add to cart buttons in product cards to trigger the pop-out cart drawer/toaster notification when items are added to cart for the best sellers row section, no we already have a section i just need to link my existing button to the add cart features

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<cart-connector-{{ ai_gen_id }} {{ block.shopify_attributes }}>
  <script>
    (function() {
      class CartConnector{{ ai_gen_id }} extends HTMLElement {
        constructor() {
          super();
          this.cart = document.querySelector('cart-notification') || document.querySelector('cart-drawer');
          this.setupEventListeners();
        }

        setupEventListeners() {document.addEventListener('click', (event) => {
            if (event.target.matches('[data-add-to-cart], .add-to-cart, .btn-add-to-cart, [data-product-form] button[type="submit"]')) {
              this.handleAddToCart(event);
            }
          });
        }

        async handleAddToCart(event) {
          const button = event.target;
          const form = button.closest('form[action*="/cart/add"]') || button.closest('[data-product-form]');
          
          if (!form) return;

          event.preventDefault();
          
          const formData = new FormData(form);
          const variantId = formData.get('id') || button.dataset.variantId;
          
          if (!variantId) return;

          const originalText = button.textContent;
          button.classList.add('loading');
          button.disabled = true;
          button.textContent = 'Adding...';

          try {
            const response = await fetch('/cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                id: variantId,
                quantity: parseInt(formData.get('quantity')) || 1
              })
            });

            if (!response.ok) {
              throw new Error('Failed to add to cart');
            }

            const item = await response.json();
            
            this.updateCartCount();
            this.triggerCartNotification(item);
            
            button.textContent = 'Added!';
            
            setTimeout(() => {
              button.textContent = originalText;
              button.classList.remove('loading');
              button.disabled = false;
            }, 2000);

          } catch (error) {
            console.error('Error adding to cart:', error);
            button.classList.remove('loading');
            button.disabled = false;
            
            button.textContent = 'Error - Try Again';
            setTimeout(() => {
              button.textContent = originalText;
            }, 2000);
          }
        }

        async updateCartCount() {
          try {
            const response = await fetch('/cart.js');
            const cart = await response.json();
            
            const cartCountElements = document.querySelectorAll('.cart-count-bubble, [data-cart-count], .cart-count');
            cartCountElements.forEach(element => {
              if (element.hasAttribute('data-cart-count')) {
                element.setAttribute('data-cart-count', cart.item_count);
              }
              element.textContent = cart.item_count;
            });
          } catch (error) {
            console.error('Error updating cart count:', error);
          }
        }

        triggerCartNotification(item) {
          if (this.cart) {
            if (this.cart.tagName === 'CART-NOTIFICATION') {
              this.cart.renderContents({
                item: item,
                cart: { item_count: this.getCartCount() + 1 }
              });
            } else if (this.cart.tagName === 'CART-DRAWER') {
              this.cart.open();
            }
          }document.dispatchEvent(new CustomEvent('cart:item-added', {
            detail: { item: item }
          }));

          const cartIconBubble = document.querySelector('.cart-count-bubble');
          if (cartIconBubble) {
            cartIconBubble.classList.add('cart-count-bubble--dot');
          }
        }

        getCartCount() {
          const cartCountElement = document.querySelector('.cart-count-bubble, [data-cart-count], .cart-count');
          return cartCountElement ? parseInt(cartCountElement.textContent || cartCountElement.getAttribute('data-cart-count') || '0') : 0;
        }
      }

      customElements.define('cart-connector-{{ ai_gen_id }}', CartConnector{{ ai_gen_id }});
    })();
  </script>
</cart-connector-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Cart Connector",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "This block automatically connects your existing add to cart buttons to trigger the cart drawer/notification. It works with buttons that have these attributes: data-add-to-cart, class'add-to-cart', class 'btn-add-to-cart', or submit buttons inside product forms."
    }
  ],
  "presets": [
    {
      "name": "Cart Connector"
    }
  ]
}
{% endschema %}