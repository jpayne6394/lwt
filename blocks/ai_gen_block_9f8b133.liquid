  .ai-company-bio-floating-elements-{{ ai_gen_id }} {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden; z-index: 0;
  }
  .ai-company-bio-floating-element-{{ ai_gen_id }} {
    position: absolute; width: 4px; height: 4px; background: {{ block.settings.accent_color }};
    border-radius: 50%; opacity: 0.1; animation: ai-float-{{ ai_gen_id }} 25s infinite linear;
  }
  .ai-company-bio-floating-element-{{ ai_gen_id }}:nth-child(1){ top:15%; left:8%;  animation-delay:0s;   background: {{ block.settings.accent_color }}; }
  .ai-company-bio-floating-element-{{ ai_gen_id }}:nth-child(2){ top:70%; right:12%; animation-delay:-8s; background: {{ block.settings.secondary_accent }}; }
  .ai-company-bio-floating-element-{{ ai_gen_id }}:nth-child(3){ bottom:25%; left:15%; animation-delay:-16s; background: {{ block.settings.accent_color }}; }
  .ai-company-bio-floating-element-{{ ai_gen_id }}:nth-child(4){ top:40%; right:25%; animation-delay:-12s; background: {{ block.settings.secondary_accent }}; }

  @keyframes ai-float-{{ ai_gen_id }} {
    0%,100% { transform: translateY(0) translateX(0) rotate(0); opacity: .05; }
    25%     { transform: translateY(-15px) translateX(10px) rotate(90deg); opacity: .15; }
    50%     { transform: translateY(-30px) translateX(-5px) rotate(180deg); opacity: .25; }
    75%     { transform: translateY(-15px) translateX(-10px) rotate(270deg); opacity: .15; }
  }

