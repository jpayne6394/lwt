{"sections":{"image_with_text_CkNHxE":{"type":"image-with-text","blocks":{"heading_nCWUnF":{"type":"heading","settings":{"heading":"Aaron Payne, N.D.c ,C.H.P.","heading_size":"h1"}},"text_TnwTU3":{"type":"text","settings":{"text":"<p>Aaron is a dedicated specialist with extensive experience in autism spectrum support. A graduate of Marshall University with a degree in Sports Medicine, Aaron has spent his career combining medical expertise with a deep understanding of neurodivergent care.<\/p><p>Recognized for his unwavering commitment, Aaron has been nominated by Autism One as one of America's top autism practitioners. His compassionate approach and evidence-based strategies have helped countless individuals and families navigate the complexities of autism with confidence and clarity.<\/p><p>Through personalized consultations, Aaron provides expert guidance on interventions, therapies, and lifestyle strategies tailored to each individual’s needs. Whether you're seeking support for autism-related challenges or looking to optimize health and performance through sports medicine, Aaron’s knowledge and dedication make him an invaluable resource.<\/p>","text_style":"body"}},"button_qCg6gd":{"type":"button","settings":{"button_label":"Meet with Aaron!","button_link":"https:\/\/living-well-today-international.myshopify.com\/apps\/meety-appointment-booking\/website-widget\/widgets\/widget-5452-1","button_style_secondary":false}}},"block_order":["heading_nCWUnF","text_TnwTU3","button_qCg6gd"],"settings":{"image":"shopify:\/\/shop_images\/aaron.jpg","height":"small","desktop_image_width":"small","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"center","content_layout":"no-overlap","section_color_scheme":"scheme-2","color_scheme":"scheme-1","image_behavior":"none","mobile_content_alignment":"center","padding_top":36,"padding_bottom":36}},"main":{"type":"main-page","disabled":true,"custom_css":[],"settings":{"padding_top":16,"padding_bottom