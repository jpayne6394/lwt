{% schema %}
{
  "name": "CTA Promo",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Just browsing for wellness products?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover curated supplements, clean ingredients, and expert-backed selections."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Visit Wellness Shop"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "CTA Promo",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section class="cta-promo" style="
  background-image: url('{{ section.settings.background_image | image_url: width: 2400 }}');
">
  <div class="cta-promo-content">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="cta-promo-btn">{{ section.settings.button_label }}</a>
    {% endif %}
  </div>
</section>

<style>
.cta-promo {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  border-radius: 20px;
  padding: 4rem 6rem;
  max-width: 1600px;
  min-height: 400px;
  margin: 3rem auto;
  box-sizing: border-box;
}

.cta-promo-content {
  background: rgba(255,255,255,0.75);
  padding: 2rem;
  border-radius: 12px;
  max-width: 1420px;
}


.cta-promo h2 {
  font-size: 2.2rem;
  color: #3e2764;
  margin-bottom: 0.8rem;
}

.cta-promo p {
  font-size: 1.1rem;
  color: #555;
  margin-bottom: 1.8rem;
}

.cta-promo-btn {
  background-color: #4a3c84;
  color: #fff;
  padding: 0.9rem 1.8rem;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.3s, transform 0.2s;
}

.cta-promo-btn:hover {
  background-color: #3e2764;
  transform: translateY(-2px);
}

@media (max-width: 768px) {
  .cta-promo {
    justify-content: center;
    text-align: center;
    padding: 4rem 2rem;
  }
  .cta-promo-content {
    max-width: 90%;
  }
}
</style>
