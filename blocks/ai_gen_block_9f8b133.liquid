{% doc %}
  @prompt
    Create a comprehensive company bio section with mission and vision statements that seamlessly integrates with the existing site theme. Include customizable fields for company description, mission statement, vision statement, founding story, and team highlights. Add style controls for background colors, text alignment, spacing, and typography. Include image upload capabilities for company photos, team images, or brand visuals. Provide layout options (single column, two column, card-based) and color scheme controls that match the site's existing design system. Make it fully responsive with smooth animations and professional styling., add better style that fits theme, make more luxury saas feel, close but give more wellness as a service, lets do a horizontal main card and trust and vision smaller under, remove badge, more style like our theme, more style, better style more luxury, wellness as a serivce, have the stats span the length at the btoom, no image hover, no card hover but we want the color gradient for the icons, add font size control for all
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-company-bio-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
    background: radial-gradient(ellipse at top, {{ block.settings.background_gradient_color }} 0%, {{ block.settings.background_color }} 70%);
    color: {{ block.settings.text_color }};
    position: relative;
    overflow: hidden;
  }

  .ai-company-bio-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.03) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba({{ block.settings.secondary_accent | color_extract: 'red' }}, {{ block.settings.secondary_accent | color_extract: 'green' }}, {{ block.settings.secondary_accent | color_extract: 'blue' }}, 0.02) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .ai-company-bio-container-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.spacing_grid_horizontal }}px;
    position: relative;
    z-index: 1;
  }

  .ai-company-bio-main-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    background: linear-gradient(145deg, {{ block.settings.card_background }} 0%, {{ block.settings.card_gradient_color }} 100%);
    border-radius: {{ settings.card_corner_radius | plus: 16 }}px;
    padding: 100px 80px 60px;
    margin-bottom: {{ settings.spacing_sections | plus: 32 }}px;
    position: relative;
    overflow: hidden;
    {% if settings.card_shadow_opacity > 0 %}
      box-shadow:
        0 32px 64px rgba({{ settings.card_shadow_color.red }}, {{ settings.card_shadow_color.green }}, {{ settings.card_shadow_color.blue }}, {{ settings.card_shadow_opacity | divided_by: 100.0 | times: 0.25 }}),
        0 16px 32px rgba({{ settings.card_shadow_color.red }}, {{ settings.card_shadow_color.green }}, {{ settings.card_shadow_color.blue }}, {{ settings.card_shadow_opacity | divided_by: 100.0 | times: 0.15 }}),
        0 8px 16px rgba({{ settings.card_shadow_color.red }}, {{ settings.card_shadow_color.green }}, {{ settings.card_shadow_color.blue }}, {{ settings.card_shadow_opacity | divided_by: 100.0 | times: 0.1 }}),
        inset 0 1px 0 rgba(255, 255, 255, 0.2),
        inset 0 -1px 0 rgba(0, 0, 0, 0.05);
    {% endif %}
    {% if settings.card_border_thickness > 0 %}
      border: {{ settings.card_border_thickness }}px solid rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.08);
    {% endif %}
    backdrop-filter: blur(20px) saturate(1.2);
  }

  .ai-company-bio-main-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute; left: 0; right: 0; top: 0; height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.6) 20%,
      {{ block.settings.accent_color }} 50%,
      rgba({{ block.settings.secondary_accent | color_extract: 'red' }}, {{ block.settings.secondary_accent | color_extract: 'green' }}, {{ block.settings.secondary_accent | color_extract: 'blue' }}, 0.6) 80%,
      transparent 100%);
  }

  .ai-company-bio-main-card-{{ ai_gen_id }}::after {
    content: '';
    position: absolute; top: -100px; right: -100px; width: 300px; height: 300px;
    background: radial-gradient(circle, rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.03) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }

  .ai-company-bio-main-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 100px;
    align-items: center;
    margin-bottom: 80px;
  }

  .ai-company-bio-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 40px;
    text-align: {{ settings.card_text_alignment }};
    position: relative;
  }

  .ai-company-bio-tagline-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.tagline_font_size }}px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: {{ block.settings.accent_color }};
    margin: 0;
    opacity: 0.9;
  }

  .ai-company-bio-heading-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: 300;
    font-size: {{ block.settings.heading_font_size }}px;
    line-height: 1.1;
    margin: 0;
    color: {{ block.settings.text_color }};
    letter-spacing: -0.02em;
    position: relative;
  }

  .ai-company-bio-heading-highlight-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.accent_color }} 0%, {{ block.settings.secondary_accent }} 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 400;
  }

  .ai-company-bio-description-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.description_font_size }}px;
    line-height: 1.8;
    margin: 0;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
    font-weight: 300;
    letter-spacing: 0.01em;
  }

/* Trailing link — bold, full-width underline, arrow on right, hover lift */
.ai-company-bio-description-link-{{ ai_gen_id }} {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-top: 16px;
  font-weight: 700;
  color: {{ block.settings.accent_color }};
  text-decoration: none;            /* custom underline instead */
  position: relative;
  padding-bottom: 6px;              /* room for underline */
  transition: color .2s ease, transform .2s ease;  /* enable lift */
  will-change: transform;
}

/* Full-width underline under BOTH text + arrow */
.ai-company-bio-description-link-{{ ai_gen_id }}::before {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 2px;
  background: currentColor;
}

/* Right arrow */
.ai-company-bio-description-link-{{ ai_gen_id }}::after {
  content: '→';
  font-weight: 600;
  transform: translateX(0);
  transition: transform .2s ease;
}

/* Hover interactions: lift the whole link and nudge arrow */
.ai-company-bio-description-link-{{ ai_gen_id }}:hover {
  transform: translateY(-2px);
}
.ai-company-bio-description-link-{{ ai_gen_id }}:hover::after {
  transform: translateX(4px);
}

/* Accessible focus */
.ai-company-bio-description-link-{{ ai_gen_id }}:focus-visible {
  outline: 2px solid {{ block.settings.accent_color }};
  outline-offset: 3px;
}


.ai-company-bio-description-link-{{ ai_gen_id }}:focus-visible {
  outline: 2px solid {{ block.settings.accent_color }};
  outline-offset: 3px;
}


  .ai-company-bio-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ settings.media_radius | plus: 20 }}px;
    overflow: hidden;
    aspect-ratio: 4/3;
    {% if settings.media_border_thickness > 0 %}
      border: {{ settings.media_border_thickness }}px solid rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.12);
    {% endif %}
    {% if settings.media_shadow_opacity > 0 %}
      box-shadow:
        0 40px 80px rgba({{ settings.card_shadow_color.red }}, {{ settings.card_shadow_color.green }}, {{ settings.card_shadow_color.blue }}, {{ settings.media_shadow_opacity | divided_by: 100.0 | times: 0.3 }}),
        0 20px 40px rgba({{ settings.card_shadow_color.red }}, {{ settings.card_shadow_color.green }}, {{ settings.card_shadow_color.blue }}, {{ settings.media_shadow_opacity | divided_by: 100.0 | times: 0.2 }}),
        0 10px 20px rgba({{ settings.card_shadow_color.red }}, {{ settings.card_shadow_color.green }}, {{ settings.card_shadow_color.blue }}, {{ settings.media_shadow_opacity | divided_by: 100.0 | times: 0.1 }});
    {% endif %}
