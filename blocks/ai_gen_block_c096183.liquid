{% doc %}
  @prompt
    Create a comprehensive contact information section with luxury styling that includes: a header area, logo placement, address display, phone numbers, and organized info areas for orders link, return policy, ordering policy, time shipping policy. Use elegant layout with clear sections, premium typography, sophisticated spacing, and luxury design elements that integrate seamlessly with the theme's design language. Include proper organization and visual hierarchy for easy readability.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
    background-image: {{ block.settings.background_gradient }};
  }

  .ai-contact-container-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.spacing_grid_horizontal }}px;
  }

  .ai-contact-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-contact-logo-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-contact-logo-{{ ai_gen_id }} img {
    max-width: {{ block.settings.logo_width }}px;
    height: auto;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.1));
  }

  .ai-contact-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-size: calc({{ block.settings.title_size }}px * {{ settings.heading_scale | divided_by: 100.0 }});
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .ai-contact-subtitle-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: calc({{ block.settings.subtitle_size }}px * {{ settings.body_scale | divided_by: 100.0 }});
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
    font-weight: 300;
  }

  .ai-contact-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: {{ block.settings.content_spacing }}px;
    margin-top: {{ block.settings.content_margin_top }}px;
  }

  .ai-contact-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .ai-contact-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical | plus: 8 }}px {{ block.settings.card_shadow_blur | plus: 10 }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 80.0 }});
  }

  .ai-contact-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, {{ block.settings.accent_color_1 }}, {{ block.settings.accent_color_2 }});
    border-radius: {{ block.settings.card_border_radius }}px {{ block.settings.card_border_radius }}px 0 0;
  }

  .ai-contact-card-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    margin-bottom: 20px;
    padding-top: 8px;
  }

  .ai-contact-card-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-right: 16px;
    color: {{ block.settings.accent_color_1 }};
    flex-shrink: 0;
  }

  .ai-contact-card-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-size: calc({{ block.settings.card_title_size }}px * {{ settings.heading_scale | divided_by: 100.0 }});
    color: {{ block.settings.text_color }};
    margin: 0;
    letter-spacing: -0.01em;
  }

  .ai-contact-card-content-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: calc({{ block.settings.card_text_size }}px * {{ settings.body_scale | divided_by: 100.0 }});
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-contact-info-item-{{ ai_gen_id }} {
    margin-bottom: 12px;
    display: flex;
    align-items: flex-start;
  }

  .ai-contact-info-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-contact-info-label-{{ ai_gen_id }} {
    font-weight: 600;
    min-width: 80px;
    margin-right: 12px;
    color: {{ block.settings.accent_color_1 }};
    font-size: 0.9em;
  }

  .ai-contact-info-value-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-contact-link-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color_1 }};
    text-decoration: none;
    transition: color 0.3s ease;
    font-weight: 500;
  }

  .ai-contact-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.accent_color_2 }};
    text-decoration: underline;
  }

  .ai-contact-address-{{ ai_gen_id }} {
    line-height: 1.5;
  }

  .ai-contact-phone-{{ ai_gen_id }} {
    margin-bottom: 8px;
  }

  .ai-contact-policy-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-contact-policy-item-{{ ai_gen_id }} {
    margin-bottom: 12px;
    padding-left: 20px;
    position: relative;
  }

  .ai-contact-policy-item-{{ ai_gen_id }}::before {
    content: '→';
    position: absolute;
    left: 0;
    color: {{ block.settings.accent_color_1 }};
    font-weight: bold;
  }

  .ai-contact-policy-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-content-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.content_spacing | times: 0.75 }}px;
    }

    .ai-contact-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }

    .ai-contact-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size | times: 0.85 }}px * {{ settings.heading_scale | divided_by: 100.0 }});
    }

    .ai-contact-card-header-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;
    }

    .ai-contact-card-icon-{{ ai_gen_id }} {
      margin-right: 0;
      margin-bottom: 12px;
    }

    .ai-contact-info-item-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-contact-info-label-{{ ai_gen_id }} {
      margin-bottom: 4px;
      min-width: auto;
    }
  }
{% endstyle %}

<div class="ai-contact-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    <div class="ai-contact-header-{{ ai_gen_id }}">
      {% if block.settings.show_logo and block.settings.logo %}
        <div class="ai-contact-logo-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.logo | image_url: width: block.settings.logo_width | times: 2 }}"
            alt="{{ shop.name }}"
            width="{{ block.settings.logo_width }}"
            height="auto"
            loading="lazy"
          >
        </div>
      {% endif %}

      {% if block.settings.title != blank %}
        <h2 class="ai-contact-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <p class="ai-contact-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-contact-content-{{ ai_gen_id }}">
      {% if block.settings.show_address_card %}
        <div class="ai-contact-card-{{ ai_gen_id }}">
          <div class="ai-contact-card-header-{{ ai_gen_id }}">
            <svg class="ai-contact-card-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.address_title }}</h3>
          </div>
          <div class="ai-contact-card-content-{{ ai_gen_id }}">
            {% if block.settings.address != blank %}
              <div class="ai-contact-address-{{ ai_gen_id }}">
                {{ block.settings.address }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_phone_card %}
        <div class="ai-contact-card-{{ ai_gen_id }}">
          <div class="ai-contact-card-header-{{ ai_gen_id }}">
            <svg class="ai-contact-card-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.phone_title }}</h3>
          </div>
          <div class="ai-contact-card-content-{{ ai_gen_id }}">
            {% if block.settings.phone_primary != blank %}
              <div class="ai-contact-phone-{{ ai_gen_id }}">
                <div class="ai-contact-info-item-{{ ai_gen_id }}">
                  <span class="ai-contact-info-label-{{ ai_gen_id }}">Primary:</span>
                  <span class="ai-contact-info-value-{{ ai_gen_id }}">
                    <a href="tel:{{ block.settings.phone_primary | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' }}" class="ai-contact-link-{{ ai_gen_id }}">
                      {{ block.settings.phone_primary }}
                    </a>
                  </span>
                </div>
              </div>
            {% endif %}
            {% if block.settings.phone_secondary != blank %}
              <div class="ai-contact-phone-{{ ai_gen_id }}">
                <div class="ai-contact-info-item-{{ ai_gen_id }}">
                  <span class="ai-contact-info-label-{{ ai_gen_id }}">Secondary:</span>
                  <span class="ai-contact-info-value-{{ ai_gen_id }}">
                    <a href="tel:{{ block.settings.phone_secondary | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' }}" class="ai-contact-link-{{ ai_gen_id }}">
                      {{ block.settings.phone_secondary }}
                    </a>
                  </span>
                </div>
              </div>
            {% endif %}
            {% if block.settings.email != blank %}
              <div class="ai-contact-info-item-{{ ai_gen_id }}">
                <span class="ai-contact-info-label-{{ ai_gen_id }}">Email:</span>
                <span class="ai-contact-info-value-{{ ai_gen_id }}">
                  <a href="mailto:{{ block.settings.email }}" class="ai-contact-link-{{ ai_gen_id }}">
                    {{ block.settings.email }}
                  </a>
                </span>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_orders_card %}
        <div class="ai-contact-card-{{ ai_gen_id }}">
          <div class="ai-contact-card-header-{{ ai_gen_id }}">
            <svg class="ai-contact-card-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <path d="M16 10a4 4 0 0 1-8 0"></path>
            </svg>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.orders_title }}</h3>
          </div>
          <div class="ai-contact-card-content-{{ ai_gen_id }}">
            {% if block.settings.orders_description != blank %}
              <p>{{ block.settings.orders_description }}</p>
            {% endif %}
            {% if block.settings.orders_link != blank %}
              <a href="{{ block.settings.orders_link }}" class="ai-contact-link-{{ ai_gen_id }}">
                {{ block.settings.orders_link_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_policies_card %}
        <div class="ai-contact-card-{{ ai_gen_id }}">
          <div class="ai-contact-card-header-{{ ai_gen_id }}">
            <svg class="ai-contact-card-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14,2 14,8 20,8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10,9 9,9 8,9"></polyline>
            </svg>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.policies_title }}</h3>
          </div>
          <div class="ai-contact-card-content-{{ ai_gen_id }}">
            <ul class="ai-contact-policy-list-{{ ai_gen_id }}">
              {% if block.settings.return_policy_link != blank %}
                <li class="ai-contact-policy-item-{{ ai_gen_id }}">
                  <a href="{{ block.settings.return_policy_link }}" class="ai-contact-link-{{ ai_gen_id }}">
                    {{ block.settings.return_policy_text }}
                  </a>
                </li>
              {% endif %}
              {% if block.settings.ordering_policy_link != blank %}
                <li class="ai-contact-policy-item-{{ ai_gen_id }}">
                  <a href="{{ block.settings.ordering_policy_link }}" class="ai-contact-link-{{ ai_gen_id }}">
                    {{ block.settings.ordering_policy_text }}
                  </a>
                </li>
              {% endif %}
              {% if block.settings.shipping_policy_link != blank %}
                <li class="ai-contact-policy-item-{{ ai_gen_id }}">
                  <a href="{{ block.settings.shipping_policy_link }}" class="ai-contact-link-{{ ai_gen_id }}">
                    {{ block.settings.shipping_policy_text }}
                  </a>
                </li>
              {% endif %}
            </ul>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact information",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Header section"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show logo",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 200
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Contact Information"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "We're here to help with all your inquiries"
    },
    {
      "type": "header",
      "content": "Address card"
    },
    {
      "type": "checkbox",
      "id": "show_address_card",
      "label": "Show address card",
      "default": true
    },
    {
      "type": "text",
      "id": "address_title",
      "label": "Address title",
      "default": "Our Location"
    },
    {
      "type": "richtext",
      "id": "address",
      "label": "Address",
      "default": "<p>123 Business Street<br>Suite 100<br>City, State 12345<br>United States</p>"
    },
    {
      "type": "header",
      "content": "Phone & email card"
    },
    {
      "type": "checkbox",
      "id": "show_phone_card",
      "label": "Show phone & email card",
      "default": true
    },
    {
      "type": "text",
      "id": "phone_title",
      "label": "Phone title",
      "default": "Contact Details"
    },
    {
      "type": "text",
      "id": "phone_primary",
      "label": "Primary phone",
      "default": "(555) 123-4567"
    },
    {
      "type": "text",
      "id": "phone_secondary",
      "label": "Secondary phone"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "info@example.com"
    },
    {
      "type": "header",
      "content": "Orders card"
    },
    {
      "type": "checkbox",
      "id": "show_orders_card",
      "label": "Show orders card",
      "default": true
    },
    {
      "type": "text",
      "id": "orders_title",
      "label": "Orders title",
      "default": "Order Support"
    },
    {
      "type": "textarea",
      "id": "orders_description",
      "label": "Orders description",
      "default": "Need help with your order? Track shipments, request returns, or get support."
    },
    {
      "type": "url",
      "id": "orders_link",
      "label": "Orders link"
    },
    {
      "type": "text",
      "id": "orders_link_text",
      "label": "Orders link text",
      "default": "Manage Your Orders"
    },
    {
      "type": "header",
      "content": "Policies card"
    },
    {
      "type": "checkbox",
      "id": "show_policies_card",
      "label": "Show policies card",
      "default": true
    },
    {
      "type": "text",
      "id": "policies_title",
      "label": "Policies title",
      "default": "Policies & Information"
    },
    {
      "type": "url",
      "id": "return_policy_link",
      "label": "Return policy link"
    },
    {
      "type": "text",
      "id": "return_policy_text",
      "label": "Return policy text",
      "default": "Return Policy"
    },
    {
      "type": "url",
      "id": "ordering_policy_link",
      "label": "Ordering policy link"
    },
    {
      "type": "text",
      "id": "ordering_policy_text",
      "label": "Ordering policy text",
      "default": "Ordering Information"
    },
    {
      "type": "url",
      "id": "shipping_policy_link",
      "label": "Shipping policy link"
    },
    {
      "type": "text",
      "id": "shipping_policy_text",
      "label": "Shipping policy text",
      "default": "Shipping & Delivery"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "accent_color_1",
      "label": "Primary accent color",
      "default": "#4b3f82"
    },
    {
      "type": "color",
      "id": "accent_color_2",
      "label": "Secondary accent color",
      "default": "#74d935"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#fdf2f2"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#e5e5e5"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 36
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size",
      "default": 18
    },
    {
      "type": "range",
      "id": "card_title_size",
      "min": 16,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Card title size",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Card text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 28
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Section padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Section padding bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Header spacing",
      "default": 48
    },
    {
      "type": "range",
      "id": "content_margin_top",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Content margin top",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_spacing",
      "min": 16,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Content spacing",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 20,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Card padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_border_radius",
