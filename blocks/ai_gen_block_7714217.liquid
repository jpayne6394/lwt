      "label": "Last name required",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "phone_required",
      "label": "Phone required",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "subject_required",
      "label": "Subject required",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "message_required",
      "label": "Message required",
      "default": true
    },
