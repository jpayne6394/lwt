{% schema %}
{
  "name": "Stacked Info",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Real Client Transformations"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Tagline / Subheading",
      "default": "Discover how our personalized protocols have changed lives."
    }
  ],
  "blocks": [
    {
      "type": "case_study",
      "name": "Case Study",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Case Study Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Headline",
          "default": "From Constant Bloating to Comfort"
        },
        {
          "type": "text",
          "id": "before_text",
          "label": "Before Text",
          "default": "Ashley experienced daily bloating, food sensitivities, and fatigue."
        },
        {
          "type": "text",
          "id": "after_text",
          "label": "After Text",
          "default": "6 weeks into a Gut Support Protocol guided by ZYTO, her symptoms dramatically improved."
        },
        {
          "type": "textarea",
          "id": "intro",
          "label": "Intro (always visible)",
          "default": "We used targeted enzyme support, food-based detox, and lifestyle tweaks."
        },
        {
          "type": "textarea",
          "id": "more_text",
          "label": "Read More Text (hidden until clicked)",
          "default": "Her personalized protocol was built using ZYTO scans and gut markers. By week 4, energy returned and digestion normalized. Ashley now eats with confidence and fewer flare-ups."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Stacked Info",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section class="bundle-stack-section section">
  <div class="section-heading">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
  </div>

  {% if section.settings.subheading != blank %}
    <div class="section-subheading">
      {{ section.settings.subheading }}
    </div>
  {% endif %}

  <div class="bundle-stack-wrapper">
    {% for block in section.blocks %}
      {% assign is_odd = forloop.index0 | modulo: 2 %}
      <div class="bundle-stack-item{% if is_odd == 1 %} row-reverse{% endif %}">
        {% if block.settings.image != blank %}
          <div class="bundle-stack-image">
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}">
          </div>
        {% endif %}

        <div class="bundle-stack-content toggle-read-wrapper">
          <div class="bundle-stack-text">
            {% if block.settings.title != blank %}
              <h3>{{ block.settings.title }}</h3>
            {% endif %}

            <div class="line-pair">
              <span class="label">Before:</span>
              <span class="value">{{ block.settings.before_text }}</span>
            </div>

            <div class="line-pair">
              <span class="label">After:</span>
              <span class="value">{{ block.settings.after_text }}</span>
            </div>

            <p class="summary-text">
              <span class="read-intro">{{ block.settings.intro }}</span>
              <span class="read-more hidden">{{ block.settings.more_text }}</span>
            </p>

            <button class="read-more-toggle" onclick="toggleReadMore(this)">Read More</button>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  function toggleReadMore(button) {
    const container = button.closest('.toggle-read-wrapper');
    const introText = container.querySelector('.read-intro');
    const moreText = container.querySelector('.read-more');

    const isHidden = moreText.classList.contains('hidden');
    moreText.classList.toggle('hidden');
    introText.classList.toggle('hidden');
    button.textContent = isHidden ? 'Read Less' : 'Read More';
  }
</script>

<style>
  .bundle-stack-wrapper {
    max-width: 1800px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .bundle-stack-item {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    padding: 3rem;
    gap: 3rem;
    border-radius: 16px;
    margin-bottom: 3rem;
    background-color: #fdf7f7;
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.3s ease;
  }

  .bundle-stack-item.row-reverse {
    direction: rtl;
  }

  .bundle-stack-item.row-reverse .bundle-stack-image,
  .bundle-stack-item.row-reverse .bundle-stack-content {
    direction: ltr;
  }

  .bundle-stack-item:hover {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1);
  }

  .bundle-stack-image {
    max-width: 300px;
  }

  .bundle-stack-image img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .bundle-stack-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .bundle-stack-text {
    max-width: 780px;
    margin: 0 auto;
    text-align: left;
  }

  .bundle-stack-text h3 {
    margin-bottom: 2.75rem;
    text-align: center;
    font-weight: 700;
  }

  .line-pair {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1rem;
    line-height: 1.8;
    text-align: left;
  }

  .line-pair .label {
    font-weight: 600;
    min-width: 80px;
    white-space: nowrap;
  }

  .line-pair .value {
    flex: 1;
    text-align: left;
    text-indent: 0;
    padding-left: 0;
    display: inline;
  }

  .summary-text {
    line-height: 1.6;
  }

  .read-more-toggle {
    background: none;
    border: none;
    color: #007a5e;
    cursor: pointer;
    font-weight: 600;
    padding: 0;
    margin-top: 0.75rem;
    text-decoration: underline;
  }

  .read-more-toggle:hover {
    text-decoration: underline;
  }

  .hidden {
    display: none;
  }

  /* Mobile */
@media (max-width: 768px) {
    .bundle-stack-item {
        flex-direction: column !important;
        text-align: center;
        padding: 1.5rem;
    }

    .bundle-stack-content {
        text-align: center;
        align-items: center;
        max-width: 100%;
    }

    .bundle-stack-content p {
        margin-bottom: 1.5rem;
    }

    .bundle-stack-content .bundle-button {
        margin-top: 0;
    }

    .bundle-stack-image {
        max-width: 100%;
    }
</style>
