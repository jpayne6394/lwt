{% doc %}
  @prompt
    Create a responsive slideshow component with navigation dots and arrow controls that has a reduced height (shorter/more compact). Include smooth transitions between slides, touch/swipe support for mobile devices, and customizable height options. The slideshow should automatically adapt to the current theme's styling while maintaining a smaller, more compact vertical size. Auto slide. Arrows reveal on hover. auto slide and user swipe on mobile , no arrows on mobile just user swiper and auto slide , make the height options pre set small medium and large , height control is not working , make the dots more to the site theme , add a hihglught color of 4B3F82 for the dot of the slide it is showing , debug height controls , do a set height of 600px, make the height of the banner 1050px, Include a dropdown setting for height options (Small: 250px, Medium: 400px, Large: 600px, Extra Large: 800px)., Create a responsive slideshow block with navigation dots and arrow controls. Include a functional height dropdown setting that actually applies CSS height changes (Small: 250px, Medium: 400px, Large: 600px, Extra Large: 800px) using proper Liquid conditional statements and CSS variables. Ensure the height setting dynamically updates the slideshow container height. Add image upload fields for multiple slides with object-fit cover to prevent distortion. Include smooth transitions, mobile touch support, and autoplay controls.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.background_color }};
    {% if block.settings.slideshow_height == 'small' %}
      --slideshow-height: 250px;
      --slideshow-mobile-height: 175px;
    {% elsif block.settings.slideshow_height == 'medium' %}
      --slideshow-height: 400px;
      --slideshow-mobile-height: 280px;
    {% elsif block.settings.slideshow_height == 'large' %}
      --slideshow-height: 600px;
      --slideshow-mobile-height: 420px;
    {% elsif block.settings.slideshow_height == 'extra_large' %}
      --slideshow-height: 800px;
      --slideshow-mobile-height: 560px;
    {% else %}
      --slideshow-height: 400px;
      --slideshow-mobile-height: 280px;
    {% endif %}
    height: var(--slideshow-height);
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    transition: transform {{ block.settings.transition_duration }}ms ease-in-out;
  }

  .ai-slide-{{ ai_gen_id }} {
    min-width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-slide-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-slide-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-slide-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-slide-content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: {{ block.settings.text_color }};
    z-index: 2;
    max-width: 90%;
  }

  .ai-slide-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 10px;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    line-height: 1.2;
  }

  .ai-slide-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    margin: 0 0 20px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    line-height: 1.4;
  }

  .ai-slide-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 500;
    transition: background-color 0.3s ease, transform 0.2s ease;
    border: none;
    cursor: pointer;
  }

  .ai-slide-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-1px);
  }

  .ai-slideshow-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: rgba(255, 255, 255, 0.9);
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease, background-color 0.3s ease, transform 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-slideshow-nav-{{ ai_gen_id }}:hover {
    background-color: rgba(255, 255, 255, 1);
    transform: translateY(-50%) scale(1.05);
  }

  .ai-slideshow-{{ ai_gen_id }}:hover .ai-slideshow-nav-{{ ai_gen_id }} {
    opacity: 1;
    visibility: visible;
  }

  .ai-slideshow-nav-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-slideshow-nav-next-{{ ai_gen_id }} {
    right: 20px;
  }

  .ai-slideshow-nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    color: #333;
  }

  .ai-slideshow-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 3;
    padding: 8px 16px;
    background-color: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 40px;
    background-color: rgba(255, 255, 255, 0.4);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    background-color: #4B3F82;
    width: 24px;
    box-shadow: 0 2px 8px rgba(75, 63, 130, 0.4);
  }

  .ai-slideshow-dot-{{ ai_gen_id }}:hover {
    background-color: rgba(75, 63, 130, 0.7);
    transform: scale(1.1);
  }

  .ai-slide-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }}) 100%
    );
    z-index: 1;
  }

  .ai-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    color: #666;
    font-size: 14px;
    text-align: center;
    pointer-events: none;
    z-index: 4;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-{{ ai_gen_id }} {
      height: var(--slideshow-mobile-height);
    }

    .ai-slide-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-slide-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-slideshow-nav-{{ ai_gen_id }} {
      display: none;
    }

    .ai-slideshow-dots-{{ ai_gen_id }} {
      gap: 10px;
      padding: 6px 12px;
    }

    .ai-slideshow-dot-{{ ai_gen_id }} {
      width: 6px;
      height: 6px;
    }

    .ai-slideshow-dot-{{ ai_gen_id }}.active {
      width: 20px;
    }
  }
{% endstyle %}

<responsive-slideshow-{{ ai_gen_id }}
  class="ai-slideshow-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
        assign slide_image_key = 'slide_' | append: i | append: '_image'
        assign slide_title_key = 'slide_' | append: i | append: '_title'
        assign slide_description_key = 'slide_' | append: i | append: '_description'
        assign slide_button_text_key = 'slide_' | append: i | append: '_button_text'
        assign slide_button_link_key = 'slide_' | append: i | append: '_button_link'

        assign slide_enabled = block.settings[slide_enabled_key]
        assign slide_image = block.settings[slide_image_key]
        assign slide_title = block.settings[slide_title_key]
        assign slide_description = block.settings[slide_description_key]
        assign slide_button_text = block.settings[slide_button_text_key]
        assign slide_button_link = block.settings[slide_button_link_key]
      %}

      {% if slide_enabled %}
        <div class="ai-slide-{{ ai_gen_id }}" data-slide="{{ forloop.index0 }}">
          {% if slide_image %}
            <img
              src="{{ slide_image | image_url: width: 2000 }}"
              alt="{{ slide_image.alt | escape }}"
              class="ai-slide-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ slide_image.width }}"
              height="{{ slide_image.height }}"
            >
          {% else %}
            <div class="ai-slide-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if block.settings.show_overlay %}
            <div class="ai-slide-overlay-{{ ai_gen_id }}"></div>
          {% endif %}

          {% if slide_title != blank or slide_description != blank or slide_button_text != blank %}
            <div class="ai-slide-content-{{ ai_gen_id }}">
              {% if slide_title != blank %}
                <h2 class="ai-slide-title-{{ ai_gen_id }}">{{ slide_title }}</h2>
              {% endif %}

              {% if slide_description != blank %}
                <p class="ai-slide-description-{{ ai_gen_id }}">{{ slide_description }}</p>
              {% endif %}

              {% if slide_button_text != blank and slide_button_link != blank %}
                <a href="{{ slide_button_link }}" class="ai-slide-button-{{ ai_gen_id }}">
                  {{ slide_button_text }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% assign enabled_slides_count = 0 %}
  {% for i in (1..5) %}
    {% liquid
      assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
      assign slide_enabled = block.settings[slide_enabled_key]
    %}
    {% if slide_enabled %}
      {% assign enabled_slides_count = enabled_slides_count | plus: 1 %}
    {% endif %}
  {% endfor %}

  {% if enabled_slides_count == 0 %}
    <div class="ai-empty-state-{{ ai_gen_id }}">
      Add images to create your slideshow
    </div>
  {% endif %}

  {% if enabled_slides_count > 1 %}
    <button class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-prev-{{ ai_gen_id }}" aria-label="Previous slide">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15,18 9,12 15,6"></polyline>
      </svg>
    </button>

    <button class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-next-{{ ai_gen_id }}" aria-label="Next slide">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9,6 15,12 9,18"></polyline>
      </svg>
    </button>

    <div class="ai-slideshow-dots-{{ ai_gen_id }}">
      {% for i in (1..enabled_slides_count) %}
        <button
          class="ai-slideshow-dot-{{ ai_gen_id }}{% if forloop.first %} active{% endif %}"
          data-slide="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
        ></button>
      {% endfor %}
    </div>
  {% endif %}
</responsive-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class ResponsiveSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayInterval = null;
        this.isAutoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) || 5000;
        this.touchStartX = 0;
        this.touchEndX = 0;
        this.isDragging = false;
        this.isTransitioning = false;
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-slideshow-container-{{ ai_gen_id }}');
        this.slides = Array.from(this.querySelectorAll('.ai-slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}'));
        this.prevBtn = this.querySelector('.ai-slideshow-nav-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-slideshow-nav-next-{{ ai_gen_id }}');

        if (this.slides.length <= 1) return;

        this.setupEventListeners();
        this.setupTouchEvents();
        
        if (this.isAutoplay) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => {
            if (!this.isTransitioning) this.previousSlide();
          });
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => {
            if (!this.isTransitioning) this.nextSlide();
          });
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            if (!this.isTransitioning) this.goToSlide(index);
          });
        });

        this.addEventListener('mouseenter', () => this.pauseAutoplay());
        this.addEventListener('mouseleave', () => {
          if (this.isAutoplay) this.startAutoplay();
        });

        this.container.addEventListener('transitionstart', () => {
          this.isTransitioning = true;
        });

        this.container.addEventListener('transitionend', () => {
          this.isTransitioning = false;
        });
      }

      setupTouchEvents() {
        this.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
          this.pauseAutoplay();
        }, { passive: true });

        this.addEventListener('touchend', (e) => {
          this.touchEndX = e.changedTouches[0].screenX;
          if (!this.isTransitioning) this.handleSwipe();
          if (this.isAutoplay) {
            setTimeout(() => this.startAutoplay(), 1000);
          }
        }, { passive: true });

        this.addEventListener('touchmove', (e) => {
          e.preventDefault();
        }, { passive: false });
      }

      handleSwipe() {
        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.nextSlide();
          } else {
            this.previousSlide();
          }
        }
      }

      goToSlide(index) {
        if (index === this.currentSlide) return;
        
        this.currentSlide = index;
        this.updateSlidePosition();
        this.updateDots();
        this.resetAutoplay();
      }

      nextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.updateSlidePosition();
        this.updateDots();
        this.resetAutoplay();
      }

      previousSlide() {
        this.currentSlide = this.currentSlide === 0 ? this.slides.length - 1 : this.currentSlide - 1;
        this.updateSlidePosition();
        this.updateDots();
        this.resetAutoplay();
      }

      updateSlidePosition() {
        const translateX = -this.currentSlide * 100;
        this.container.style.transform = `translateX(${translateX}%)`;
      }

      updateDots() {
        this.dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentSlide);
        });
      }

      startAutoplay() {
        if (!this.isAutoplay || this.slides.length <= 1) return;
        
        this.pauseAutoplay();
        this.autoplayInterval = setInterval(() => {
          if (!this.isTransitioning) {
            this.nextSlide();
          }
        }, this.autoplaySpeed);
      }

      pauseAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        this.pauseAutoplay();
        if (this.isAutoplay) {
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.pauseAutoplay();
      }
    }

    customElements.define('responsive-slideshow-{{ ai_gen_id }}', ResponsiveSlideshow{{ ai_gen_id }});
  })();
</script>

