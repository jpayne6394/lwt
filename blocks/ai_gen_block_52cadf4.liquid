{% doc %}
  @prompt
    Create a blank flexible section that can contain custom blocks. This section should have minimal styling and act as a container where merchants can add various custom blocks. Include basic section settings for padding, background, and alignment options., Liquid error (temp/ai_gen_block_a853f43 line 62): Nesting too deep, code is producing an error and is not rendering, ensure this section shows in the "Add Section" menu of the theme editor, this section is not showing in the theme editor

{% enddoc %}
{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-flexible-section-{{ ai_gen_id }} {
    background-color: {{ section.settings.background_color }};
    {% if section.settings.background_gradient != blank %}
      background: {{ section.settings.background_gradient }};
    {% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_horizontal }}px;
    padding-right: {{ section.settings.padding_horizontal }}px;
  }

  .ai-flexible-section__container-{{ ai_gen_id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.block_spacing }}px;
    {% if section.settings.content_alignment == 'left' %}
      align-items: flex-start;
    {% elsif section.settings.content_alignment == 'center' %}
      align-items: center;
    {% elsif section.settings.content_alignment == 'right' %}
      align-items: flex-end;
    {% endif %}
  }

  .ai-flexible-section__block-{{ ai_gen_id }} {
    width: 100%;
    {% if section.settings.content_alignment == 'center' %}
      text-align: center;
    {% elsif section.settings.content_alignment == 'right' %}
      text-align: right;
    {% else %}
      text-align: left;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-flexible-section-{{ ai_gen_id }} {
      padding-left: {{ section.settings.padding_horizontal | times: 0.7 }}px;
      padding-right: {{ section.settings.padding_horizontal | times: 0.7 }}px;
      padding-top: {{ section.settings.padding_top | times: 0.8 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.8 }}px;
    }

    .ai-flexible-section__container-{{ ai_gen_id }} {
      gap: {{ section.settings.block_spacing | times: 0.8 }}px;
    }
  }
{% endstyle %}

<section class="ai-flexible-section-{{ ai_gen_id }}" {{ section.shopify_attributes }}>
  <div class="ai-flexible-section__container-{{ ai_gen_id }}">
    {% for block in section.blocks %}
      <div class="ai-flexible-section__block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
        {% case block.type %}
          {% when '@app' %}
            {% render block %}
        {% endcase %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Flexible container",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 600,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "block_spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Space between blocks",
      "default": 32
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Flexible container"
    }
  ]
}
{% endschema %}