{% comment %}
  Practitioner Insights Blog Template
  Purpose: Render plug-and-play formatted article for educated readers
  Fonts: Inter
  Accent: Soft brand purple
{% endcomment %}

{% assign hero_image = article.metafields.custom.hero_image | img_url: '1600x' %}
{% assign subheading = article.metafields.custom.subheading %}
{% assign intro_text = article.metafields.custom.intro_text %}
{% assign pull_quote = article.metafields.custom.pull_quote %}
{% assign highlight_box = article.metafields.custom.highlight_box %}
{% assign section_1_title = article.metafields.custom.section_1_title %}
{% assign section_1_body = article.metafields.custom.section_1_body %}
{% assign inline_product = article.metafields.custom.inline_product %}
{% assign wrap_up_note = article.metafields.custom.wrap_up_note %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');

  .practitioner-article {
    font-family: 'Inter', sans-serif;
    color: #333;
    max-width: 820px;
    margin: 0 auto;
    padding: 3rem 1rem;
    line-height: 1.7;
  }
  .practitioner-article h1 {
    font-size: 2.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .practitioner-article .subheading {
    font-size: 1.2rem;
    color: #666;
    margin-bottom: 1.5rem;
  }
  .practitioner-article .meta {
    font-size: 0.9rem;
    color: #999;
    margin-bottom: 2.5rem;
  }
  .practitioner-article .hero-image {
    width: 100%;
    margin-bottom: 2rem;
    border-radius: 6px;
  }
  .practitioner-article .intro-text {
    font-size: 1.15rem;
    font-weight: 400;
    margin-bottom: 2rem;
  }
  .practitioner-article blockquote {
    border-left: 4px solid #9c89b8;
    padding-left: 1rem;
    margin: 2rem 0;
    font-style: italic;
    color: #555;
    background: #f9f9f9;
  }
  .practitioner-article .highlight-box {
    background: #f4f4f4;
    border-left: 4px solid #9c89b8;
    padding: 1.25rem;
    margin: 2.5rem 0;
    font-size: 1rem;
    color: #444;
  }
  .practitioner-article h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .practitioner-article .product-spotlight {
    border: 1px solid #ddd;
    padding: 1.5rem;
    margin: 3rem 0;
    border-radius: 6px;
    background: #fafafa;
    text-align: center;
  }
  .practitioner-article .product-spotlight h3 {
    margin-bottom: 0.5rem;
  }
  .practitioner-article .wrap-up {
    margin-top: 3rem;
    font-style: italic;
    color: #666;
  }
</style>

<article class="practitioner-article">
  <h1>{{ article.title }}</h1>
  {% if subheading != blank %}
    <div class="subheading">{{ subheading }}</div>
  {% endif %}
  <div class="meta">By {{ article.author }}, {{ article.published_at | date: "%B %d, %Y" }}</div>

  {% if hero_image != blank %}
    <img src="{{ hero_image }}" alt="{{ article.title }}" class="hero-image">
  {% endif %}

  {% if intro_text != blank %}
    <p class="intro-text">{{ intro_text }}</p>
  {% endif %}

  {% if pull_quote != blank %}
    <blockquote>{{ pull_quote }}</blockquote>
  {% endif %}

  {% if section_1_title != blank %}
    <h2>{{ section_1_title }}</h2>
  {% endif %}
  {% if section_1_body != blank %}
    <div class="section-body">{{ section_1_body }}</div>
  {% endif %}

  {% if highlight_box != blank %}
    <div class="highlight-box">{{ highlight_box }}</div>
  {% endif %}

  {% if inline_product != blank %}
    <div class="product-spotlight">
      <h3>{{ inline_product.title }}</h3>
      <p>{{ inline_product.description | truncatewords: 30 }}</p>
      <a href="{{ inline_product.url }}" class="button">View Product</a>
    </div>
  {% endif %}

  {% if wrap_up_note != blank %}
    <div class="wrap-up">{{ wrap_up_note }}</div>
  {% endif %}
</article>


{% schema %}
{
  "name": "Practitioner Insights",
  "tag": "section",
  "class": "section-practitioner-article",
  "settings": [],
  "presets": [
    {
      "name": "Practitioner Insights Article"
    }
  ]
}
{% endschema %}
