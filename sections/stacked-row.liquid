<style>
.bundle-stack-section {
    background-color: #fff;
    padding: 50px 20px 120px;
    margin-top: 25px;
    margin-bottom: 50px;
}

.bundle-stack-section .section-heading {
    text-align: center;
    margin-top: -3.5rem;
    margin-bottom: 1rem;
    min-height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
}

.bundle-stack-section .section-heading:empty {
    min-height: 2rem;
    margin-bottom: 4rem;
}

.bundle-stack-section .section-heading h2 {
    font-size: 4rem;
    font-weight: 500;
    line-height: 1.3;
}

.bundle-stack-section .section-subheading {
    text-align: center;
    font-size: 1.25rem;
    color: #555;
    max-width: 750px;
    margin: 0 auto 3rem;
}

.bundle-stack-wrapper {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    max-width: 1880px; /* Matches your expanded container */
    margin: 0 auto;
    padding: 0 20px;
}

.bundle-stack-item {
    display: flex;
    align-items: center; /* Center image and text vertically */
    justify-content: center;
    gap: 8.5rem; /*  gap between image + text */
    flex-wrap: wrap;
    padding: 2rem 6rem;
    background-color: #fdf2f2;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
    transition: box-shadow 0.3s ease;
}

.bundle-stack-item:hover {
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.08);
}

.bundle-stack-item:nth-child(even) {
    flex-direction: row-reverse;
}

.bundle-stack-image {
    flex: 1 1 45%;
    text-align: center;
    max-width: 550px;
}

.bundle-stack-image img {
    object-fit: contain;
    width: 100%;         /* no full width */
    max-width: 1000px;    /* allow wider images */
    max-height: 250px;   /* force not too tall — this is the key */
    border-radius: 12px;
}

.bundle-stack-content {
    flex: 1 1 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center; /* <— center all children (title, paragraph, button) */
    max-width: 550px;
    text-align: center;
}

.bundle-stack-content h3 {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 1rem;
    width: 100%;
    text-align: center;
}

.bundle-stack-content p {
    max-width: 100%;
    text-align: center;
}

.bundle-stack-content .bundle-button {
    display: block;
    margin: 1rem 0 0 0;
    align-self: center; /* <— ensure button is centered */
    padding: 0.75rem 2rem;
    background: linear-gradient(90deg, #4B2671 0%, #5E3592 100%);
    color: #fff;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.4rem;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
    transition: background-color 0.3s ease, transform 0.2s ease;
}

.bundle-stack-content .bundle-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
}


/* Mobile */
@media (max-width: 768px) {
    .bundle-stack-item {
        flex-direction: column !important;
        text-align: center;
        padding: 1.5rem;
    }

    .bundle-stack-content {
        text-align: center;
        align-items: center;
        max-width: 100%;
    }

    .bundle-stack-content p {
        margin-bottom: 1.5rem;
    }

    .bundle-stack-content .bundle-button {
        margin-top: 0;
    }

    .bundle-stack-image {
        max-width: 100%;
    }
}
</style>




<section class="bundle-stack-section section">
  
  <div class="section-heading">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
  </div>

  {% if section.settings.subheading != blank %}
    <div class="section-subheading">
      {{ section.settings.subheading }}
    </div>
  {% endif %}

  <div class="bundle-stack-wrapper">
    {% for block in section.blocks %}
      {% assign image = block.settings.image %}
      {% assign title = block.settings.title %}
      {% assign text = block.settings.text %}
      {% assign link = block.settings.link %}
      {% assign button_text = block.settings.button_text %}
      
      <div class="bundle-stack-item" {{ block.shopify_attributes }}>
        
        {% if image != blank %}
          <div class="bundle-stack-image">
            <img src="{{ image | image_url: width: 600 }}" alt="{{ title | escape }}">
          </div>
        {% endif %}

        <div class="bundle-stack-content">
          {% if title != blank %}
            <h3>{{ title }}</h3>
          {% endif %}

          {% if text != blank %}
            <p>{{ text }}</p>
          {% endif %}

          {% if button_text != blank and link != blank %}
            <a href="{{ link }}" class="bundle-button">{{ button_text }}</a>
          {% endif %}
        </div>

      </div>

    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Bundle Stack Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Supplement Bundles"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Tagline / Subheading",
      "default": "Curated supplement kits designed to support your wellness journey. View bundle details and usage instructions."
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Bundle",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bundle Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Bundle Name",
          "default": "Bundle Name"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Short Description",
          "default": "Short bundle description goes here."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Bundle Link (Product Page)"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "View Protocol"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundle Stack Section",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
