{% doc %}
  @prompt
    Create a customizable slideshow block with the following features: navigation dots and arrows that match the theme's design, ability to add and remove images with removed images staying removed, automatically hide navigation arrows and dots when only one image is present, smooth transitions between slides, and mobile-responsive design
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slideshow_height }}px;
  }

  .ai-slideshow-slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    transition: transform {{ block.settings.transition_speed }}s ease-in-out;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_speed }}s ease-in-out;
    pointer-events: none;
  }

  .ai-slideshow-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-slideshow-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-slideshow-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: {{ block.settings.arrow_border_radius }}px;
    cursor: pointer;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, transform 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-slideshow-arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-slideshow-arrow-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-slideshow-arrow-prev-{{ ai_gen_id }} {
    left: {{ block.settings.arrow_offset }}px;
  }

  .ai-slideshow-arrow-next-{{ ai_gen_id }} {
    right: {{ block.settings.arrow_offset }}px;
  }

  .ai-slideshow-arrow-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.arrow_size }}px * 0.5);
    height: calc({{ block.settings.arrow_size }}px * 0.5);
  }

  .ai-slideshow-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.dots_offset }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: {{ block.settings.dots_spacing }}px;
    z-index: 2;
  }

  .ai-slideshow-dots-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    padding: 0;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.dot_hover_color }};
    transform: scale(1.2);
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-container-{{ ai_gen_id }} {
      height: {{ block.settings.slideshow_height_mobile }}px;
    }

    .ai-slideshow-arrow-{{ ai_gen_id }} {
      width: calc({{ block.settings.arrow_size }}px * 0.8);
      height: calc({{ block.settings.arrow_size }}px * 0.8);
    }

    .ai-slideshow-arrow-prev-{{ ai_gen_id }} {
      left: calc({{ block.settings.arrow_offset }}px * 0.5);
    }

    .ai-slideshow-arrow-next-{{ ai_gen_id }} {
      right: calc({{ block.settings.arrow_offset }}px * 0.5);
    }

    .ai-slideshow-dot-{{ ai_gen_id }} {
      width: calc({{ block.settings.dot_size }}px * 0.8);
      height: calc({{ block.settings.dot_size }}px * 0.8);
    }
  }
{% endstyle %}

<slideshow-block-{{ ai_gen_id }} class="ai-slideshow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    <div class="ai-slideshow-slides-{{ ai_gen_id }}">
      {% liquid
        assign has_images = false
        for i in (1..10)
          assign image_key = 'image_' | append: i
          if block.settings[image_key] != blank
            assign has_images = true
            break
          endif
        endfor
      %}

      {% if has_images %}
        {% for i in (1..10) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign image = block.settings[image_key]
          %}
          {% if image != blank %}
            <div class="ai-slideshow-slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
              <img
                src="{{ image | image_url: width: 2000 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-slideshow-slide-{{ ai_gen_id }} active" data-slide-index="0">
          <div class="ai-slideshow-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-slideshow-empty-state-{{ ai_gen_id }}">
              Next, add images to your slideshow
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    <button
      class="ai-slideshow-arrow-{{ ai_gen_id }} ai-slideshow-arrow-prev-{{ ai_gen_id }}"
      aria-label="Previous slide"
      data-direction="prev"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button
      class="ai-slideshow-arrow-{{ ai_gen_id }} ai-slideshow-arrow-next-{{ ai_gen_id }}"
      aria-label="Next slide"
      data-direction="next"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>

    <div class="ai-slideshow-dots-{{ ai_gen_id }}"></div>
  </div>
</slideshow-block-{{ ai_gen_id }}>

<script>
  (function() {
    class SlideshowBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-slideshow-arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-slideshow-arrow-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-slideshow-dots-{{ ai_gen_id }}');
        
        this.init();
      }

      init() {
        if (this.slides.length === 0) return;

        this.updateNavigationVisibility();
        this.createDots();
        this.setupEventListeners();
        this.showSlide(0);

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      updateNavigationVisibility() {
        const shouldHide = this.slides.length <= 1;
        
        if (shouldHide) {
          this.prevButton.classList.add('hidden');
          this.nextButton.classList.add('hidden');
          this.dotsContainer.classList.add('hidden');
        } else {
          this.prevButton.classList.remove('hidden');
          this.nextButton.classList.remove('hidden');
          this.dotsContainer.classList.remove('hidden');
        }
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        
        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-slideshow-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
          dot.dataset.slideIndex = index;
          
          if (index === 0) {
            dot.classList.add('active');
          }
          
          this.dotsContainer.appendChild(dot);
        });
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.navigate('prev'));
        this.nextButton.addEventListener('click', () => this.navigate('next'));

        this.dotsContainer.addEventListener('click', (e) => {
          if (e.target.classList.contains('ai-slideshow-dot-{{ ai_gen_id }}')) {
            const index = parseInt(e.target.dataset.slideIndex);
            this.showSlide(index);
            this.resetAutoplay();
          }
        });

        {% if block.settings.pause_on_hover %}
          this.addEventListener('mouseenter', () => this.pauseAutoplay());
          this.addEventListener('mouseleave', () => this.resumeAutoplay());
        {% endif %}

        if ('ontouchstart' in window) {
          this.setupTouchEvents();
        }
      }

      setupTouchEvents() {
        let touchStartX = 0;
        let touchEndX = 0;

        this.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.navigate('next');
          } else {
            this.navigate('prev');
          }
          this.resetAutoplay();
        }
      }

      navigate(direction) {
        if (direction === 'next') {
          this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        } else {
          this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        }
        this.showSlide(this.currentSlide);
      }

      showSlide(index) {
        this.slides.forEach((slide, i) => {
          if (i === index) {
            slide.classList.add('active');
          } else {
            slide.classList.remove('active');
          }
        });

        const dots = this.dotsContainer.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}');
        dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        this.currentSlide = index;
      }

      startAutoplay() {
        if (this.slides.length <= 1) return;
        
        this.autoplayInterval = setInterval(() => {
          this.navigate('next');
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      pauseAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resumeAutoplay() {
        {% if block.settings.autoplay %}
          if (!this.autoplayInterval) {
            this.startAutoplay();
          }
        {% endif %}
      }

      resetAutoplay() {
        {% if block.settings.autoplay %}
          this.pauseAutoplay();
          this.startAutoplay();
        {% endif %}
      }

      disconnectedCallback() {
        this.pauseAutoplay();
      }
    }

    customElements.define('slideshow-block-{{ ai_gen_id }}', SlideshowBlock{{ ai_gen_id }});
  })();
</script>

