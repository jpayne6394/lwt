  }

  .ai-company-bio-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute; left: 0; right: 0; top: 0; height: 3px;
    background: linear-gradient(90deg, {{ block.settings.accent_color }} 0%, {{ block.settings.secondary_accent }} 50%, rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.3) 100%);
  }

  .ai-company-bio-card-{{ ai_gen_id }}::after {
