{% doc %}
  @prompt
    Create a fun and engaging blog article template with a prominent title section, subtitle area, and content area where images are specifically positioned after the first paragraph. Include an attractive author card with photo and bio, stylized quote blocks, and support for 1-2 images that appear right after the opening.  paragraph. Make it visually appealing with modern typography, good spacing, and responsive design. Add a visual background color that fits the theme, move the second lower in the section. no hover effect.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-article-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    font-family: {{ block.settings.body_font.family }}, sans-serif;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-blog-article__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
    padding-bottom: 30px;
    border-bottom: 2px solid {{ block.settings.accent_color }};
  }

  .ai-blog-article__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, serif;
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0 0 15px;
    line-height: 1.2;
  }

  .ai-blog-article__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 20px;
    font-style: italic;
    opacity: 0.9;
  }

  .ai-blog-article__meta-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    font-size: 14px;
    color: {{ block.settings.meta_color }};
    margin-top: 15px;
  }

  .ai-blog-article__date-{{ ai_gen_id }},
  .ai-blog-article__read-time-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .ai-blog-article__content-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-blog-article__opening-paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.opening_paragraph_size }}px;
    font-weight: 500;
    margin-bottom: 30px;
    color: {{ block.settings.opening_text_color }};
    line-height: 1.7;
  }

  .ai-blog-article__first-image-{{ ai_gen_id }} {
    margin: 40px 0;
  }

  .ai-blog-article__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
  }

  .ai-blog-article__image-{{ ai_gen_id }} {
    width: 100%;
    height: 250px;
    object-fit: cover;display: block;
  }

  .ai-blog-article__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 250px;
    background-color: #f8f9fa;
    display: flex;
    align-items: center;
    justify-content: center;}

  .ai-blog-article__image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;opacity: 0.3;
  }

  .ai-blog-article__main-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_size }}px;
    line-height: 1.8;}

  .ai-blog-article__quote-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.quote_bg_color }}, {{ block.settings.quote_bg_color }}dd);
    border-left: 5px solid {{ block.settings.accent_color }};
    padding: 30px;
    margin: 40px 0;
    border-radius: 0 {{ block.settings.border_radius }}px {{ block.settings.border_radius }}px 0;
    position: relative;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .ai-blog-article__quote-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    font-style: italic;
    color: {{ block.settings.quote_text_color }};
    margin: 0;
    position: relative;
    z-index: 2;
  }

  .ai-blog-article__quote::before {
    content: '"';
    position: absolute;
    top: -10px;
    left: 20px;
    font-size: 80px;
    color: {{ block.settings.accent_color }};
    opacity: 0.3;
    font-family: serif;
    line-height: 1;
  }

  .ai-blog-article__second-image-{{ ai_gen_id }} {
    margin: 40px 0;
  }

  .ai-blog-article__author-card-{{ ai_gen_id }} {
    background: {{ block.settings.author_card_bg }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 30px;
    margin-top: 50px;
    display: flex;
    align-items: center;
    gap: 20px;box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid {{ block.settings.accent_color }}22;
  }

  .ai-blog-article__author-photo-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 3px solid {{ block.settings.accent_color }};
  }

  .ai-blog-article__author-photo-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-article__author-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e9ecef;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-blog-article__author-placeholder-{{ ai_gen_id }} svg {
    width: 40px;
    height: 40px;
    opacity: 0.4;
  }

  .ai-blog-article__author-info-{{ ai_gen_id }} {
    flex-grow: 1;}

  .ai-blog-article__author-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_name_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 8px;
  }

  .ai-blog-article__author-bio-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_bio_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    opacity: 0.8;
  }

  @media screen and (max-width: 768px) {
    .ai-blog-article-{{ ai_gen_id }} {
      padding: 30px 15px;
    }

    .ai-blog-article__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-blog-article__meta-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 10px;
    }

    .ai-blog-article__author-card-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;gap: 15px;
    }

    .ai-blog-article__quote-{{ ai_gen_id }} {
      padding: 20px;
      margin: 30px 0;
    }
  }
{% endstyle %}

<article class="ai-blog-article-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <header class="ai-blog-article__header-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h1 class="ai-blog-article__title-{{ ai_gen_id }}">{{ block.settings.title }}</h1>
    {% endif %}
    
    {% if block.settings.subtitle != blank %}
      <p class="ai-blog-article__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}<div class="ai-blog-article__meta-{{ ai_gen_id }}">
      {% if block.settings.publish_date != blank %}
        <div class="ai-blog-article__date-{{ ai_gen_id }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          <span>{{ block.settings.publish_date }}</span>
        </div>
      {% endif %}
      
      {% if block.settings.read_time != blank %}
        <div class="ai-blog-article__read-time-{{ ai_gen_id }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12,6 12,12 16,14"></polyline></svg>
          <span>{{ block.settings.read_time }} min read</span>
        </div>
      {% endif %}
    </div>
  </header>

  <div class="ai-blog-article__content-{{ ai_gen_id }}">
    {% if block.settings.opening_paragraph != blank %}
      <div class="ai-blog-article__opening-paragraph-{{ ai_gen_id }}">
        {{ block.settings.opening_paragraph }}
      </div>
    {% endif %}

    {% if block.settings.image_1 %}
      <div class="ai-blog-article__first-image-{{ ai_gen_id }}">
        <div class="ai-blog-article__image-wrapper-{{ ai_gen_id }}"><img
            src="{{ block.settings.image_1 | image_url: width: 800}}"
            alt="{{ block.settings.image_1.alt | escape }}"
            class="ai-blog-article__image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image_1.width }}"
            height="{{ block.settings.image_1.height }}"
          ></div>
      </div>
    {% else %}
      <div class="ai-blog-article__first-image-{{ ai_gen_id }}">
        <div class="ai-blog-article__image-wrapper-{{ ai_gen_id }}">
          <div class="ai-blog-article__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.main_content != blank %}
      <div class="ai-blog-article__main-content-{{ ai_gen_id }}">
        {{ block.settings.main_content }}
      </div>
    {% endif %}

    {% if block.settings.quote_text != blank %}
      <blockquote class="ai-blog-article__quote-{{ ai_gen_id }}">
        <p class="ai-blog-article__quote-text-{{ ai_gen_id }}">{{ block.settings.quote_text }}</p>
      </blockquote>
    {% endif %}

    {% if block.settings.image_2 %}
      <div class="ai-blog-article__second-image-{{ ai_gen_id }}">
        <div class="ai-blog-article__image-wrapper-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.image_2 | image_url: width: 800 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            class="ai-blog-article__image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image_2.width }}"
            height="{{ block.settings.image_2.height }}"
          >
        </div>
      </div>
    {% endif %}

    {% if block.settings.additional_content != blank %}
      <div class="ai-blog-article__main-content-{{ ai_gen_id }}">
        {{ block.settings.additional_content }}
      </div>
    {% endif %}
  </div><div class="ai-blog-article__author-card-{{ ai_gen_id }}">
    <div class="ai-blog-article__author-photo-{{ ai_gen_id }}">
      {% if block.settings.author_photo %}
        <img
          src="{{ block.settings.author_photo | image_url: width: 160}}"
          alt="{{ block.settings.author_name | escape }}"
          loading="lazy"
        >
      {% else %}
        <div class="ai-blog-article__author-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-blog-article__author-info-{{ ai_gen_id }}">
      {% if block.settings.author_name != blank %}
        <h3 class="ai-blog-article__author-name-{{ ai_gen_id }}">{{ block.settings.author_name }}</h3>
      {% endif %}
      {% if block.settings.author_bio != blank %}
        <p class="ai-blog-article__author-bio-{{ ai_gen_id }}">{{ block.settings.author_bio }}</p>
      {% endif %}
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Blog Article Template",
  "settings": [
    {
      "type": "header",
      "content": "Article Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Article title",
      "default": "The Future of Modern Design"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Article subtitle",
      "default": "Exploring innovative approaches to contemporary aesthetics"
    },
    {
      "type": "text",
      "id": "publish_date",
      "label": "Publish date",
      "default": "March 15, 2024"
    },
    {
      "type": "text",
      "id": "read_time",
      "label": "Read time (minutes)",
      "default": "5"
    },
    {
      "type": "richtext",
      "id": "opening_paragraph",
      "label": "Opening paragraph",
      "default": "<p>This compelling opening paragraph draws readers in with an engaging introduction to the topic. It sets the tone for the entire article and provides a preview of what's to come.</p>"
    },
    {
      "type": "richtext",
      "id": "main_content",
      "label": "Main content",
      "default": "<p>Here you can add the main body of your article. This section appears after the first image and continues the narrative established in your opening paragraph.</p>"
    },
    {
      "type": "text",
      "id": "quote_text",
      "label": "Featured quote",
      "default": "Great design is not just what it looks like and feels like. Great design is how it works."
    },
    {
      "type": "richtext",
      "id": "additional_content",
      "label": "Additional content",
      "default": "<p>Add any additional paragraphs, conclusions, or final thoughts here. This content appears after the second image.</p>"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "First image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Second image (optional)"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Author Information"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author name",
      "default": "Jane Smith"
    },
    {
      "type": "textarea",
      "id": "author_bio",
      "label": "Author bio",
      "default": "Jane is a design expert with over 10 years of experience in creating beautiful, functional spaces. She specializes in modern aesthetics and sustainable design practices."
    },
    {
      "type": "image_picker",
      "id": "author_photo",
      "label": "Author photo"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "helvetica_n4"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 36
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size",
      "default": 18
    },
    {
      "type": "range",
      "id": "opening_paragraph_size",
      "min": 16,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Opening paragraph size",
      "default": 20
    },
    {
      "type": "range",
      "id": "content_size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Content size",
      "default": 16
    },
    {
      "type": "range",
      "id": "quote_size",
      "min": 16,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Quote size",
      "default": 20
    },
    {
      "type": "range",
      "id": "author_name_size",
      "min": 16,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Author name size",
      "default": 18
    },
    {
      "type": "range",
      "id": "author_bio_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Author bio size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "opening_text_color",
      "label": "Opening paragraph color",
      "default": "#2c2c2c"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Meta text color",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#007bff"
    },
    {
      "type": "color",
      "id": "quote_bg_color",
      "label": "Quote background color",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "quote_text_color",
      "label": "Quote text color",
      "default": "#495057"
    },
    {
      "type": "color",
      "id": "author_card_bg",
      "label": "Author card background",
      "default": "#f8f9fa"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Blog Article Template"
    }
  ]
}
{% endschema %}