    <div class="ai-company-bio-main-card-{{ ai_gen_id }}">
      <div class="ai-company-bio-main-content-{{ ai_gen_id }}">
        <div class="ai-company-bio-content-{{ ai_gen_id }}">
          {% if block.settings.tagline != blank %}
            <p class="ai-company-bio-tagline-{{ ai_gen_id }}">{{ block.settings.tagline }}</p>
          {% endif %}

          {% if block.settings.company_name != blank %}
            <h2 class="ai-company-bio-heading-{{ ai_gen_id }}">
              {{ block.settings.company_name_prefix }}<span class="ai-company-bio-heading-highlight-{{ ai_gen_id }}">{{ block.settings.company_name }}</span>
              {{ block.settings.company_name_suffix }}
            </h2>
          {% endif %}

          {% if block.settings.company_description != blank %}
            <div class="ai-company-bio-description-{{ ai_gen_id }}">
              {{ block.settings.company_description }}
              {% if block.settings.description_link_text != blank and block.settings.description_link_url != blank %}
                <a
                  class="ai-company-bio-description-link-{{ ai_gen_id }}"
                  href="{{ block.settings.description_link_url }}"
                  {% if block.settings.description_link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                >
                  {{ block.settings.description_link_text }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>

        <div class="ai-company-bio-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.company_image %}
            <img
              src="{{ block.settings.company_image | image_url: width: 1000 }}"
              alt="{{ block.settings.company_image.alt | escape }}"
              class="ai-company-bio-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.company_image.width }}"
              height="{{ block.settings.company_image.height }}"
            >
          {% else %}
            <div class="ai-company-bio-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-company-bio-empty-state-{{ ai_gen_id }}">
                Add wellness center image
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      {% if block.settings.show_stats %}
        <div class="ai-company-bio-stats-{{ ai_gen_id }}">
          {% if block.settings.stat_1_number != blank %}
            <div class="ai-company-bio-stat-{{ ai_gen_id }}">
              <span class="ai-company-bio-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_1_number }}</span>
              <div class="ai-company-bio-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_1_label }}</div>
            </div>
          {% endif %}
          {% if block.settings.stat_2_number != blank %}
            <div class="ai-company-bio-stat-{{ ai_gen_id }}">
              <span class="ai-company-bio-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_2_number }}</span>
              <div class="ai-company-bio-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_2_label }}</div>
            </div>
          {% endif %}
          {% if block.settings.stat_3_number != blank %}
            <div class="ai-company-bio-stat-{{ ai_gen_id }}">
              <span class="ai-company-bio-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_3_number }}</span>
              <div class="ai-company-bio-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_3_label }}</div>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="ai-company-bio-cards-grid-{{ ai_gen_id }}">
      {% if block.settings.show_mission %}
        <div class="ai-company-bio-card-{{ ai_gen_id }}">
          <div class="ai-company-bio-card-icon-{{ ai_gen_id }}">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2h-4"/>
              <path d="M9 11V9a3 3 0 1 1 6 0v2"/>
              <circle cx="12" cy="16" r="1"/>
            </svg>
          </div>
          <h3 class="ai-company-bio-card-title-{{ ai_gen_id }}">{{ block.settings.mission_title }}</h3>
          <div class="ai-company-bio-card-text-{{ ai_gen_id }}">
            {{ block.settings.mission_statement }}
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_vision %}
        <div class="ai-company-bio-card-{{ ai_gen_id }}">
          <div class="ai-company-bio-card-icon-{{ ai_gen_id }}">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <h3 class="ai-company-bio-card-title-{{ ai_gen_id }}">{{ block.settings.vision_title }}</h3>
          <div class="ai-company-bio-card-text-{{ ai_gen_id }}">
            {{ block.settings.vision_statement }}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Luxury wellness bio",
  "settings": [
    { "type": "header", "content": "Company information" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Premium Wellness Technology" },
    { "type": "text", "id": "company_name_prefix", "label": "Company name prefix", "default": "Elevating" },
    { "type": "text", "id": "company_name", "label": "Company name (highlighted)", "default": "Wellness" },
    { "type": "text", "id": "company_name_suffix", "label": "Company name suffix", "default": "Through Innovation" },
    {
      "type": "richtext",
      "id": "company_description",
      "label": "Company description",
      "default": "<p>We curate transformative wellness experiences through cutting-edge technology and personalized care. Our platform seamlessly connects discerning clients with world-class practitioners, creating a sanctuary of well-being that transcends traditional boundaries and elevates your journey to optimal health.</p>"
    },
    { "type": "text", "id": "description_link_text", "label": "Description trailing link text", "default": "Learn About Us" },
    { "type": "url", "id": "description_link_url", "label": "Description trailing link URL" },
    { "type": "checkbox", "id": "description_link_new_tab", "label": "Open description link in new tab", "default": true },

    { "type": "image_picker", "id": "company_image", "label": "Wellness center image" },

    { "type": "header", "content": "Mission statement" },
    { "type": "checkbox", "id": "show_mission", "label": "Show mission", "default": true },
    { "type": "text", "id": "mission_title", "label": "Mission title", "default": "Our Purpose" },
    {
      "type": "richtext",
      "id": "mission_statement",
      "label": "Mission statement",
      "default": "<p>To democratize access to premium wellness experiences through innovative technology, creating a seamless bridge between world-class practitioners and individuals seeking transformative health journeys in an atmosphere of luxury and care.</p>"
    },

    { "type": "header", "content": "Vision statement" },
    { "type": "checkbox", "id": "show_vision", "label": "Show vision", "default": true },
    { "type": "text", "id": "vision_title", "label": "Vision title", "default": "Our Future" },
    {
      "type": "richtext",
      "id": "vision_statement",
      "label": "Vision statement",
      "default": "<p>A world where exceptional wellness is accessible to all, where technology enhances human connection rather than replacing it, and where every individual has the tools and support to achieve their highest potential for well-being and vitality.</p>"
    },

    { "type": "header", "content": "Statistics" },
    { "type": "checkbox", "id": "show_stats", "label": "Show statistics", "default": true },
    { "type": "text", "id": "stat_1_number", "label": "Statistic 1 number", "default": "25K+" },
    { "type": "text", "id": "stat_1_label", "label": "Statistic 1 label", "default": "Wellness journeys" },
    { "type": "text", "id": "stat_2_number", "label": "Statistic 2 number", "default": "500+" },
    { "type": "text", "id": "stat_2_label", "label": "Statistic 2 label", "default": "Expert practitioners" },
    { "type": "text", "id": "stat_3_number", "label": "Statistic 3 number", "default": "98%" },
    { "type": "text", "id": "stat_3_label", "label": "Statistic 3 label", "default": "Client satisfaction" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "tagline_font_size", "min": 10, "max": 24, "step": 1, "unit": "px", "label": "Tagline font size", "default": 14 },
    { "type": "range", "id": "heading_font_size", "min": 32, "max": 120, "step": 2, "unit": "px", "label": "Main heading font size", "default": 64 },
    { "type": "range", "id": "description_font_size", "min": 14, "max": 32, "step": 1, "unit": "px", "label": "Description font size", "default": 18 },
    { "type": "range", "id": "stat_number_font_size", "min": 24, "max": 80, "step": 2, "unit": "px", "label": "Statistic number font size", "default": 48 },
    { "type": "range", "id": "stat_label_font_size", "min": 10, "max": 20, "step": 1, "unit": "px", "label": "Statistic label font size", "default": 14 },
    { "type": "range", "id": "card_title_font_size", "min": 16, "max": 36, "step": 1, "unit": "px", "label": "Card title font size", "default": 24 },
    { "type": "range", "id": "card_text_font_size", "min": 12, "max": 24, "step": 1, "unit": "px", "label": "Card text font size", "default": 16 },

    { "type": "header", "content": "Colors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#fdfbfb" },
    { "type": "color", "id": "background_gradient_color", "label": "Background gradient color", "default": "#f9f4f7" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_gradient_color", "label": "Card gradient color", "default": "#fefefe" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1a1a1a" },
    { "type": "color", "id": "accent_color", "label": "Primary accent color", "default": "#6b5b95" },
    { "type": "color", "id": "secondary_accent", "label": "Secondary accent color", "default": "#88d8c0" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "section_padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Top padding", "default": 120 },
    { "type": "range", "id": "section_padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Bottom padding", "default": 120 }
  ],
  "presets": [
    { "name": "Luxury wellness bio" }
  ]
}
{% endschema %}
