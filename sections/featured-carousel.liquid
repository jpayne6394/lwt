{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .featured-carousel-{{ section.id }} .section-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .featured-carousel-{{ section.id }} .section-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .featured-carousel-{{ section.id }} .featured-carousel__grid {
    display: grid;
    gap: var(--lwt-space-lg, 2rem);
    grid-template-columns: 1fr;
  }
  @media screen and (min-width: 750px) {
    .featured-carousel-{{ section.id }} .featured-carousel__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }
{%- endstyle -%}

{%- liquid
  assign post_limit = section.settings.post_limit
  assign articles_to_show = blog.articles | default: '' | size
  if blog.articles_count > 0
    assign articles_to_show = post_limit
    if blog.articles_count < post_limit
      assign articles_to_show = blog.articles_count
    endif
  endif
-%}

<div class="featured-carousel featured-carousel-{{ section.id }}">
  <div class="page-width section-padding">
    {%- unless section.settings.heading == blank -%}
      <div class="title-wrapper-with-link title-wrapper--no-top-margin" style="margin-bottom: var(--lwt-space-lg, 2rem);">
        <h2 class="featured-carousel__heading inline-richtext {{ section.settings.heading_size | default: 'h2' }}">
          {{ section.settings.heading | escape }}
        </h2>
        {%- if section.settings.show_view_all and blog.articles_count > post_limit -%}
          <a href="{{ blog.url }}" class="link underlined-link">
            {{ 'sections.featured_blog.view_all' | t }}
          </a>
        {%- endif -%}
      </div>
    {%- endunless -%}

    {%- if blog.articles_count > 0 -%}
      <ul class="featured-carousel__grid list-unstyled" role="list">
        {%- for article in blog.articles limit: section.settings.post_limit -%}
          <li class="featured-carousel__item">
            {%- render 'article-card',
              blog: blog,
              article: article,
              media_height: 'small',
              media_aspect_ratio: article.image.aspect_ratio,
              show_image: section.settings.show_image,
              show_date: section.settings.show_date,
              show_author: section.settings.show_author,
              show_excerpt: true
            -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- elsif has_blog -%}
      <p class="rte">{{ 'blogs.general.no_articles' | t }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Posts"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "Number of posts",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show “View all” link",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Default",
      "category": "Blog"
    }
  ]
}
{% endschema %}
