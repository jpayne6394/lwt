<!-- meet-the-experts.liquid -->

<section class="meet-experts">
  <div class="meet-experts-inner">
    <div class="meet-experts-image">
      <img src="{{ section.settings.image | image_url: width: 800 }}" alt="Our Experts" loading="lazy">
    </div>
    <div class="meet-experts-text">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.paragraph }}</p>
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="button">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

<style>
.meet-experts {
  max-width: 1400px;
  margin: 4rem auto;
  padding: 0 5rem;
}

.meet-experts-inner {
  display: flex;
  gap: 6rem;
  align-items: center;
  justify-content: center;
  max-width: 1400px;
  margin: 4rem auto;
  flex-wrap: wrap;
}

/* image on desktop */
.meet-experts-image {
  flex: 1 1 380px;
  max-width: 600px;
}

.meet-experts-image img {
  width: 100%;
  height: auto;
  border-radius: 22px;
  object-fit: cover;
  box-shadow: 
    0 45px 90px rgba(0,0,0,0.1),
    0 -20px 40px rgba(0,0,0,0.1),
    30px 0 50px rgba(0,0,0,0.15);
}

/* text card on desktop */
.meet-experts-text {
  background: linear-gradient(135deg, #ffffff, #faf6ff);
  border: 1px solid rgba(74, 60, 132, 0.06);
  border-radius: 20px;
  box-shadow:
    inset 0 6px 12px rgba(0,0,0,0.08),
    inset 0 -4px 8px rgba(0,0,0,0.05);
  padding: 4rem 3rem;
  max-width: 600px;
  flex: 1 1 380px;
  position: relative;
  overflow: hidden;
}

.meet-experts-text::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(
    45deg,
    rgba(74,60,132,0.015) 0 1px,
    transparent 1px 8px
  );
  opacity: 0.5;
  pointer-events: none;
  border-radius: 20px;
}

.meet-experts-text h2 {
  font-size: 2.5rem;
  color: #2c1e4a;
  margin-bottom: 1.2rem;
}

.meet-experts-text p {
  font-size: 1.35rem;
  line-height: 1.8;
  color: #555;
  margin-bottom: 2.2rem;
}

.meet-experts-text .button {
  display: inline-block;
  background: #4A3C84;
  color: #fff;
  padding: 1.3rem 3.1rem;
  font-size: 1.5rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  line-height: 1.2;
  border-radius: 9999px;
  text-decoration: none;
  border: 2px solid rgba(255, 255, 255, 0.8);
  box-shadow: 
    0 8px 15px rgba(0,0,0,0.15),
    0 2px 6px rgba(0,0,0,0.15);
  transition: all 0.3s ease;
}

.meet-experts-text .button:hover {
  background: #3A2F6E;
  box-shadow: 
    0 12px 28px rgba(0,0,0,0.13),
    0 4px 8px rgba(0,0,0,0.13);
  transform: translateY(-2px);
}

/* ✅ MOBILE & SMALL TABLETS (matches vision/mission cards) */
@media (max-width: 768px) {
  .meet-experts-inner {
    display: block;
    max-width: 600px;
    margin: 2rem auto;
    padding: 0;
  }

  /* make the text card the unified card */
  .meet-experts-text {
    background: linear-gradient(135deg, #ffffff, #faf6ff);
    border: 1px solid rgba(74, 60, 132, 0.06);
    border-radius: 20px;
    box-shadow: 0 12px 36px rgba(0,0,0,0.06);
    padding: 2.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .meet-experts-text::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      rgba(74,60,132,0.015) 0 1px,
      transparent 1px 8px
    );
    opacity: 0.5;
    pointer-events: none;
    border-radius: 20px;
    z-index: 1;
  }

  .meet-experts-text h2,
  .meet-experts-text p,
  .meet-experts-text .button,
  .meet-experts-text .meet-experts-image {
    position: relative;
    z-index: 2;
  }

  .meet-experts-text h2 {
    font-size: 2rem;
    margin-bottom: 1.2rem;
  }

  /* move the image into the card */
  .meet-experts-image {
    width: 100%;
    margin-bottom: 1.5rem;
    border-radius: 15px;
    overflow: hidden;
  }

  .meet-experts-image img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 15px;
    box-shadow: none;
  }

  .meet-experts-text p {
    font-size: 1.2rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .meet-experts-text .button {
    display: inline-block;
    background: #4A3C84;
    color: #fff;
    padding: 1.1rem 2.5rem;
    font-size: 1.4rem;
    font-weight: 600;
    border-radius: 9999px;
    text-decoration: none;
    border: 2px solid rgba(255, 255, 255, 0.8);
    box-shadow: 
      0 8px 15px rgba(0,0,0,0.15),
      0 2px 6px rgba(0,0,0,0.15);
    transition: all 0.3s ease;
  }

  .meet-experts-text .button:hover {
    background: #3A2F6E;
    box-shadow: 
      0 12px 28px rgba(0,0,0,0.13),
      0 4px 8px rgba(0,0,0,0.13);
    transform: translateY(-2px);
  }
}



</style>

{% schema %}
{
  "name": "Meet the Experts",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Expert Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Experts. Real Results."
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Description",
      "default": "Our experienced practitioners bring decades of functional wellness knowledge to guide your healing journey."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Meet the Team"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Meet the Experts"
    }
  ]
}
{% endschema %}
