{% comment %}
  SECTION: About Intro Card
  FILE NAME: about-intro-card.liquid
  Improved: eyebrow, accent bar, link-as-button, logo alt, full schema controls.
{% endcomment %}

<section class="about-card-section lwt-card lwt-section{% if section.settings.show_accent %} about-card-section--accent{% endif %}" id="about-card-{{ section.id }}">
  <style>
    .about-card-section {
      background: var(--lwt-surface);
      border-radius: var(--lwt-radius-card);
      margin: var(--lwt-space-2xl) auto;
      padding: var(--lwt-space-xl) var(--lwt-space-lg);
      max-width: var(--lwt-content-max-width);
      box-shadow: var(--lwt-shadow-card);
      border: 1px solid var(--lwt-border);
      transition: box-shadow var(--lwt-transition-base), border-color var(--lwt-transition-base);
      display: grid;
      grid-template-columns: 1fr;
      align-items: center;
      gap: var(--lwt-space-xl);
      position: relative;
    }
    .about-card-section--accent {
      padding-left: calc(var(--lwt-space-lg) + 4px);
      border-left: 4px solid var(--lwt-primary);
    }

    @media (min-width: 768px) {
      .about-card-section {
        grid-template-columns: {{ section.settings.logo_width }}px 1fr;
        padding: var(--lwt-space-2xl) var(--lwt-space-xl);
      }
      .about-card-section--accent {
        padding-left: calc(var(--lwt-space-xl) + 4px);
      }
    }

    #about-card-{{ section.id }} .about-logo img {
      width: 100%;
      max-width: 120px;
      height: auto;
    }
    @media (min-width: 768px) {
      #about-card-{{ section.id }} .about-logo img {
        max-width: {{ section.settings.logo_width }}px;
      }
    }

    #about-card-{{ section.id }} .about-text {
      text-align: {{ section.settings.text_align }};
    }
    #about-card-{{ section.id }} .about-eyebrow {
      font-size: {{ section.settings.eyebrow_size }}px;
      color: {{ section.settings.eyebrow_color }};
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: var(--lwt-space-xs);
    }
    {% if section.settings.eyebrow_font != blank %}
    #about-card-{{ section.id }} .about-eyebrow {
        font-family: {{ section.settings.eyebrow_font.family }}, {{ section.settings.eyebrow_font.fallback_families }};
      }
    {% endif %}

    #about-card-{{ section.id }} .about-heading {
      margin: 0 0 var(--lwt-space-sm);
      font-size: {{ section.settings.heading_size | default: 24 }}px;
      color: {{ section.settings.heading_color | default: 'var(--lwt-primary)' }};
      font-weight: {{ section.settings.heading_weight | default: 700 }};
      line-height: var(--lwt-line-height-tight);
      {% if section.settings.heading_font != blank %}
        font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
      {% endif %}
    }

    #about-card-{{ section.id }} .about-text p {
      font-size: {{ section.settings.paragraph_size | default: 17 }}px;
      color: {{ section.settings.paragraph_color | default: 'var(--lwt-primary-light)' }};
      line-height: {{ section.settings.paragraph_line_height | default: 1.65 }};
      margin-bottom: var(--lwt-space-md);
      font-weight: {{ section.settings.paragraph_weight | default: 400 }};
      max-width: 42em;
      {% if section.settings.paragraph_font != blank %}
        font-family: {{ section.settings.paragraph_font.family }}, {{ section.settings.paragraph_font.fallback_families }};
      {% endif %}
    }
    #about-card-{{ section.id }} .about-text.text-align-center p,
    #about-card-{{ section.id }} .about-text.text-align-right p {
      max-width: none;
    }

    #about-card-{{ section.id }} .about-text a.about-link {
      font-weight: 600;
      color: {{ section.settings.link_color | default: 'var(--lwt-primary)' }};
      text-decoration: underline;
      transition: color var(--lwt-transition-base);
    }
    #about-card-{{ section.id }} .about-text a.about-link:hover {
      color: {{ section.settings.link_hover_color | default: 'var(--lwt-primary-dark)' }};
    }
    #about-card-{{ section.id }} .about-text a.about-link-button {
      display: inline-block;
      padding: 0.75em 1.5em;
      background: {{ section.settings.link_color | default: 'var(--lwt-primary)' }};
      color: {{ section.settings.link_text_color | default: '#ffffff' }};
      text-decoration: none;
      border-radius: var(--lwt-radius-button);
      font-weight: 600;
      letter-spacing: 0.02em;
      box-shadow: var(--lwt-shadow-button);
      transition: background-color var(--lwt-transition-base), color var(--lwt-transition-base), box-shadow var(--lwt-transition-base), transform var(--lwt-transition-fast);
    }
    #about-card-{{ section.id }} .about-text a.about-link-button:hover {
      background: {{ section.settings.link_hover_color | default: 'var(--lwt-primary-dark)' }};
      color: {{ section.settings.link_text_color | default: '#ffffff' }};
      box-shadow: var(--lwt-shadow-button-hover);
      transform: translateY(-1px);
    }
    #about-card-{{ section.id }} .about-text a.about-link-button:focus-visible {
      outline: none;
      box-shadow: var(--lwt-shadow-focus);
    }

    @media (max-width: 767px) {
      #about-card-{{ section.id }} { text-align: center; }
      #about-card-{{ section.id }}.about-card-section--accent { padding-left: var(--lwt-space-lg); border-left: none; border-top: 4px solid var(--lwt-primary); padding-top: var(--lwt-space-lg); }
      #about-card-{{ section.id }} .about-logo { display: flex; justify-content: center; }
      #about-card-{{ section.id }} .about-text { text-align: center !important; margin-left: auto; margin-right: auto; max-width: 34rem; }
      #about-card-{{ section.id }} .about-text p { margin-left: auto; margin-right: auto; }
      #about-card-{{ section.id }} .about-text a { display: inline-block; }
    }
  </style>

  <div class="about-logo">
    {% if section.settings.logo %}
      <img
        src="{{ section.settings.logo | image_url: width: 400 }}"
        alt="{{ section.settings.logo_alt | default: 'Company logo' }}"
        width="{{ section.settings.logo_width }}"
        height="{{ section.settings.logo_width | times: 0.5 | round }}"
        loading="lazy"
      >
    {% endif %}
  </div>

  <div class="about-text {{ section.settings.text_align | prepend: 'text-align-' }}">
    {% if section.settings.eyebrow_text != blank %}
      <p class="about-eyebrow">{{ section.settings.eyebrow_text }}</p>
    {% endif %}
    <h2 class="about-heading">{{ section.settings.heading_text | default: 'Serving Since 1999' }}</h2>
    <p>{{ section.settings.paragraph_text | default: 'We help you uncover root causes with functional medicine, personalized insights, and care for the whole person—so you can take charge of your health for good.' }}</p>
    {% if section.settings.link_label != blank and section.settings.link != blank %}
      {% if section.settings.link_as_button %}
        <a href="{{ section.settings.link }}" class="about-link-button">{{ section.settings.link_label }}</a>
      {% else %}
        <a href="{{ section.settings.link }}" class="about-link">{{ section.settings.link_label }}</a>
      {% endif %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "About Intro Card",
  "settings": [
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "text", "id": "logo_alt", "label": "Logo alt text", "default": "Company logo", "info": "For accessibility" },
    { "type": "range", "id": "logo_width", "label": "Logo width (desktop)", "min": 80, "max": 200, "step": 8, "unit": "px", "default": 140 },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow / tagline", "default": "Trusted in Functional Medicine", "info": "Optional short line above the heading" },
    { "type": "text", "id": "heading_text", "label": "Heading", "default": "Serving Since 1999" },
    { "type": "textarea", "id": "paragraph_text", "label": "Paragraph text", "default": "We’ve helped thousands uncover root causes with functional medicine, advanced insights, and deep care for the whole person." },

    { "type": "header", "content": "Link" },
    { "type": "url", "id": "link", "label": "Link URL" },
    { "type": "text", "id": "link_label", "label": "Link text", "default": "Our Story →" },
    { "type": "checkbox", "id": "link_as_button", "label": "Show link as button", "default": true },
    { "type": "color", "id": "link_color", "label": "Link / button color", "default": "#4b3f82" },
    { "type": "color", "id": "link_hover_color", "label": "Link / button hover color", "default": "#3d3268" },
    { "type": "color", "id": "link_text_color", "label": "Button text color", "default": "#ffffff", "info": "When link is shown as button" },

    { "type": "header", "content": "Appearance" },
    { "type": "checkbox", "id": "show_accent", "label": "Show accent bar", "default": true, "info": "Purple bar on the left (desktop) or top (mobile)" },

    { "type": "header", "content": "Typography" },
    { "type": "font_picker", "id": "eyebrow_font", "label": "Eyebrow font", "default": "montserrat_n4" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "montserrat_n4" },
    { "type": "font_picker", "id": "paragraph_font", "label": "Paragraph font", "default": "montserrat_n4" },

    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#4b3f82" },
    { "type": "range", "id": "eyebrow_size", "label": "Eyebrow size", "min": 11, "max": 16, "step": 1, "unit": "px", "default": 12 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#3b1e5a" },
    { "type": "color", "id": "paragraph_color", "label": "Paragraph color", "default": "#5f4b80" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 14, "max": 48, "step": 1, "unit": "px", "default": 24 },
    { "type": "range", "id": "paragraph_size", "label": "Paragraph size", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 17 },
    { "type": "range", "id": "heading_weight", "label": "Heading weight", "min": 400, "max": 800, "step": 100, "default": 700 },
    { "type": "range", "id": "paragraph_weight", "label": "Paragraph weight", "min": 400, "max": 700, "step": 100, "default": 400 },
    { "type": "range", "id": "paragraph_line_height", "label": "Paragraph line height", "min": 1.3, "max": 2, "step": 0.05, "default": 1.65 },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    }
  ],
  "presets": [
    { "name": "About Intro Card" }
  ]
}
{% endschema %}

