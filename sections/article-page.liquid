<style>
  .clickable-columns-wrapper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
    align-items: stretch;
    margin: 0 auto;
    max-width: 1200px;
    padding: 60px 20px;
  }

  .clickable-tile {
    background: #fff;
    border: 1px solid #e2e2e2;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    padding: 2.5rem 1.5rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
  }

  .clickable-tile:hover {
    border-color: #ccc;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
    transform: translateY(-4px);
  }

  .tile-image {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 140px;
    margin-bottom: 1.5rem;
  }

  .tile-image img {
    max-height: 100px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.9;
  }

  .image--square img {
    aspect-ratio: 1 / 1;
  }

  .image--portrait img {
    aspect-ratio: 3 / 4;
  }

  .image--circle img {
    border-radius: 50%;
    aspect-ratio: 1 / 1;
  }

  .image--adapt img {
    height: auto;
    width: auto;
    max-width: 100px;
  }

  .clickable-tile h3 {
    font-size: 1.375rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .clickable-tile p {
    font-size: 1.125rem;
    line-height: 1.7;
    color: #333;
    max-width: 90%;
    margin: 0 auto;
  }
</style>

{% if section.settings.heading != blank %}
  <div class="section-heading" style="text-align: center; margin-bottom: 2rem;">
    <h2>{{ section.settings.heading }}</h2>
  </div>
{% endif %}

<div class="clickable-columns-wrapper page-width">
  {% for block in section.blocks %}
    {% assign image = block.settings.image %}
    {% assign title = block.settings.title %}
    {% assign text = block.settings.text %}
    {% assign link = block.settings.link %}
    {% if link != blank %}
      <a href="{{ link }}" class="clickable-tile" {{ block.shopify_attributes }}>
    {% else %}
      <div class="clickable-tile" {{ block.shopify_attributes }}>
    {% endif %}

        {% if image != blank %}
          <div class="tile-image image--{{ section.settings.image_ratio }}">
            <img src="{{ image | image_url: width: 300 }}" alt="{{ title | escape }}">
          </div>
        {% endif %}

        {% if title != blank %}
          <h3>{{ title }}</h3>
        {% endif %}

        {% if text != blank %}
          <p>{{ text }}</p>
        {% endif %}

    {% if link != blank %}
      </a>
    {% else %}
      </div>
    {% endif %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Clickable Columns",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "What Makes Us Different"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "default": "adapt",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "circle", "label": "Circle" }
      ]
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Number of columns on desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "radio",
      "id": "column_alignment",
      "label": "Column alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select",
      "id": "background",
      "label": "Secondary background",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "background-1", "label": "Scheme 1" },
        { "value": "background-2", "label": "Scheme 2" }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-6",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" },
        { "value": "scheme-5", "label": "Scheme 5" },
        { "value": "scheme-6", "label": "Scheme 6" }
      ]
    },
    {
      "type": "radio",
      "id": "columns_mobile",
      "label": "Number of columns on mobile",
      "default": "1",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ]
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "label": "Enable swipe on mobile",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Column title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Column description goes here."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clickable Columns",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
