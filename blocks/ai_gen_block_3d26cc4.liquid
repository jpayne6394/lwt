{% doc %}
  @prompt
    Create a fun and engaging blog article template with the following features: a prominent title section, subtitle area, content area that supports embedded images, an attractive author card with photo and bio, and stylized quote blocks. Make it visually appealing with modern typography, good spacing, and responsive design that works well on all devices.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-article-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    line-height: 1.6;}

  .ai-blog-article__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.title_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
    padding-bottom: {{ block.settings.header_spacing | divided_by: 2 }}px;
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
  }

  .ai-blog-article__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-blog-article__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    font-weight: 400;
    opacity: 0.8;
  }

  .ai-blog-article__meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.title_alignment }};
    gap: 20px;
    margin-top: {{ block.settings.title_spacing }}px;font-size: 14px;
    color: {{ block.settings.meta_color }};
  }

  .ai-blog-article__date-{{ ai_gen_id }},
  .ai-blog-article__read-time-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-blog-article__content-{{ ai_gen_id }} {
    margin: {{ block.settings.content_spacing }}px 0;
  }

  .ai-blog-article__content-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px 0;
    font-size: {{ block.settings.content_size }}px;
  }

  .ai-blog-article__content-{{ ai_gen_id }} h2,
  .ai-blog-article__content-{{ ai_gen_id }} h3,
  .ai-blog-article__content-{{ ai_gen_id }} h4 {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    color: {{ block.settings.heading_color }};
    margin: {{ block.settings.heading_spacing }}px 0 {{ block.settings.heading_spacing | divided_by: 2 }}px 0;
    line-height: 1.3;
  }

  .ai-blog-article__content-{{ ai_gen_id }} h2 {
    font-size: {{ block.settings.h2_size }}px;
  }

  .ai-blog-article__content-{{ ai_gen_id }} h3 {
    font-size: {{ block.settings.h3_size }}px;
  }

  .ai-blog-article__content-{{ ai_gen_id }} h4 {
    font-size: {{ block.settings.h4_size }}px;
  }

  .ai-blog-article__image-{{ ai_gen_id }} {
    margin: {{ block.settings.image_spacing }}px 0;
    text-align: center;
  }

  .ai-blog-article__image-{{ ai_gen_id }} img {
    max-width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-blog-article__image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-blog-article__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 300px;
    object-fit: cover;}

  .ai-blog-article__quote-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.quote_bg_color }}, {{ block.settings.quote_bg_color }}dd);
    border-left: {{ block.settings.quote_border_width }}px solid {{ block.settings.quote_accent_color }};
    padding: {{ block.settings.quote_padding }}px;
    margin: {{ block.settings.quote_spacing }}px 0;
    border-radius: 0 {{ block.settings.quote_border_radius }}px {{ block.settings.quote_border_radius }}px 0;
    position: relative;
    box-shadow: 0 2px 15px rgba(0, 0, 0, 0.08);
  }

  .ai-blog-article__quote-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_text_size }}px;
    font-style: italic;
    color: {{ block.settings.quote_text_color }};
    margin: 00 {{ block.settings.quote_spacing | divided_by: 2 }}px 0;
    line-height: 1.5;
    position: relative;}

  .ai-blog-article__quote-text-{{ ai_gen_id }}::before {
    content: '"';
    font-size: {{ block.settings.quote_text_size | times: 2 }}px;
    color: {{ block.settings.quote_accent_color }};
    position: absolute;
    left: -15px;
    top: -10px;
    font-family: serif;
    line-height: 1;
  }

  .ai-blog-article__quote-author-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_author_size }}px;
    color: {{ block.settings.quote_author_color }};
    font-weight: 600;
    text-align: right;
    margin: 0;
  }

  .ai-blog-article__quote-author-{{ ai_gen_id }}::before {
    content: '— ';
  }

  .ai-blog-article__author-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.author_card_bg }};
    border-radius: {{ block.settings.author_card_radius }}px;
    padding: {{ block.settings.author_card_padding }}px;
    margin: {{ block.settings.author_card_spacing }}px 0;
    display: flex;
    align-items: center;
    gap: {{ block.settings.author_card_padding }}px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border:1px solid {{ block.settings.author_card_border }};
  }

  .ai-blog-article__author-image-{{ ai_gen_id }} {
    width: {{ block.settings.author_image_size }}px;
    height: {{ block.settings.author_image_size }}px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: #f4f4f4;
  }

  .ai-blog-article__author-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-article__author-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;}

  .ai-blog-article__author-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.5;
  }

  .ai-blog-article__author-info-{{ ai_gen_id }} {
    flex-grow: 1;}

  .ai-blog-article__author-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_name_size }}px;
    font-weight: 600;
    color: {{ block.settings.author_name_color }};
    margin: 0 0 8px 0;font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
  }

  .ai-blog-article__author-bio-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_bio_size }}px;
    color: {{ block.settings.author_bio_color }};
    margin: 0;
    line-height: 1.4;
  }

  @media screen and (max-width: 768px) {
    .ai-blog-article-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | divided_by: 2 }}px 16px;
    }

    .ai-blog-article__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-blog-article__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-blog-article__content-{{ ai_gen_id }} h2 {
      font-size: {{ block.settings.h2_size | times: 0.85 }}px;
    }

    .ai-blog-article__content-{{ ai_gen_id }} h3 {
      font-size: {{ block.settings.h3_size | times: 0.85 }}px;
    }

    .ai-blog-article__content-{{ ai_gen_id }} h4 {
      font-size: {{ block.settings.h4_size | times: 0.85 }}px;
    }

    .ai-blog-article__meta-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 10px;
      align-items: flex-start;
    }

    .ai-blog-article__author-card-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;gap: {{ block.settings.author_card_padding | divided_by: 2 }}px;
    }

    .ai-blog-article__quote-{{ ai_gen_id }} {
      padding: {{ block.settings.quote_padding | times: 0.75 }}px;
    }

    .ai-blog-article__quote-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_text_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-blog-article__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-blog-article__author-image-{{ ai_gen_id }} {
      width: {{ block.settings.author_image_size | times: 0.8 }}px;
      height: {{ block.settings.author_image_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<article class="ai-blog-article-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <header class="ai-blog-article__header-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h1 class="ai-blog-article__title-{{ ai_gen_id }}">{{ block.settings.title }}</h1>
    {% endif %}
    
    {% if block.settings.subtitle != blank %}
      <p class="ai-blog-article__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}

    {% if block.settings.show_meta %}
      <div class="ai-blog-article__meta-{{ ai_gen_id }}">
        {% if block.settings.publish_date != blank %}
          <div class="ai-blog-article__date-{{ ai_gen_id }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <span>{{ block.settings.publish_date }}</span>
          </div>
        {% endif %}
        
        {% if block.settings.read_time != blank %}
          <div class="ai-blog-article__read-time-{{ ai_gen_id }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12,6 12,12 16,14"></polyline></svg>
            <span>{{ block.settings.read_time }} min read</span>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </header>

  <div class="ai-blog-article__content-{{ ai_gen_id }}">
    {% if block.settings.content != blank %}
      {{ block.settings.content }}
    {% else %}
      <p>This is where your blog content will appear. You can add paragraphs, headings, and format your text using the rich text editor.</p><h2>Sample Heading</h2>
      <p>This is a sample paragraph to demonstrate the typography and spacing of your blog article. The text is designed to be highly readable with proper line height and font sizing.</p>
      
      <h3>Another Section</h3>
      <p>You can create multiple sections in your blog post with different heading levels. Each section will maintain consistent spacing and typography throughout your article.</p>
    {% endif %}

    {% if block.settings.featured_image %}
      <div class="ai-blog-article__image-{{ ai_gen_id }}">
        <img
          src="{{ block.settings.featured_image | image_url: width: 1200 }}"
          alt="{{ block.settings.featured_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.featured_image.width }}"
          height="{{ block.settings.featured_image.height }}"
        >
      </div>
    {% elsif block.settings.show_placeholder_image %}
      <div class="ai-blog-article__image-{{ ai_gen_id }}">
        <div class="ai-blog-article__image-placeholder-{{ ai_gen_id }}">
          {{ 'detailed-apparel-1' | placeholder_svg_tag }}
        </div>
      </div>
    {% endif %}

    {% if block.settings.quote_text != blank %}
      <blockquote class="ai-blog-article__quote-{{ ai_gen_id }}">
        <p class="ai-blog-article__quote-text-{{ ai_gen_id }}">{{ block.settings.quote_text }}</p>
        {% if block.settings.quote_author != blank %}
          <cite class="ai-blog-article__quote-author-{{ ai_gen_id }}">{{ block.settings.quote_author }}</cite>
        {% endif %}
      </blockquote>
    {% endif %}
  </div>

  {% if block.settings.show_author_card %}
    <div class="ai-blog-article__author-card-{{ ai_gen_id }}">
      <div class="ai-blog-article__author-image-{{ ai_gen_id }}">
        {% if block.settings.author_image %}
          <img
            src="{{ block.settings.author_image | image_url: width: 200 }}"
            alt="{{ block.settings.author_name | escape }}"
            loading="lazy"
            width="200"
            height="200"
          >
        {% else %}
          <div class="ai-blog-article__author-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      
      <div class="ai-blog-article__author-info-{{ ai_gen_id }}">
        {% if block.settings.author_name != blank %}
          <h3 class="ai-blog-article__author-name-{{ ai_gen_id }}">{{ block.settings.author_name }}</h3>
        {% endif %}
        
        {% if block.settings.author_bio != blank %}
          <div class="ai-blog-article__author-bio-{{ ai_gen_id }}">{{ block.settings.author_bio }}</div>
        {% endif %}
      </div>
    </div>
  {% endif %}
</article>

{% schema %}
{
  "name": "Blog Article Template",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Article Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Article title",
      "default": "The Future of Modern Design"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Article subtitle",
      "default": "Exploring innovative approaches to contemporary aesthetics"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Article content"
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Featured image"
    },
    {
      "type": "checkbox",
      "id": "show_placeholder_image",
      "label": "Show placeholder image if no featured image",
      "default": true
    },
    {
      "type": "header",
      "content": "Article Meta"
    },
    {
      "type": "checkbox",
      "id": "show_meta",
      "label": "Show article meta information",
      "default": true
    },
    {
      "type": "text",
      "id": "publish_date",
      "label": "Publish date",
      "default": "March 15, 2024"
    },
    {
      "type": "text",
      "id": "read_time",
      "label": "Read time (minutes)",
      "default": "5"
    },
    {
      "type": "header",
      "content": "Quote Block"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote text",
      "default": "Design is not just what it looks like and feels like. Design is how it works."
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Quote author",
      "default": "Steve Jobs"
    },
    {
      "type": "header",
      "content": "Author Card"
    },
    {
      "type": "checkbox",
      "id": "show_author_card",
      "label": "Show author card",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "Author photo"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author name",
      "default": "Jane Smith"
    },
    {
      "type": "richtext",
      "id": "author_bio",
      "label": "Author bio",
      "default": "<p>Jane is a design expert with over 10 years of experience in creating beautiful and functional digital experiences. She loves exploring new trends and sharing insights with the design community.</p>"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Maximum content width",
      "default": 800
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Section padding",
      "default": 40
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Title alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "helvetica_n4"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 42
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size",
      "default": 18
    },
    {
      "type": "range",
      "id": "content_size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Content size",
      "default": 16
    },
    {
      "type": "range",
      "id": "h2_size",
      "min": 20,
      "max": 36,
      "step": 2,
      "unit": "px",
      "label": "H2 heading size",
      "default": 28
    },
    {
      "type": "range",
      "id": "h3_size",
      "min": 18,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "H3 heading size",
      "default": 22
    },
    {
      "type": "range",
      "id": "h4_size",
      "min": 16,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "H4 heading size",
      "default": 18
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Header spacing",
      "default": 40
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 10,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Title spacing",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_spacing",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Content spacing",
      "default": 40
    },
    {
      "type": "range",
      "id": "paragraph_spacing",
      "min": 10,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Paragraph spacing",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 20,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Heading spacing",
      "default": 30
    },
    {
      "type": "range",
      "id": "image_spacing",
      "min": 20,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Image spacing",
      "default": 30
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Meta text color",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#e5e5e5"
    },
    {
      "type": "header",
      "content": "Quote Styling"
    },
    {
      "type": "color",
      "id": "quote_bg_color",
      "label": "Quote background color",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "quote_accent_color",
      "label": "Quote accent color",
      "default": "#007bff"
    },
    {
      "type": "color",
      "id": "quote_text_color",
      "label": "Quote text color",
      "default": "#2c3e50"
    },
    {
      "type": "color",
      "id": "quote_author_color",
      "label": "Quote author color",
      "default": "#6c757d"
    },
    {
      "type": "range",
      "id": "quote_text_size",
      "min": 16,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Quote text size",
      "default": 20
    },
    {
      "type": "range",
      "id": "quote_author_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Quote author size",
      "default": 14
    },
    {
      "type": "range",
      "id": "quote_padding",
      "min": 20,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Quote padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "quote_spacing",
      "min": 20,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Quote spacing",
      "default": 30
