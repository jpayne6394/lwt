{% doc %}
  @prompt
    Create a complete product page section with image gallery, product info, subscription options, quantity selector, and working Add to Cart and Buy Now buttons. Include all styling to match existing design with gallery thumbnails, price display, subscription radio buttons, and accordion sections. Ensure proper cart functionality and checkout redirect., make it exactly like product full 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .product-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 4rem;
    row-gap: 3rem;
  }

  .product__media-{{ ai_gen_id }} {
    position: sticky;
    top: 2rem;
  }

  .product__media-list-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .product__media-item-{{ ai_gen_id }} {
    border-radius: {{ settings.media_radius }}px;
    overflow: hidden;
    border: {{ settings.media_border_thickness }}px solid rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, {{ settings.media_border_opacity | divided_by: 100.0 }});
  }

  .product__media-item-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .product__media-toggle-{{ ai_gen_id }} {
    display: none;
  }

  .product__media-list-{{ ai_gen_id }} .product__media-item-{{ ai_gen_id }}:not(:first-child) {
    display: none;
  }

  .product__media-thumbs-{{ ai_gen_id }} {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .product__media-thumb-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    border-radius: {{ settings.media_radius }}px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.15s ease-in-out;
  }

  .product__media-thumb-{{ ai_gen_id }}.is-active {
    border-color: rgb({{ settings.color_schemes[settings.card_color_scheme].settings.button | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.button | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.button | color_extract: 'blue' }});
  }

  .product__media-thumb-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product__info-{{ ai_gen_id }} {
    padding-top: 0;
  }

  .product__title-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-style: {{ settings.type_header_font.style }};
    font-weight: {{ settings.type_header_font.weight }};
    color: rgb({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }});
    margin: 0 0 1.5rem;
    word-break: break-word;
    font-size: calc({{ settings.heading_scale }}% * 2.4rem / 100);
    line-height: calc(1 + 0.3 / max(1, {{ settings.heading_scale | times: 0.01 }}));
  }

  .product__text-{{ ai_gen_id }} {
    margin-bottom: 0;
  }

  .product__text-{{ ai_gen_id }}.caption-with-letter-spacing {
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .price-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    margin-bottom: 1.2rem;
  }

  .price__container-{{ ai_gen_id }} {
    display: contents;
  }

  .price-item-{{ ai_gen_id }} {
    color: rgb({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }});
    font-size: 1.5rem;
    font-weight: 400;
    line-height: calc(1 + 0.5 / max(1, 1.5 * 0.75));
  }

  .price-item--regular-{{ ai_gen_id }} {
    font-size: 1.5rem;
  }

  .price-item--sale-{{ ai_gen_id }} {
    color: rgb({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }});
    text-decoration: line-through;
  }

  .price__sale-badge-{{ ai_gen_id }} {
    align-self: flex-start;
    background-color: rgb({{ settings.color_schemes[settings.sale_badge_color_scheme].settings.background | color_extract: 'red' }}, {{ settings.color_schemes[settings.sale_badge_color_scheme].settings.background | color_extract: 'green' }}, {{ settings.color_schemes[settings.sale_badge_color_scheme].settings.background | color_extract: 'blue' }});
    border-radius: {{ settings.badge_corner_radius }}px;
    color: rgb({{ settings.color_schemes[settings.sale_badge_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.sale_badge_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.sale_badge_color_scheme].settings.text | color_extract: 'blue' }});
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1;
    margin-left: 1.2rem;
    padding: 0.6rem 1.3rem;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
  }

  .product-form-{{ ai_gen_id }} {
    display: block;
  }

  .product-form__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-top: 3.6rem;
  }

  .product-form__cart-submit-{{ ai_gen_id }} {
    margin-bottom: 0;
  }

  .btn-{{ ai_gen_id }} {
    font-family: inherit;
    cursor: pointer;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    border: 0;
    padding: 1.5rem 3rem;
    text-decoration: none;
    background-color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.button | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.button | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.button | color_extract: 'blue' }}, 1);
    color: rgb({{ settings.color_schemes[settings.card_color_scheme].settings.button_label | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.button_label | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.button_label | color_extract: 'blue' }});
    min-width: calc(12rem + var(--buttons-border-width));
    min-height: calc(4.5rem + var(--buttons-border-width));
    transition: box-shadow var(--duration-short) ease;
    position: relative;
    font-size: 1.5rem;
    letter-spacing: 0.1rem;
    line-height: calc(1 + 0.2 / max(1, 1.5 * 0.75));
    text-transform: uppercase;
    border: {{ settings.buttons_border_thickness }}px solid rgba({{ settings.color_schemes[settings.card_color_scheme].settings.button | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.button | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.button | color_extract: 'blue' }}, {{ settings.buttons_border_opacity | divided_by: 100.0 }});
    border-radius: {{ settings.buttons_radius }}px;
    box-shadow: {{ settings.buttons_shadow_horizontal_offset }}px {{ settings.buttons_shadow_vertical_offset }}px {{ settings.buttons_shadow_blur }}px rgba({{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'blue' }}, {{ settings.buttons_shadow_opacity | divided_by: 100.0 }});
  }

  .btn--secondary-{{ ai_gen_id }} {
    background-color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'blue' }}, 1);
    color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.secondary_button_label | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.secondary_button_label | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.secondary_button_label | color_extract: 'blue' }}, 1);
    border-color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.secondary_button_label | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.secondary_button_label | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.secondary_button_label | color_extract: 'blue' }}, {{ settings.buttons_border_opacity | divided_by: 100.0 }});
  }

  .btn:hover {
    box-shadow: {{ settings.buttons_shadow_horizontal_offset }}px {{ settings.buttons_shadow_vertical_offset | plus: 4 }}px {{ settings.buttons_shadow_blur | plus: 5 }}px rgba({{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'blue' }}, {{ settings.buttons_shadow_opacity | plus: 10 | divided_by: 100.0 }});
  }

  .btn:disabled,
  .btn[aria-disabled='true'] {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .product-form__input-{{ ai_gen_id }} {
    flex: 0 0 auto;
    padding: 1.5rem 2rem;
    text-decoration: none;
    text-align: center;
    border: {{ settings.inputs_border_thickness }}px solid rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, {{ settings.inputs_border_opacity | divided_by: 100.0 }});
    background-color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'blue' }}, 1);
    color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, 1);
    border-radius: {{ settings.inputs_radius }}px;
    box-shadow: {{ settings.inputs_shadow_horizontal_offset }}px {{ settings.inputs_shadow_vertical_offset }}px {{ settings.inputs_shadow_blur }}px rgba({{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'blue' }}, {{ settings.inputs_shadow_opacity | divided_by: 100.0 }});
  }

  .quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.2rem;
  }

  .quantity__label-{{ ai_gen_id }} {
    flex-shrink: 0;
    margin-right: 1.5rem;
    margin-bottom: 0;
  }

  .quantity__input-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    position: relative;
  }

  .quantity__button-{{ ai_gen_id }} {
    width: 4.5rem;
    flex-shrink: 0;
    font-size: 1.8rem;
    border: {{ settings.inputs_border_thickness }}px solid rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, {{ settings.inputs_border_opacity | divided_by: 100.0 }});
    background-color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'blue' }}, 1);
    color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, 1);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    position: relative;
    border-radius: {{ settings.inputs_radius }}px;
  }

  .quantity__input-{{ ai_gen_id }} input[type='number'] {
    background-color: transparent;
    border: 0;
    border-left: {{ settings.inputs_border_thickness }}px solid rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, {{ settings.inputs_border_opacity | divided_by: 100.0 }});
    border-right: {{ settings.inputs_border_thickness }}px solid rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, {{ settings.inputs_border_opacity | divided_by: 100.0 }});
    color: currentColor;
    font-size: 1.6rem;
    padding: 0;
    text-align: center;
    width: 5rem;
    height: 4.5rem;
  }

  .product-form__error-message-wrapper-{{ ai_gen_id }} {
    margin-top: 1.2rem;
  }

  .product-form__error-message-{{ ai_gen_id }} {
    color: rgba(var(--color-foreground), 0.75);
    font-size: 1.2rem;
  }

  .variant-picker-{{ ai_gen_id }} {
    display: block;
  }

  .variant-picker__option-{{ ai_gen_id }} {
    display: block;
    margin-bottom: 1.2rem;
  }

  .variant-picker__label-{{ ai_gen_id }} {
    font-weight: 500;
    margin-bottom: 0.5rem;
    display: block;
  }

  .variant-picker__button-{{ ai_gen_id }} {
    border: {{ settings.variant_pills_border_thickness }}px solid rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, {{ settings.variant_pills_border_opacity | divided_by: 100.0 }});
    border-radius: {{ settings.variant_pills_radius }}px;
    background-color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'blue' }}, 1);
    color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, 1);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    min-height: 4.4rem;
    min-width: 4.4rem;
    padding: 1.2rem 2rem;
    position: relative;
    transition: border-color var(--duration-short) ease;
    word-break: break-word;
    box-shadow: {{ settings.variant_pills_shadow_horizontal_offset }}px {{ settings.variant_pills_shadow_vertical_offset }}px {{ settings.variant_pills_shadow_blur }}px rgba({{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.shadow | color_extract: 'blue' }}, {{ settings.variant_pills_shadow_opacity | divided_by: 100.0 }});
  }

  .variant-picker__button-{{ ai_gen_id }}:hover {
    border-color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, 1);
  }

  .variant-picker__button-{{ ai_gen_id }}[aria-pressed='true'] {
    background-color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, 1);
    color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.background | color_extract: 'blue' }}, 1);
  }

  .product__accordion-{{ ai_gen_id }} {
    border-top: 0.1rem solid rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, 0.08);
  }

  .accordion-{{ ai_gen_id }} summary {
    cursor: pointer;
    display: flex;
    position: relative;
    line-height: 1;
    padding: 1.5rem 0;
    color: rgba({{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[settings.card_color_scheme].settings.text | color_extract: 'blue' }}, 1);
    font-size: 1.6rem;
  }

  .accordion-{{ ai_gen_id }} summary .icon {
    height: 1.6rem;
    right: 0;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 1.6rem;
  }

  .accordion-{{ ai_gen_id }}[open] summary .icon {
    transform: translateY(-50%) rotate(180deg);
  }

  .accordion-{{ ai_gen_id }} .accordion__content {
    padding-bottom: 1.5rem;
    padding-top: 0;
  }

  .accordion-{{ ai_gen_id }} .accordion__content > * {
    margin-top: 0;
  }

  .accordion-{{ ai_gen_id }} .accordion__content > *:not(.accordion__content > *:last-child) {
    margin-bottom: 1.5rem;
  }

  @media screen and (max-width: 749px) {
    .product-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }

    .product__media-{{ ai_gen_id }} {
      position: static;
      max-width: 100%;
    }

    .product__media-thumbs-{{ ai_gen_id }} {
      justify-content: center;
    }

    .product-form__buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }

  @media screen and (min-width: 750px) {
    .product-{{ ai_gen_id }} {
      padding-top: 2.4rem;
    }

    .product__info-{{ ai_gen_id }} {
      padding-top: 0;
    }

    .product__title-{{ ai_gen_id }} {
      margin-bottom: 2.5rem;
    }

    .product-form__buttons-{{ ai_gen_id }} {
      flex-direction: row;
    }

    .product-form__buttons-{{ ai_gen_id }} > * {
      flex-grow: 1;
      max-width: none;
    }
  }

  @media screen and (min-width: 990px) {
    .product-{{ ai_gen_id }} {
      column-gap: 5rem;
    }
  }
{% endstyle %}

<product-form-{{ ai_gen_id }}
  class="product product-{{ ai_gen_id }} page-width section-{{ block.id }}-padding"
  data-section="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  <div class="product__media-{{ ai_gen_id }}">
    <div class="product__media-list-{{ ai_gen_id }}">
      {% if product.featured_media %}
        <div class="product__media-item-{{ ai_gen_id }}" data-media-id="{{ product.featured_media.id }}">
          <img
            src="{{ product.featured_media | image_url: width: 1946 }}"
            alt="{{ product.featured_media.alt | escape }}"
            width="{{ product.featured_media.width }}"
            height="{{ product.featured_media.height }}"
            loading="lazy"
            class="product__media-img-{{ ai_gen_id }}"
            sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 11.5rem) / 2), calc(100vw - 4rem)"
          >
        </div>
      {% else %}
        <div class="product__media-item-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {% endif %}

      {% for media in product.media offset: 1 %}
        <div class="product__media-item-{{ ai_gen_id }}" data-media-id="{{ media.id }}">
          <img
            src="{{ media | image_url: width: 1946 }}"
            alt="{{ media.alt | escape }}"
            width="{{ media.width }}"
            height="{{ media.height }}"
            loading="lazy"
            class="product__media-img-{{ ai_gen_id }}"
            sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 11.5rem) / 2), calc(100vw - 4rem)"
          >
        </div>
      {% endfor %}
    </div>

    {% if product.media.size > 1 %}
      <div class="product__media-thumbs-{{ ai_gen_id }}">
        {% for media in product.media %}
          <button
            class="product__media-thumb-{{ ai_gen_id }} {% if forloop.first %}is-active{% endif %}"
            data-target="{{ media.id }}"
            type="button"
            aria-label="Load image {{ forloop.index }} in gallery view"
          >
            <img
              src="{{ media | image_url: width: 416 }}"
              alt="{{ media.alt | escape }}"
              width="416"
              height="416"
              loading="lazy"
            >
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="product__info-{{ ai_gen_id }}">
    {% if block.settings.show_vendor and product.vendor != blank %}
      <p class="product__text-{{ ai_gen_id }} caption-with-letter-spacing">{{ product.vendor }}</p>
    {% endif %}

    <h1 class="product__title-{{ ai_gen_id }}">
      {{ product.title | escape }}
    </h1>

    <div class="price-{{ ai_gen_id }} price--large">
      <div class="price__container-{{ ai_gen_id }}">
        <div class="price__regular-{{ ai_gen_id }}">
          <span class="visually-hidden visually-hidden--inline">Regular price</span>
          <span class="price-item price-item--regular-{{ ai_gen_id }}">
            {{ product.selected_or_first_available_variant.price | money }}
          </span>
        </div>
        <div class="price__sale-{{ ai_gen_id }}">
          {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
            <span class="visually-hidden visually-hidden--inline">Sale price</span>
            <span class="price-item price-item--sale-{{ ai_gen_id }}">
              {{ product.selected_or_first_available_variant.compare_at_price | money }}
            </span>
            <span class="price__sale-badge-{{ ai_gen_id }}">
              Sale
            </span>
          {% endif %}
        </div>
      </div>
    </div>

    {% form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" disabled>

      {% unless product.has_only_default_variant %}
        <variant-radios-{{ ai_gen_id }} class="variant-picker-{{ ai_gen_id }}" data-section="{{ block.id }}" data-url="{{ product.url }}">
          {% for option in product.options_with_values %}
            <fieldset class="variant-picker__option-{{ ai_gen_id }}">
              <legend class="variant-picker__label-{{ ai_gen_id }}">{{ option.name }}</legend>
              {% for value in option.values %}
                <input
                  type="radio"
                  id="{{ block.id }}-{{ option.position }}-{{ forloop.index0 }}"
                  name="{{ option.name }}"
                  value="{{ value | escape }}"
                  form="{{ product_form_id }}"
                  {% if option.selected_value == value %}checked{% endif %}
                  class="visually-hidden"
                >
                <label for="{{ block.id }}-{{ option.position }}-{{ forloop.index0 }}" class="variant-picker__button-{{ ai_gen_id }}">
                  {{ value }}
                </label>
              {% endfor %}
            </fieldset>
          {% endfor %}
        </variant-radios-{{ ai_gen_id }}
      {% endunless %}

      <div class="quantity-{{ ai_gen_id }}">
        <label class="quantity__label-{{ ai_gen_id }}" for="Quantity-{{ block.id }}">
          Quantity
        </label>
        <div class="quantity__input-{{ ai_gen_id }}">
          <button class="quantity__button-{{ ai_gen_id }}" name="minus" type="button">
            <span class="visually-hidden">Decrease quantity for {{ product.title | escape }}</span>
            {% render 'icon-minus' %}
          </button>
          <input
            class="quantity__input-{{ ai_gen_id }}"
            type="number"
            name="quantity"
            id="Quantity-{{ block.id }}"
            min="1"
            value="1"
            form="{{ product_form_id }}"
          >
          <button class="quantity__button-{{ ai_gen_id }}" name="plus" type="button">
            <span class="visually-hidden">Increase quantity for {{ product.title | escape }}</span>
            {% render 'icon-plus' %}
          </button>
        </div>
      </div>

      <div class="product-form__buttons-{{ ai_gen_id }}">
        <button
          type="submit"
          name="add"
          class="product-form__cart-submit-{{ ai_gen_id }} btn btn-{{ ai_gen_id }} btn--full-width"
          {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
        >
          <span>
            {% if product.selected_or_first_available_variant.available %}
              Add to cart
            {% else %}
              Sold out
            {% endif %}
          </span>
          <div class="loading-overlay__spinner hidden">
            <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
              <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
            </svg>
          </div>
        </button>

        {% if block.settings.show_dynamic_checkout %}
          {{ form | payment_button }}
        {% endif %}
      </div>
    {% endform %}

    {% if block.settings.show_description and product.description != blank %}
      <div class="product__accordion-{{ ai_gen_id }} accordion-{{ ai_gen_id }}">
        <details>
          <summary>
            <div class="summary__title">
              Description
            </div>
            {% render 'icon-caret' %}
          </summary>
          <div class="accordion__content rte">
            {{ product.description }}
          </div>
        </details>
      </div>
    {% endif %}

    {% if block.settings.show_shipping_policy %}
      <div class="product__accordion-{{ ai_gen_id }} accordion-{{ ai_gen_id }}">
        <details>
          <summary>
            <div class="summary__title">
              Shipping
            </div>
            {% render 'icon-caret' %}
          </summary>
          <div class="accordion__content rte">
            {{ block.settings.shipping_policy }}
          </div>
        </details>
      </div>
    {% endif %}

    {% if block.settings.show_return_policy %}
      <div class="product__accordion-{{ ai_gen_id }} accordion-{{ ai_gen_id }}">
        <details>
          <summary>
            <div class="summary__title">
              Returns
            </div>
            {% render 'icon-caret' %}
          </summary>
          <div class="accordion__content rte">
            {{ block.settings.return_policy }}
          </div>
        </details>
      </div>
    {% endif %}
  </div>
</product-form-{{ ai_gen_id }}>

<script>
  (function() {
    class VariantRadios{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.addEventListener('change', this.onVariantChange);
      }

      onVariantChange() {
        this.updateOptions();
        this.updateMasterId();
        this.toggleAddButton(true, '', false);
        this.updatePickupAvailability();
        this.removeErrorMessage();

        if (!this.currentVariant) {
          this.toggleAddButton(true, '', true);
          this.setUnavailable();
        } else {
          this.updateMedia();
          this.updateURL();
          this.updateVariantInput();
          this.renderProductInfo();
          this.updateShareUrl();
        }
      }

      updateOptions() {
        this.options = Array.from(this.querySelectorAll('select'), (select) => select.value);
      }

      updateMasterId() {
        this.currentVariant = this.getVariantData().find((variant) => {
          return !variant.options.map((option, index) => {
            return this.options[index] === option;
          }).includes(false);
        });
      }

      updateMedia() {
        if (!this.currentVariant) return;
        if (!this.currentVariant.featured_media) return;

        const mediaGallery = document.getElementById(`MediaGallery-${this.dataset.section}`);
        mediaGallery.setActiveMedia(`${this.dataset.section}-${this.currentVariant.featured_media.id}`, true);

        const modalContent = document.querySelector(`#ProductModal-${this.dataset.section} .product-media-modal__content`);
        if (!modalContent) return;
        const newMediaModal = modalContent.querySelector( `[data-media-id="${this.currentVariant.featured_media.id}"]`);
        modalContent.prepend(newMediaModal);
      }

      updateURL() {
        if (!this.currentVariant || this.dataset.updateUrl === 'false') return;
        window.history.replaceState({ }, '', `${this.dataset.url}?variant=${this.currentVariant.id}`);
      }

      updateShareUrl() {
        const shareButton = document.getElementById(`Share-${this.dataset.section}`);
        if (!shareButton || !shareButton.updateUrl) return;
        shareButton.updateUrl(`${window.shopUrl}${this.dataset.url}?variant=${this.currentVariant.id}`);
      }

      updateVariantInput() {
        const productForms = document.querySelectorAll(`#product-form-${this.dataset.section}, #product-form-installment-${this.dataset.section}`);
        productForms.forEach((productForm) => {
          const input = productForm.querySelector('input[name="id"]');
          input.value = this.currentVariant.id;
          input.dispatchEvent(new Event('change', { bubbles: true }));
        });
      }

      updatePickupAvailability() {
        const pickUpAvailability = document.querySelector('pickup-availability');
        if (!pickUpAvailability) return;

        if (this.currentVariant && this.currentVariant.available) {
          pickUpAvailability.fetchAvailability(this.currentVariant.id);
        } else {
          pickUpAvailability.removeAttribute('available');
          pickUpAvailability.innerHTML = '';
        }
      }

      removeErrorMessage() {
        const section = this.closest('section');
        if (!section) return;

        const productForm = section.querySelector('product-form');
        if (productForm) productForm.handleErrorMessage();
      }

      renderProductInfo() {
        const requestedVariantId = this.currentVariant.id;
        const sectionId = this.dataset.originalSection ? this.dataset.originalSection : this.dataset.section;

        fetch(`${this.dataset.url}?variant=${requestedVariantId}&section_id=${this.dataset.section}`)
          .then((response) => response.text())
          .then((responseText) => {
            if (this.currentVariant.id !== requestedVariantId) return;

            const html = new DOMParser().parseFromString(responseText, 'text/html');
            const destination = document.getElementById(`price-${this.dataset.section}`);
            const source = html.getElementById(`price-${this.dataset.originalSection ? this.dataset.originalSection : this.dataset.section}`);
            const skuSource = html.getElementById(`Sku-${this.dataset.originalSection ? this.dataset.originalSection : this.dataset.section}`);
            const skuDestination = document.getElementById(`Sku-${this.dataset.section}`);
            const inventorySource = html.getElementById(`Inventory-${this.dataset.originalSection ? this.dataset.originalSection : this.dataset.section}`);
            const inventoryDestination = document.getElementById(`Inventory-${this.dataset.section}`);

            if (source && destination) destination.innerHTML = source.innerHTML;
            if (inventorySource && inventoryDestination) inventoryDestination.innerHTML = inventorySource.innerHTML;
            if (skuSource && skuDestination) {
              skuDestination.innerHTML = skuSource.innerHTML;
              skuDestination.classList.toggle('visibility-hidden', skuSource.classList.contains('visibility-hidden'));
            }

            const price = document.getElementById(`price-${this.dataset.section}`);

            if (price) price.classList.remove('visibility-hidden');
            this.toggleAddButton(!this.currentVariant.available, window.variantStrings.soldOut);
          });
      }

      toggleAddButton(disable = true, text, modifyClass = true) {
        const productForm = document.getElementById(`product-form-${this.dataset.section}`);
        if (!productForm) return;

        const addButton = productForm.querySelector('[name="add"]');
        const addButtonText = productForm.querySelector('[name="add"] > span');
        if (!addButton) return;

        if (disable) {
          addButton.setAttribute('disabled', 'disabled');
          if (text) addButtonText.textContent = text;
        } else {
          addButton.removeAttribute('disabled');
          addButtonText.textContent = window.variantStrings.addToCart;
        }

        if (!modifyClass) return;
      }

      setUnavailable() {
        const button = document.getElementById(`product-form-${this.dataset.section}`);
        const addButton = button.querySelector('[name="add"]');
        const addButtonText = button.querySelector('[name="add"] > span');
        const price = document.getElementById(`price-${this.dataset.section}`);
        if (!addButton) return;
        addButtonText.textContent = window.variantStrings.unavailable;
        if (price) price.classList.add('visibility-hidden');
      }

      getVariantData() {
        this.variantData = this.variantData || JSON.parse(this.querySelector('[type="application/json"]').textContent);
        return this.variantData;
      }
    }

    class ProductForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();

        this.form = this.querySelector('form');
        this.form.querySelector('[name=id]').disabled = false;
        this.form.addEventListener('submit', this.onSubmitHandler.bind(this));
        this.cart = document.querySelector('cart-notification') || document.querySelector('cart-drawer');
        this.submitButton = this.querySelector('[type="submit"]');
        if (document.querySelector('cart-drawer')) this.submitButton.setAttribute('aria-haspopup', 'dialog');

        this.hideErrors = this.dataset.hideErrors === 'true';
      }

      onSubmitHandler(evt) {
        evt.preventDefault();
        if (this.submitButton.getAttribute('aria-disabled') === 'true') return;

        this.handleErrorMessage();

        this.submitButton.setAttribute('aria-disabled', true);
        this.submitButton.classList.add('loading');
        this.querySelector('.loading-overlay__spinner').classList.remove('hidden');

        const config = fetchConfig('javascript');
        config.headers['X-Requested-With'] = 'XMLHttpRequest';
        delete config.headers['Content-Type'];

        const formData = new FormData(this.form);
        if (this.cart) {
          formData.append('sections', this.cart.getSectionsToRender().map((section) => section.id));
          formData.append('sections_url', window.location.pathname);
          config.body = formData;
        }

        fetch(`${routes.cart_add_url}`, config)
          .then((response) => response.json())
          .then((response) => {
            if (response.status) {
              this.handleErrorMessage(response.description);

              const soldOutMessage = this.submitButton.querySelector('.sold-out-message');
              if (!soldOutMessage) return;
              this.submitButton.setAttribute('aria-disabled', false);
              this.submitButton.classList.remove('loading');
              this.querySelector('.loading-overlay__spinner').classList.add('hidden');
              return;
            } else if (!this.cart) {
              window.location = window.routes.cart_url;
              return;
            }

            if (!this.error) this.handleErrorMessage();
            this.cart.renderContents(response);
          })
          .catch((e) => {
            console.error(e);
          })
          .finally(() => {
            this.submitButton.classList.remove('loading');
            if (this.cart && this.cart.classList.contains('is-empty')) this.cart.classList.remove('is-empty');
            if (!this.error) this.submitButton.removeAttribute('aria-disabled');
            this.querySelector('.loading-overlay__spinner').classList.add('hidden');
          });
      }

      handleErrorMessage(errorMessage = false) {
        if (this.hideErrors) return;

        this.errorMessageWrapper = this.errorMessageWrapper || this.querySelector('.product-form__error-message-wrapper');
        if (!this.errorMessageWrapper) return;
        this.errorMessage = this.errorMessage || this.errorMessageWrapper.querySelector('.product-form__error-message');

        this.errorMessageWrapper.toggleAttribute('hidden', !errorMessage);

        if (errorMessage) {
          this.errorMessage.textContent = errorMessage;
        }
      }
    }

    customElements.define('variant-radios-{{ ai_gen_id }}', VariantRadios{{ ai_gen_id }});
    customElements.define('product-form-{{ ai_gen_id }}', ProductForm{{ ai_gen_id }});

    // Media gallery functionality
    const mediaItems = document.querySelectorAll('.product__media-item-{{ ai_gen_id }}');
    const thumbButtons = document.querySelectorAll('.product__media-thumb-{{ ai_gen_id }}');

    thumbButtons.forEach(button => {
      button.addEventListener('click', () => {
        const targetId = button.dataset.target;
        
        // Hide all media items
        mediaItems.forEach(item => {
          item.style.display = 'none';
        });
        
        // Show target media item
        const targetItem = document.querySelector(`[data-media-id="${targetId}"]`);
        if (targetItem) {
          targetItem.style.display = 'block';
        }
        
        // Update active thumb
        thumbButtons.forEach(thumb => thumb.classList.remove('is-active'));
        button.classList.add('is-active');
      });
    });

    // Quantity controls
    const quantityInput = document.querySelector('#Quantity-{{ block.id }}');
    const minusButton = document.querySelector('.quantity__button-{{ ai_gen_id }}[name="minus"]');
    const plusButton = document.querySelector('.quantity__button-{{ ai_gen_id }}[name="plus"]');

    if (minusButton) {
      minusButton.addEventListener('click', () => {
        const currentValue = parseInt(quantityInput.value);
        if (currentValue > 1) {
          quantityInput.value = currentValue - 1;
        }
      });
    }

    if (plusButton) {
      plusButton.addEventListener('click', () => {
        const currentValue = parseInt(quantityInput.value);
        quantityInput.value = currentValue + 1;
      });
    }

    // Variant selection
    const variantButtons = document.querySelectorAll('.variant-picker__button-{{ ai_gen_id }}');
    
    variantButtons.forEach(button => {
      button.addEventListener('click', () => {
        const input = document.querySelector(`#${button.getAttribute('for')}`);
        if (input) {
          input.checked = true;
          
          // Update button states
          const fieldset = button.closest('fieldset');
          fieldset.querySelectorAll('.variant-picker__button-{{ ai_gen_id }}').forEach(btn => {
            btn.setAttribute('aria-pressed', 'false');
          });
          button.setAttribute('aria-pressed', 'true');
          
          // Trigger change event
          input.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });
    });

    // Set initial variant button states
    document.querySelectorAll('input[type="radio"]:checked').forEach(input => {
      const button = document.querySelector(`label[for="${input.id}"]`);
      if (button) {
        button.setAttribute('aria-pressed', 'true');
      }
    });
  })();
</script>

<script type="application/json">
  {{ product.variants | json }}
</script>

{% schema %}
{
  "name": "Product full",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "default": true,
      "label": "Show dynamic checkout buttons"
    },
    {
      "type": "header",
      "content": "Product information"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "default": true,
      "label": "Show description"
    },
    {
      "type": "checkbox",
      "id": "show_shipping_policy",
      "default": false,
      "label": "Show shipping policy"
    },
    {
      "type": "richtext",
      "id": "shipping_policy",
      "label": "Shipping policy",
      "default": "<p>Free shipping on orders over $50. Standard delivery takes 3-5 business days.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_return_policy",
      "default": false,
      "label": "Show return policy"
    },
    {
      "type": "richtext",
      "id": "return_policy",
      "label": "Return policy",
      "default": "<p>30-day return policy. Items must be in original condition with tags attached.</p>"
    }
  ],
  "presets": [
    {
      "name": "Product full"
    }
  ]
}
{% endschema %}