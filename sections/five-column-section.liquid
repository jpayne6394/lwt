{% comment %}
  Custom Columns Section — CLEAN VERSION
{% endcomment %}

<style>
.custom-columns-wrapper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); /* fallback for mobile */
    gap: 2rem;
    align-items: start;
    margin: 0 auto;
    max-width: 100%; /* allow full width */
    padding: 20px 20px;
}

@media (min-width: 1024px) {
    .custom-columns-wrapper {
        grid-template-columns: repeat(5, 1fr); /* force 5 columns on desktop */
        max-width: 1400px; /* ensure enough width for 5 columns */
    }
}

.custom-columns-section img {
    filter: none !important; /* un-grey images */
}

.custom-tile {
    background: #fff;
    border: none;
    border-radius: 10px;
    box-shadow: none;
    padding: 1rem .05rem; /* reduced padding to give more space to image */
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: none;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    height: 100%;
}

  .custom-columns-section .section-heading {
    text-align: center;
    margin-top: 8rem;    /* add space ABOVE heading */
    margin-bottom: 1rem; /* add space BELOW heading */
}

  /* Heading size controls */
.heading-size-small {
    font-size: 2rem;
}

.heading-size-medium {
    font-size: 2rem;
}

.heading-size-large {
    font-size: 4rem;
}

.custom-tile:hover {
    border-color: none;
    box-shadow: none;
    transform: none;
}

.tile-image {
    width: 220px;
    height: 230px;
    margin: 0 auto 0.5rem auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
    flex-shrink: 0;
}

.tile-image img {
    min-width: 160px; /* forces small images to scale up */
    min-height: 160px;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
}

.tile-image {
    margin-bottom: -48.75px; /* add this line */
}


.custom-tile h3 {
    font-size: 1.95rem;
    margin: 0.1rem 0 0.8rem 0; /* tight spacing */
    font-weight: 600;
}

.custom-tile p {
    font-size: 1.4rem;
    line-height: 1.65; /* compact */
    color: #333;
    max-width: 90%;
    margin: 0 auto;
}



</style>

<section class="custom-columns-section section">

  {% if section.settings.heading != blank %}
    <div class="section-heading" style="text-align: center; margin-bottom: 1rem;">
      <h2 class="heading-size-{{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="custom-columns-wrapper">
    {% for block in section.blocks %}
      {% assign image = block.settings.image %}
      {% assign title = block.settings.title %}
      {% assign text = block.settings.text %}
      {% assign link = block.settings.link %}

      {% if link != blank %}
        <a href="{{ link }}" class="custom-tile" {{ block.shopify_attributes }}>
      {% else %}
        <div class="custom-tile" {{ block.shopify_attributes }}>
      {% endif %}

        {% if image != blank %}
          <div class="tile-image">
            <img src="{{ image | image_url: width: 300 }}" alt="{{ title | escape }}">
          </div>
        {% endif %}

        {% if title != blank %}
          <h3>{{ title }}</h3>
        {% endif %}

        {% if text != blank %}
          <p>{{ text }}</p>
        {% endif %}

      {% if link != blank %}
        </a>
      {% else %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "custom Columns",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "What Makes Us Different"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Number of columns on desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 5
    },
    {
      "type": "radio",
      "id": "columns_mobile",
      "label": "Number of columns on mobile",
      "default": "1",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Column title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Column description goes here."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "custom Columns",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
