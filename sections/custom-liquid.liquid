{% schema %}
{
  "name": "Products & News Row",
  "settings": [
    { "type": "text",    "id": "heading_products",      "label": "Products heading",       "default": "Product Highlights" },
    { "type": "collection","id": "collection",        "label": "Collection to show" },
    { "type": "number",  "id": "product_limit",       "label": "Number of products",     "default": 3 },
    { "type": "text",    "id": "button_text",         "label": "Products button text",  "default": "Learn More" },
    { "type": "url",     "id": "button_link",         "label": "Products button link" },
    { "type": "text",    "id": "heading_blog",        "label": "News heading",          "default": "Latest News & Events" },
    { "type": "blog",    "id": "blog",                "label": "Blog to show" },
    { "type": "number",  "id": "article_limit",       "label": "Number of articles",    "default": 3 },
    { "type": "color",   "id": "product_title_color", "label": "Product title color",  "default": "#000000" },
    { "type": "color",   "id": "news_title_color",    "label": "News title color",     "default": "#000000" },
    { "type": "color",   "id": "divider_color",       "label": "Divider color",        "default": "#cccccc" }
  ],
  "presets": [ { "name": "Products & News Row" } ]
}
{% endschema %}

<div id="section-{{ section.id }}" class="page-width">
  <style>
    #section-{{ section.id }} .title-products { color: {{ section.settings.product_title_color }}; }
    #section-{{ section.id }} .title-news     { color: {{ section.settings.news_title_color }}; }
    #section-{{ section.id }} .news-column    { border-left-color: {{ section.settings.divider_color }} !important; }
  </style>

  <div class="grid grid--2-col-desktop grid--2-col-tablet grid--1-col-mobile gap__large">

    <!-- Products Column -->
    <div class="grid__item">
      <h2 class="title title-products">{{ section.settings.heading_products }}</h2>
      <div class="grid grid--3-col-desktop grid--3-col-tablet grid--1-col-mobile gap__small">
        {% assign img_size = '200x200' %}
        {% for product in collections[section.settings.collection].products limit: section.settings.product_limit %}
          <div class="grid__item" style="text-align:center;">
            <a href="{{ product.url }}" class="card">
              {% if product.featured_image != blank %}
                <div class="card__media" style="max-width:150px; margin:0 auto 1rem;">
                  <img
                    src="{{ product.featured_image | img_url: img_size }}"
                    alt="{{ product.title }}"
                    width="200" height="200"
                    style="width:100%; height:auto;"
                    loading="lazy"
                  />
                </div>
              {% endif %}
              <div class="card__content">
                <h3>{{ product.title }}</h3>
                {% if product.price %}
                  <p class="price">{{ product.price | money }}</p>
                {% endif %}
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.button_link != blank %}
        <div class="text-center" style="margin-top: 1.5rem;">
          <a href="{{ section.settings.button_link }}" class="button button--primary">{{ section.settings.button_text }}</a>
        </div>
      {% endif %}
      <!-- View All Products Link -->
      {% if section.settings.collection != blank %}
        <div class="text-center" style="margin-top: 1rem;">
          <a href="{{ collections[section.settings.collection].url }}" class="link underlined-link">View all products</a>
        </div>
      {% endif %}
    </div>

    <!-- News Column -->
    <div class="grid__item news-column" style="border-left:1px solid; padding-left:2rem;">
      <h2 class="title title-news">{{ section.settings.heading_blog }}</h2>
      <ul style="list-style:none; padding:0; margin:0;">
        {% assign thumb_size = '100x100' %}
        {% for article in blogs[section.settings.blog].articles limit: section.settings.article_limit %}
          <li style="display:flex; align-items:flex-start; margin-bottom:1rem;">
            {% if article.image != blank %}
              <div style="flex:0 0 auto; width:60px; height:60px; margin-right:1rem; overflow:hidden;">
                <img
                  src="{{ article.image | img_url: thumb_size }}"
                  alt="{{ article.title }}"
                  width="100" height="100"
                  style="width:100%; height:100%; object-fit:cover;"
                  loading="lazy"
                />
              </div>
            {% endif %}
            <div style="flex:1 1 auto;">
              <a href="{{ article.url }}" class="link" style="font-weight:600;">{{ article.title }}</a>
              <p class="caption small light" style="margin:0.25rem 0 0;">{{ article.published_at | date: "%B %d, %Y" }}</p>
            </div>
          </li>
        {% endfor %}
      </ul>
      <div class="text-center" style="margin-top:1rem;">
        <a href="/blogs/{{ section.settings.blog.handle }}" class="link">View all news</a>
      </div>
    </div>

  </div>
</div>
