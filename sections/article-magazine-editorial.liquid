{% comment %}
  Article — Magazine Editorial (Reusable)
  - Reuses brand styling via section settings
  - Pulls per-post content via article + metafields (namespace: newsletter)
  - Dawn 15 compatible
{% endcomment %}

<section class="ai-magazine-layout" id="magazine-{{ section.id }}">
  <style>
    .ai-magazine-layout { max-width: 1200px; margin: 0 auto; padding: 40px 20px;
      background: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};
      font-family: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};
      font-weight: {{ section.settings.body_font.weight }}; line-height: 1.6; }

    .ai-magazine-logo-bar { margin-bottom: 36px; padding: 28px 20px; border-radius: {{ section.settings.logo_section_border_radius }}px;
      background: {{ section.settings.logo_section_bg_color }}; border-bottom: 3px solid {{ section.settings.accent_color }};
      display:flex; justify-content: {{ section.settings.logo_position }}; }
    .ai-magazine-logo { width: {{ section.settings.logo_width }}px; }
    .ai-magazine-logo img { width: 100%; height:auto; max-height: {{ section.settings.logo_max_height }}px; object-fit: contain; }

    .ai-magazine-header { text-align: center; margin-bottom: 60px; border-bottom: 3px solid {{ section.settings.accent_color }}; padding-bottom: 26px; }
    .ai-magazine-title { font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
      font-weight: {{ section.settings.heading_font.weight }}; font-size: {{ section.settings.title_size }}px; letter-spacing:-.02em;
      color: {{ section.settings.heading_color }}; line-height:1.2; margin: 0 0 12px; }
    .ai-magazine-subtitle { font-size: {{ section.settings.subtitle_size }}px; color: {{ section.settings.subtitle_color }}; font-style: italic; margin:0 0 18px; }
    .ai-magazine-byline { font-size: 14px; color: {{ section.settings.byline_color }}; text-transform: uppercase; letter-spacing:1px; margin:0; }
    .ai-magazine-date { font-size: 12px; color: {{ section.settings.byline_color }}; margin-top:6px; }

    .ai-magazine-featured { margin: 36px 0; }
    .ai-magazine-featured img { width:100%; height:400px; object-fit:cover; border-radius: {{ section.settings.image_border_radius }}px; }
    .ai-magazine-caption { font-size:12px; color: {{ section.settings.caption_color }}; font-style: italic; margin-top:10px; text-align:center; }

    .ai-magazine-grid { display:grid; grid-template-columns: 2fr 1fr; gap: 60px; margin: 60px 0; }
    .ai-magazine-main { min-width:0; }
    .ai-magazine-cols { column-count: {{ section.settings.column_count }}; column-gap:40px; column-rule: 1px solid {{ section.settings.column_divider_color }};
      text-align: justify; font-size: {{ section.settings.body_text_size }}px; line-height:1.7; }
    .ai-magazine-cols p { margin:0 0 20px; break-inside: avoid; }
    .ai-magazine-cols h3 { font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
      font-weight: {{ section.settings.heading_font.weight }}; font-size: {{ section.settings.subheading_size }}px;
      color: {{ section.settings.heading_color }}; margin: 30px 0 15px; line-height:1.3; break-after: avoid; }

    .ai-quote { background: {{ section.settings.quote_bg_color }}; border-left:5px solid {{ section.settings.accent_color }};
      padding: 28px; margin: 36px 0; font-size: {{ section.settings.quote_size }}px; font-style: italic; color: {{ section.settings.quote_color }};
      column-span: all; text-align:center; position:relative; }
    .ai-quote::before { content:'"'; font-size:80px; color: {{ section.settings.accent_color }}; position:absolute; top:-10px; left:30px; opacity:.3; line-height:1; }

    .ai-callout { background: linear-gradient(135deg, {{ section.settings.callout_bg_color }}, {{ section.settings.callout_bg_color }}dd);
      border:2px solid {{ section.settings.accent_color }}; padding: 26px; margin: 40px 0; border-radius: {{ section.settings.callout_border_radius }}px;
      column-span: all; position:relative; overflow:hidden; text-align:center; }
    .ai-callout h3 { margin:0 0 12px; font-size:24px; color: {{ section.settings.heading_color }}; }
    .ai-callout::before { content:''; position:absolute; inset:-50% -50% auto auto; width:200%; height:200%;
      background: repeating-linear-gradient(45deg, transparent, transparent 10px, {{ section.settings.accent_color }}10 10px, {{ section.settings.accent_color }}10 20px);
      opacity:.1; }

    .ai-product { background: {{ section.settings.product_bg_color }}; border:1px solid {{ section.settings.product_border_color }};
      border-radius: {{ section.settings.product_border_radius }}px; padding: 22px; margin: 30px 0; display:flex; gap:20px; align-items:center;
      column-span: all; transition: transform .3s ease, box-shadow .3s ease; }
    .ai-product:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,.1); }
    .ai-product-img { width:120px; height:120px; flex-shrink:0; }
    .ai-product-img img { width:100%; height:100%; object-fit:cover; border-radius:8px; }
    .ai-product-title { margin:0 0 6px; font-size:18px; color: {{ section.settings.heading_color }}; }
    .ai-product-price { margin:0 0 10px; font-size:16px; font-weight:600; color: {{ section.settings.price_color }}; }
    .ai-product-desc { margin:0 0 14px; font-size:14px; }
    .ai-product-link { display:inline-block; background: {{ section.settings.button_color }}; color: {{ section.settings.button_text_color }};
      padding:10px 20px; border-radius:25px; font-size:14px; font-weight:600; text-decoration:none; transition: background .3s; }
    .ai-product-link:hover { background: {{ section.settings.button_hover_color }}; }

    .ai-sidebar { background: {{ section.settings.sidebar_bg_color }}; padding: 34px 28px; border-radius: {{ section.settings.sidebar_border_radius }}px;
      height: fit-content; position: sticky; top: 20px; min-width:0; }
    .ai-sidebar h3 { margin:0 0 18px; text-transform:uppercase; letter-spacing: 1px; border-bottom:2px solid {{ section.settings.accent_color }};
      padding-bottom:10px; color: {{ section.settings.heading_color }}; font-size:20px; }
    .ai-sideprod { background: {{ section.settings.product_bg_color }}; border:1px solid {{ section.settings.product_border_color }};
      border-radius: {{ section.settings.product_border_radius }}px; padding:18px; margin: 22px 0; }
    .ai-sideprod img { width:100%; height:150px; object-fit:cover; border-radius:6px; margin-bottom:12px; }
    .ai-sideprod-title { margin:0 0 6px; font-size:16px; color: {{ section.settings.heading_color }}; }
    .ai-sideprod-price { margin:0 8px 10px 0; font-size:14px; font-weight:600; color: {{ section.settings.price_color }}; display:inline-block; }
    .ai-sideprod-desc { font-size:12px; margin:0 0 10px; }
    .ai-sideprod-link { display:inline-block; width:100%; text-align:center; background: {{ section.settings.button_color }};
      color: {{ section.settings.button_text_color }}; padding:8px 16px; border-radius:20px; font-size:12px; font-weight:600; text-decoration:none; }
    .ai-sideprod-link:hover { background: {{ section.settings.button_hover_color }}; }

    .ai-footer { margin-top: 72px; padding-top: 32px; border-top:2px solid {{ section.settings.accent_color }}; text-align:center; }
    .ai-copy { margin:0; font-size:12px; text-transform:uppercase; letter-spacing:1px; color: {{ section.settings.copyright_color }}; }
    .ai-pubinfo { margin:10px 0 0; font-size:11px; color: {{ section.settings.copyright_color }}; opacity:.8; }

    @media (max-width: 768px) {
      .ai-magazine-layout { padding: 22px 15px; }
      .ai-magazine-logo-bar { justify-content:center; padding: 20px 15px; }
      .ai-magazine-title { font-size: calc({{ section.settings.title_size }}px * 0.8); }
      .ai-magazine-grid { grid-template-columns: 1fr; gap: 40px; }
      .ai-magazine-cols { column-count: 1; column-rule: none; }
      .ai-product { flex-direction: column; text-align:center; }
      .ai-product-img { width:100px; height:100px; }
      .ai-sidebar { position: static; margin-top:40px; }
    }
  </style>

  {%- comment -%} Logo bar (accent purple), logo above title {%- endcomment -%}
  <div class="ai-magazine-logo-bar">
    <div class="ai-magazine-logo">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: section.settings.logo_width | image_tag: alt: shop.name, loading: 'lazy' }}
      {% else %}
        {{ 'image' | placeholder_svg_tag }}
      {% endif %}
    </div>
  </div>

  <header class="ai-magazine-header">
    <h1 class="ai-magazine-title">{{ article.title | escape }}</h1>
    {% if article.metafields.newsletter.subheading != blank %}
      <div class="ai-magazine-subtitle">{{ article.metafields.newsletter.subheading }}</div>
    {% endif %}
    <p class="ai-magazine-byline">
      {% if article.author %}By {{ article.author }}{% endif %}
    </p>
    <p class="ai-magazine-date">{{ article.published_at | time_tag: format: 'date' }}</p>
  </header>

  {%- assign custom_featured = article.metafields.newsletter.featured_image -%}
  <div class="ai-magazine-featured">
    {% if custom_featured != blank %}
      {{ custom_featured | image_url: width: 1600 | image_tag: loading: 'lazy', alt: article.title }}
    {% elsif article.image %}
      {{ article.image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: article.title }}
    {% endif %}
    {% if article.metafields.newsletter.image_caption != blank %}
      <p class="ai-magazine-caption">{{ article.metafields.newsletter.image_caption }}</p>
    {% endif %}
  </div>

  <div class="ai-magazine-grid">
    <main class="ai-magazine-main">
      {%- comment -%} Intro (remove right whitespace by letting columns span full width container) {%- endcomment -%}
      {% if article.metafields.newsletter.intro != blank %}
        <div class="ai-magazine-cols">
          {{ article.metafields.newsletter.intro }}
        </div>
      {% endif %}

      {% if article.metafields.newsletter.pull_quote != blank %}
        <blockquote class="ai-quote">{{ article.metafields.newsletter.pull_quote }}</blockquote>
      {% endif %}

      {%- comment -%} Main article body in columns {%- endcomment -%}
      <div class="ai-magazine-cols">
        {{ article.content }}
      </div>

      {%- comment -%} Inline product placement (main) {%- endcomment -%}
      {% assign fp = article.metafields.newsletter.featured_product %}
      {% if fp and fp.available %}
        <div class="ai-product">
          <div class="ai-product-img">
            {% if fp.featured_image %}
              {{ fp.featured_image | image_url: width: 240 | image_tag: loading: 'lazy', alt: fp.title }}
            {% endif %}
          </div>
          <div>
            <h3 class="ai-product-title">{{ fp.title }}</h3>
            <p class="ai-product-price">
              {% render 'price', product: fp %}
            </p>
            {% if article.metafields.newsletter.featured_product_blurb != blank %}
              <p class="ai-product-desc">{{ article.metafields.newsletter.featured_product_blurb }}</p>
            {% endif %}
            <a class="ai-product-link" href="{{ fp.url }}">Shop Now</a>
          </div>
        </div>
      {% endif %}

      {%- comment -%} Editorial callout {%- endcomment -%}
      {% if article.metafields.newsletter.callout_title != blank or article.metafields.newsletter.callout_text != blank %}
        <div class="ai-callout">
          {% if article.metafields.newsletter.callout_title != blank %}
            <h3>{{ article.metafields.newsletter.callout_title }}</h3>
          {% endif %}
          {% if article.metafields.newsletter.callout_text != blank %}
            <div>{{ article.metafields.newsletter.callout_text }}</div>
          {% endif %}
        </div>
      {% endif %}
    </main>

    <aside class="ai-sidebar">
      <h3>{{ article.metafields.newsletter.sidebar_title | default: 'In this issue' }}</h3>
      {% if article.metafields.newsletter.sidebar_content != blank %}
        <div>{{ article.metafields.newsletter.sidebar_content }}</div>
      {% endif %}

      {% assign sp = article.metafields.newsletter.sidebar_product %}
      {% if sp %}
        <div class="ai-sideprod">
          {% if sp.featured_image %}
            {{ sp.featured_image | image_url: width: 480 | image_tag: loading: 'lazy', alt: sp.title }}
          {% endif %}
          <div class="ai-sideprod-title">{{ sp.title }}</div>
          <div class="ai-sideprod-price">
            {% render 'price', product: sp %}
          </div>
          {% if article.metafields.newsletter.sidebar_product_blurb != blank %}
            <div class="ai-sideprod-desc">{{ article.metafields.newsletter.sidebar_product_blurb }}</div>
          {% endif %}
          <a class="ai-sideprod-link" href="{{ sp.url }}">View details</a>
        </div>
      {% endif %}
    </aside>
  </div>

  <footer class="ai-footer">
    <p class="ai-copy">
      {{ section.settings.copyright_text | default: "© " | append: now | date: "%Y" | append: " All Rights Reserved" }}
    </p>
    {% if section.settings.publication_info != blank %}
      <p class="ai-pubinfo">{{ section.settings.publication_info }}</p>
    {% endif %}
  </footer>

  {% schema %}
  {
    "name": "article-magazine",
    "settings": [
      { "type":"image_picker","id":"logo","label":"Logo" },
      { "type":"select","id":"logo_position","label":"Logo position","default":"center","options":[
        {"value":"flex-start","label":"Left"},{"value":"center","label":"Center"},{"value":"flex-end","label":"Right"}]},
      { "type":"range","id":"logo_width","label":"Logo width","min":100,"max":500,"step":10,"unit":"px","default":260 },
      { "type":"range","id":"logo_max_height","label":"Logo max height","min":60,"max":240,"step":10,"unit":"px","default":120 },
      { "type":"color","id":"logo_section_bg_color","label":"Logo bar background","default":"#4b3f82" },
      { "type":"range","id":"logo_section_border_radius","label":"Logo bar radius","min":0,"max":30,"step":2,"unit":"px","default":12 },

      { "type":"font_picker","id":"heading_font","label":"Heading font","default":"helvetica_n7" },
      { "type":"font_picker","id":"body_font","label":"Body font","default":"helvetica_n4" },
      { "type":"range","id":"title_size","label":"Title size","min":24,"max":72,"step":2,"unit":"px","default":48 },
      { "type":"range","id":"subtitle_size","label":"Subtitle size","min":14,"max":32,"step":1,"unit":"px","default":20 },
      { "type":"range","id":"subheading_size","label":"Subheading size","min":16,"max":36,"step":1,"unit":"px","default":24 },
      { "type":"range","id":"body_text_size","label":"Body text size","min":12,"max":20,"step":1,"unit":"px","default":16 },

      { "type":"color","id":"background_color","label":"Background","default":"#ffffff" },
      { "type":"color","id":"text_color","label":"Body text","default":"#333333" },
      { "type":"color","id":"heading_color","label":"Headings","default":"#1a1a1a" },
      { "type":"color","id":"subtitle_color","label":"Subtitle","default":"#666666" },
      { "type":"color","id":"byline_color","label":"Byline/Date","default":"#888888" },
      { "type":"color","id":"caption_color","label":"Caption","default":"#777777" },
      { "type":"color","id":"copyright_color","label":"Footer text","default":"#999999" },
      { "type":"color","id":"accent_color","label":"Accent color","default":"#4b3f82" },
      { "type":"color","id":"column_divider_color","label":"Column divider","default":"#e0e0e0" },
      { "type":"color","id":"quote_color","label":"Quote text","default":"#2c3e50" },
      { "type":"color","id":"quote_bg_color","label":"Quote background","default":"#f8f9fa" },
      { "type":"color","id":"sidebar_bg_color","label":"Sidebar background","default":"#f5f5f5" },
      { "type":"color","id":"callout_bg_color","label":"Callout background","default":"#fff3cd" },
      { "type":"color","id":"product_bg_color","label":"Product card bg","default":"#ffffff" },
      { "type":"color","id":"product_border_color","label":"Product card border","default":"#e0e0e0" },
      { "type":"color","id":"price_color","label":"Price color","default":"#e74c3c" },
      { "type":"color","id":"button_color","label":"Button color","default":"#4b3f82" },
      { "type":"color","id":"button_text_color","label":"Button text","default":"#ffffff" },
      { "type":"color","id":"button_hover_color","label":"Button hover","default":"#3e336b" },

      { "type":"range","id":"column_count","label":"Body columns","min":1,"max":3,"step":1,"default":2 },
      { "type":"range","id":"image_border_radius","label":"Image radius","min":0,"max":20,"step":2,"unit":"px","default":8 },
      { "type":"range","id":"sidebar_border_radius","label":"Sidebar radius","min":0,"max":20,"step":2,"unit":"px","default":12 },
      { "type":"range","id":"callout_border_radius","label":"Callout radius","min":0,"max":20,"step":2,"unit":"px","default":8 },

      { "type":"text","id":"publication_info","label":"Footer: publication info","default":"Published monthly by Living Well Today" },
      { "type":"text","id":"copyright_text","label":"Footer: custom copyright (optional)","default":"© 2024 Living Well Today. All Rights Reserved." }
    ],
    "presets": [{ "name": "Article — Magazine Editorial" }]
  }
  {% endschema %}
</section>
