{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-ticker-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
    position: relative;
    z-index: 1;
  }

  .ai-collection-ticker-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.title_alignment }};
    margin-bottom: {{ block.settings.title_spacing }}px;
    padding: 0 20px;
  }

  .ai-collection-ticker-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_text_color }};
    margin: 0;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-collection-ticker-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_font_size }}px;
    color: {{ block.settings.subtitle_text_color }};
    margin: 8px 0 0 0;
    opacity: 0.8;
    line-height: 1.4;
  }

  .ai-collection-ticker-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-collection-ticker-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .ai-collection-ticker-track-{{ ai_gen_id }} {
    display: flex;
    width: max-content;
    will-change: transform;
    transition: transform 0.3s ease;
  }

  .ai-collection-ticker-{{ ai_gen_id }}:hover .ai-collection-ticker-track-{{ ai_gen_id }} {
    {% if block.settings.pause_on_hover %} animation-play-state: paused; {% endif %}
  }

  .ai-collection-ticker-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    margin-right: {{ block.settings.item_spacing }}px;
    transition: transform 0.3s ease;
    width: {{ block.settings.item_width }}px;
  }

  .ai-collection-ticker-item-{{ ai_gen_id }}:hover { transform: translateY(-{{ block.settings.hover_lift }}px); }

  .ai-collection-ticker-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
    transition: box-shadow .3s ease;
    position: relative;
    cursor: pointer;
  }

  .ai-collection-ticker-card-{{ ai_gen_id }}:hover { box-shadow: 0 4px 16px rgba(0,0,0,.15); }
  .ai-collection-ticker-card-{{ ai_gen_id }}:hover .ai-collection-ticker-view-link-{{ ai_gen_id }} { text-decoration: underline; color: {{ block.settings.link_hover_color }}; }

  .ai-collection-ticker-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.image_height }}px;
    overflow: hidden;
    background-color: #ffffff;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.image_padding }}px;
  }

  .ai-collection-ticker-image-{{ ai_gen_id }} {
    width: calc(100% - {{ block.settings.image_padding | times: 2 }}px);
    height: calc(100% - {{ block.settings.image_padding | times: 2 }}px);
    object-fit: {{ block.settings.image_fit }};
    object-position: center;
    transition: transform .3s ease;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-collection-ticker-card-{{ ai_gen_id }}:hover .ai-collection-ticker-image-{{ ai_gen_id }} { transform: scale(1.05); }

  .ai-collection-ticker-placeholder-{{ ai_gen_id }} {
    width: calc(100% - {{ block.settings.image_padding | times: 2 }}px);
    height: calc(100% - {{ block.settings.image_padding | times: 2 }}px);
    background-color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }
  .ai-collection-ticker-placeholder-{{ ai_gen_id }} svg { width: 60%; height: 60%; opacity: .3; }

  .ai-collection-ticker-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex-grow: 1;
    min-height: 100px;
  }

  .ai-collection-ticker-product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ai-collection-ticker-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 500;
    color: {{ block.settings.product_title_color }};
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.6em;
    order: 1;
  }

  .ai-collection-ticker-vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_size }}px;
    color: #999999;
    margin: 0;
    order: 2;
    text-transform: uppercase;
    letter-spacing: .5px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-collection-ticker-price-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    background-color: {{ block.settings.badge_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
    z-index: 2;
    {% if block.settings.show_price_inline %} display: none; {% endif %}
  }

  .ai-collection-ticker-price-inline-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_inline_size }}px;
    color: {{ block.settings.price_inline_color }};
    font-weight: 600;
    margin: 8px 0 4px 0;
    order: 3;
  }

  .ai-collection-ticker-view-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    font-size: {{ block.settings.link_size }}px;
    font-weight: 500;
    text-decoration: none;
    margin-top: auto;
    transition: text-decoration .3s ease, color .3s ease;
    display: inline-block;
    order: 4;
  }

  .ai-collection-ticker-controls-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    {% if block.settings.show_controls %} opacity: 1; visibility: visible; {% else %} opacity: 0; visibility: hidden; {% endif %}
    transition: opacity .3s ease, visibility .3s ease;
  }
  .ai-collection-ticker-wrapper-{{ ai_gen_id }}:hover .ai-collection-ticker-controls-{{ ai_gen_id }} { {% if block.settings.show_controls_on_hover %} opacity: 1; visibility: visible; {% endif %} }
  .ai-collection-ticker-control-left-{{ ai_gen_id }}  { left: {{ block.settings.control_offset }}px; }
  .ai-collection-ticker-control-right-{{ ai_gen_id }} { right: {{ block.settings.control_offset }}px; }

  .ai-collection-ticker-control-btn-{{ ai_gen_id }} {
    width: {{ block.settings.control_size }}px;
    height: {{ block.settings.control_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.control_background }};
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,.15);
    transition: all .3s ease;
    color: {{ block.settings.control_color }};
  }
  .ai-collection-ticker-control-btn-{{ ai_gen_id }}:hover   { background-color: {{ block.settings.control_hover_background }}; color: {{ block.settings.control_hover_color }}; transform: scale(1.1); }
  .ai-collection-ticker-control-btn-{{ ai_gen_id }}:disabled{ opacity:.5; cursor:not-allowed; transform:none; }
  .ai-collection-ticker-control-btn-{{ ai_gen_id }} svg { width: 60%; height: 60%; }

  .ai-collection-ticker-view-all-{{ ai_gen_id }} {
    text-align: {{ block.settings.view_all_alignment }};
    margin-top: {{ block.settings.view_all_spacing }}px;
    padding: 0 20px {{ block.settings.view_all_bottom_spacing }}px 20px;
    position: relative;
    z-index: 2;
  }

  .ai-collection-ticker-view-all-btn-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    min-height: 36px;
    background-color: rgba(var(--color-button), 1);
    color: rgba(var(--color-button-text), 1);
    border: {{ settings.buttons_border_thickness }}px solid rgba(var(--color-button), {{ settings.buttons_border_opacity | divided_by: 100.0 }});
    border-radius: {{ settings.buttons_radius }}px;
    font-family: inherit;
    font-size: 1.1rem;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: .06rem;
    line-height: 1.2;
    cursor: pointer;
    transition: color .15s ease, background-color .15s ease, border-color .15s ease, box-shadow .15s ease;
    box-shadow: {{ settings.buttons_shadow_horizontal_offset }}px {{ settings.buttons_shadow_vertical_offset }}px {{ settings.buttons_shadow_blur }}px rgba(var(--color-shadow), {{ settings.buttons_shadow_opacity | divided_by: 100.0 }});
    position: relative;
    overflow: hidden;
  }
  .ai-collection-ticker-view-all-btn-{{ ai_gen_id }}:hover { background-color: rgba(var(--color-button), .85); border-color: rgba(var(--color-button), {{ settings.buttons_border_opacity | divided_by: 100.0 }}); }
  .ai-collection-ticker-view-all-btn-{{ ai_gen_id }}:focus, .ai-collection-ticker-view-all-btn-{{ ai_gen_id }}:focus-visible {
    outline: .2rem solid rgba(var(--color-foreground), .5);
    outline-offset: .3rem;
    box-shadow: 0 0 0 .3rem rgb(var(--color-background)), 0 0 .5rem .4rem rgba(var(--color-foreground), .3);
  }

  @media screen and (max-width: 749px) {
    .ai-collection-ticker-wrapper-{{ ai_gen_id }} { padding: {{ block.settings.padding_vertical | times: 0.7 }}px 0; }
    .ai-collection-ticker-header-{{ ai_gen_id }} { padding: 0 15px; margin-bottom: {{ block.settings.title_spacing | times: 0.8 }}px; }
    .ai-collection-ticker-title-{{ ai_gen_id }} { font-size: {{ block.settings.title_font_size | times: 0.9 }}px; }
    .ai-collection-ticker-subtitle-{{ ai_gen_id }} { font-size: {{ block.settings.subtitle_font_size | times: 0.9 }}px; }

    .ai-collection-ticker-item-{{ ai_gen_id }} { width: {{ block.settings.item_width | times: 0.8 }}px; margin-right: {{ block.settings.item_spacing | times: 0.8 }}px; }
    .ai-collection-ticker-image-wrapper-{{ ai_gen_id }} { height: {{ block.settings.image_height | times: 0.8 }}px; padding: {{ block.settings.image_padding | times: 0.8 }}px; }
    .ai-collection-ticker-content-{{ ai_gen_id }} { padding: {{ block.settings.content_padding | times: 0.8 }}px; min-height: 80px; }

    .ai-collection-ticker-product-title-{{ ai_gen_id }} { font-size: {{ block.settings.product_title_size | times: 0.9 }}px; }
    .ai-collection-ticker-vendor-{{ ai_gen_id }}       { font-size: {{ block.settings.vendor_size | times: 0.9 }}px; }
    .ai-collection-ticker-price-inline-{{ ai_gen_id }} { font-size: {{ block.settings.price_inline_size | times: 0.9 }}px; }
    .ai-collection-ticker-view-link-{{ ai_gen_id }}    { font-size: {{ block.settings.link_size | times: 0.9 }}px; }

    .ai-collection-ticker-controls-{{ ai_gen_id }} { display: none; }
    .ai-collection-ticker-{{ ai_gen_id }} { touch-action: pan-x; -webkit-overflow-scrolling: touch; }
    .ai-collection-ticker-item-{{ ai_gen_id }}:hover { transform: none; }
    .ai-collection-ticker-card-{{ ai_gen_id }}:hover .ai-collection-ticker-image-{{ ai_gen_id }} { transform: none; }

    .ai-collection-ticker-view-all-{{ ai_gen_id }} { padding: 0 15px {{ block.settings.view_all_bottom_spacing | times: 0.8 }}px 15px; margin-top: {{ block.settings.view_all_spacing | times: 0.8 }}px; }
    .ai-collection-ticker-view-all-btn-{{ ai_gen_id }} { font-size: 1rem; padding: 6px 14px; min-height: 32px; }
  }

  @media screen and (max-width: 480px) {
    .ai-collection-ticker-header-{{ ai_gen_id }} { padding: 0 10px; }
    .ai-collection-ticker-title-{{ ai_gen_id }} { font-size: {{ block.settings.title_font_size | times: 0.8 }}px; }
    .ai-collection-ticker-subtitle-{{ ai_gen_id }} { font-size: {{ block.settings.subtitle_font_size | times: 0.8 }}px; }

    .ai-collection-ticker-item-{{ ai_gen_id }} { width: {{ block.settings.item_width | times: 0.7 }}px; margin-right: {{ block.settings.item_spacing | times: 0.7 }}px; }
    .ai-collection-ticker-image-wrapper-{{ ai_gen_id }} { height: {{ block.settings.image_height | times: 0.7 }}px; padding: {{ block.settings.image_padding | times: 0.7 }}px; }
    .ai-collection-ticker-content-{{ ai_gen_id }} { min-height: 70px; }

    .ai-collection-ticker-price-inline-{{ ai_gen_id }} { font-size: {{ block.settings.price_inline_size | times: 0.8 }}px; }
    .ai-collection-ticker-view-all-{{ ai_gen_id }} { padding: 0 10px {{ block.settings.view_all_bottom_spacing | times: 0.7 }}px 10px; }
    .ai-collection-ticker-view-all-btn-{{ ai_gen_id }} { font-size: .95rem; padding: 6px 12px; min-height: 30px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-collection-ticker-track-{{ ai_gen_id }} { animation: none; }
    .ai-collection-ticker-{{ ai_gen_id }} { overflow-x: auto; scrollbar-width: thin; }
    .ai-collection-ticker-{{ ai_gen_id }}::-webkit-scrollbar { height: 6px; }
    .ai-collection-ticker-{{ ai_gen_id }}::-webkit-scrollbar-track { background: #f1f1f1; }
    .ai-collection-ticker-{{ ai_gen_id }}::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 3px; }
  }
{% endstyle %}

