      "label": "Button text",
      "default": "Send Message"
    },
    {
      "type": "header",
      "content": "Messages"
    },
    {
      "type": "textarea",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for your message. We'll get back to you within 24 hours."
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "title_font",
