{% comment %}
  SECTION: Functional Wellness, Reimagined
  FILE NAME: functional-wellness-reimagined.liquid
{% endcomment %}

<section class="fwr-section">
  <style>
    .fwr-section {
      background: linear-gradient(135deg, #3b1e5a, #5c3e7c);
      color: white;
      padding: 6rem 2rem;
      display: grid;
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    @media (min-width: 900px) {
      .fwr-section {
        grid-template-columns: 1fr 1fr;
        align-items: center;
        padding: 8rem 4rem;
      }
    }

    .fwr-text {
      max-width: 600px;
    }

    .fwr-text h2 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: #f1e6ff;
    }

    .fwr-text p {
      font-size: 1.2rem;
      line-height: 1.7;
      color: #f1e6ff;
      margin-bottom: 2rem;
    }

    .fwr-btn-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .fwr-btn {
      padding: 0.9rem 1.8rem;
      border-radius: 30px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      transition: background 0.3s ease;
      border: 2px solid white;
    }

    .fwr-btn.primary {
      background: white;
      color: #3b1e5a;
    }

    .fwr-btn.primary:hover {
      background: #d9c2f0;
    }

    .fwr-btn.outline {
      background: transparent;
      color: white;
    }

    .fwr-btn.outline:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    .fwr-image img {
      width: 100%;
      max-width: 600px;
      border-radius: 16px;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
    }
  
  </style>

  <div class="fwr-text">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
    <div class="fwr-btn-row">
      <a href="{{ section.settings.book_link }}" class="fwr-btn primary">{{ section.settings.book_label }}</a>
      <a href="{{ section.settings.team_link }}" class="fwr-btn outline">{{ section.settings.team_label }}</a>
    </div>
  </div>

  <div class="fwr-image">
    {% if section.settings.image %}
      <img src="{{ section.settings.image | img_url: '800x' }}" alt="Functional Wellness">
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Functional Wellness",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Functional Wellness, Reimagined"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Virtual care. Personalized plans. Proven results. Functional medicine that's easy to access and built around your real life."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "GIF or Image"
    },
    {
      "type": "url",
      "id": "book_link",
      "label": "Book Button Link"
    },
    {
      "type": "text",
      "id": "book_label",
      "label": "Book Button Label",
      "default": "Book a Consult"
    },
    {
      "type": "url",
      "id": "team_link",
      "label": "Meet the Team Link"
    },
    {
      "type": "text",
      "id": "team_label",
      "label": "Meet Team Label",
      "default": "Meet the Team →"
    }
  ],
  "presets": [
    {
      "name": "Functional Wellness Reimagined",
      "category": "Wellness"
    }
  ]
}
{% endschema %}
