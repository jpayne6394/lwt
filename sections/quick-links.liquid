<style>
:root {
  --quick-icon-size: 78px;             /* Shrink for desktop */
  --quick-icon-size-mobile: 68px;      /* Shrink for mobile */
}
.shop-by-goal {
  background: none;
  box-shadow: none;
  border-radius: 0;
  border-top: 2px solid var(--lwt-border);
  border-bottom: 2px solid var(--lwt-border);
  padding: var(--lwt-space-sm) 0;
  max-width: 100vw;
  margin: 0 0 var(--lwt-space-md) 0;
  transition: padding var(--lwt-transition-base);
}
.goal-grid {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: var(--lwt-space-xl);
  max-width: 620px;
  margin: 0 auto var(--lwt-space-xs) auto;
  transition: gap var(--lwt-transition-base);
}
.goal-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-decoration: none;
  background: transparent;
  border: none;
  box-shadow: none;
  padding: 0;
  cursor: pointer;
  outline: none;
  min-width: 70px;
  transition: min-width 0.2s;
}
.goal-card:focus-visible {
  outline: 2.5px solid var(--lwt-primary);
  outline-offset: 2px;
}
.goal-icon {
  width: var(--quick-icon-size);
  height: var(--quick-icon-size);
  border-radius: 50%;
  background: var(--lwt-surface);
  border: 2px solid var(--lwt-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 0;
  transition: width var(--lwt-transition-base), height var(--lwt-transition-base);
}
.goal-icon img, .goal-icon svg {
  width: 85%;
  height: 85%;
  object-fit: contain;
  display: block;
  margin: 0 auto;
}
.goal-label {
  font-weight: 700;
  color: var(--lwt-primary-dark);
  font-size: 1rem;
  margin-top: 0.13rem;
  line-height: 1.16;
  text-align: center;
  transition: font-size var(--lwt-transition-base);
}
.goal-card:hover .goal-icon,
.goal-card:focus .goal-icon {
  border-color: var(--lwt-primary);
  box-shadow: var(--lwt-shadow-button);
  transform: scale(1.06);
}
.goal-card:hover .goal-label,
.goal-card:focus .goal-label {
  color: var(--lwt-primary);
}

/* Responsive shrink for ticker and extra spacing! */
@media (max-width: 900px) {
  .goal-grid { gap: 1.6rem; max-width: 92vw; }
  .shop-by-goal { padding: 0.7rem 0 0.6rem 0; }
  .goal-card { min-width: 52px; }
  .goal-icon {
    width: var(--quick-icon-size-mobile);
    height: var(--quick-icon-size-mobile);
  }
  .goal-label { font-size: 0.93rem; }
}
@media (max-width: 600px) {
  .goal-grid { gap: .3rem; max-width: 80vw;}  /* More space for ticker on mobile! */
  .shop-by-goal { padding: 0.5rem 0 0.5rem 0; }
  .goal-card { min-width: 40px;  min-width: 90px !important; padding: 0.4rem 0.2rem 0.5rem 0.2rem;}
  .goal-icon {
    width: 58px;
    height: 58px;
  }

  .goal-label { font-size: 1.11rem; }
}

</style>

<div class="shop-by-goal">
  <div class="goal-grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="goal-card" aria-label="{{ block.settings.label }}">
        <span class="goal-icon">
          {% if block.settings.theme_icon == 'consults' %}
            <img src="{{ 'lwt-icon-consults.png' | asset_url }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="72" height="72">
          {% elsif block.settings.theme_icon == 'wellness_shop' %}
            <img src="{{ 'lwt-icon-wellness-shop.png' | asset_url }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="72" height="72">
          {% elsif block.settings.theme_icon == 'training' %}
            <img src="{{ 'lwt-icon-training.png' | asset_url }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="72" height="72">
          {% elsif block.settings.icon != blank %}
            <img
              src="{{ block.settings.icon | image_url: width: 72 }}"
              alt="{{ block.settings.label | escape }}"
              loading="lazy"
              width="72"
              height="72"
            >
          {% endif %}
        </span>
        <span class="goal-label">{{ block.settings.label }}</span>
      </a>
    {% endfor %}
  </div>
</div>


{% schema %}
{
  "name": "Quick Links Grid",
  "settings": [],
  "blocks": [
    {
      "type": "quick_link",
      "name": "Quick Link",
      "settings": [
        {
          "type": "select",
          "id": "theme_icon",
          "label": "Visit icon",
          "default": "none",
          "options": [
            { "value": "none", "label": "Custom (upload below)" },
            { "value": "consults", "label": "Consults" },
            { "value": "wellness_shop", "label": "Wellness Shop" },
            { "value": "training", "label": "Training" }
          ],
          "info": "Theme icons match the LWT brand. Use Custom to upload your own."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image (when Custom above)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Link label",
          "default": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Quick Links Grid"
    }
  ]
}
{% endschema %}
