        0 5px 10px rgba({{ settings.card_shadow_color.red }}, {{ settings.card_shadow_color.green }}, {{ settings.card_shadow_color.blue }}, {{ settings.card_shadow_opacity | divided_by: 100.0 | times: 0.05 }}),
