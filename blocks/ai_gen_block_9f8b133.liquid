  }
  .ai-company-bio-stats-{{ ai_gen_id }}::before {
    content: '';
    position: absolute; left: 0; right: 0; top: 0; height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.3) 20%,
      {{ block.settings.accent_color }} 50%,
      rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.3) 80%,
      transparent 100%);
  }

  .ai-company-bio-stat-{{ ai_gen_id }} { text-align: center; position: relative; }

  .ai-company-bio-stat-number-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-size: {{ block.settings.stat_number_font_size }}px;
