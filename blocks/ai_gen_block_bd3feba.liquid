<script>
(function() {
  class NewsletterHighlights{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.isExpanded = false;
      this.isLoading = false;
    }

    connectedCallback() {
      this.grid = this.querySelector('#ai-newsletter-grid-{{ ai_gen_id }}');
      this.button = this.querySelector('#ai-newsletter-load-more-button-{{ ai_gen_id }}');
      
      this.button.addEventListener('click', () => {
        this.handleLoadMore();
      });

      {% if settings.animations_reveal_on_scroll %}
        this.setupScrollAnimations();
      {% endif %}
    }

    {% if settings.animations_reveal_on_scroll %}
    setupScrollAnimations() {
      const cards = this.querySelectorAll('.ai-newsletter-card-{{ ai_gen_id }}');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      cards.forEach((card) => observer.observe(card));
    }
    {% endif %}

    handleLoadMore() {
      if (this.isLoading) return;

      if (!this.isExpanded) {
        this.expandView();
      } else {
        this.collapseView();
      }
    }

    expandView() {
      this.isLoading = true;
      this.button.classList.add('loading');
      this.button.querySelector('span').textContent = 'Loading...';

      setTimeout(() => {
        this.grid.classList.remove('compact');
        this.grid.classList.add('expanded');
        
        this.createExpandedCards();
        this.button.querySelector('span').textContent = 'Show less';
        this.button.classList.remove('loading');
        this.isExpanded = true;
        this.isLoading = false;
      }, 800);
    }

    collapseView() {
      this.grid.classList.remove('expanded');
      this.grid.classList.add('compact');
      
      this.removeExpandedCards();
      this.button.querySelector('span').textContent = '{{ block.settings.button_text }}';
      this.isExpanded = false;
    }

    createExpandedCards() {
      const blogArticles = [];
      {% if block.settings.featured_blog != blank %}
        {% for article in block.settings.featured_blog.articles offset: 3 limit: 5 %}
          blogArticles.push({
            title: {{ article.title | json }},
            url: {{ article.url | json }},
            published_at: {{ article.published_at | date: '%B %d, %Y' | json }},
            summary: {% if article.summary != blank %}{{ article.summary | strip_html | truncate: 120 | json }}{% else %}null{% endif %},
            excerpt: {% if article.excerpt != blank %}{{ article.excerpt | strip_html | truncate: 120 | json }}{% else %}{{ article.content | strip_html | truncate: 120 | json }}{% endif %},
            featured_image: {% if article.image %}{{ article.image | image_url: width: 400 | json }}{% else %}null{% endif %},
            comingSoon: false
          });
        {% endfor %}
      {% endif %}
      
      const placeholderCards = [
        { 
          title: 'Summer Collection Launch', 
          date: 'Coming Soon', 
          summary: 'Exclusive preview of our upcoming summer line',
          excerpt: 'Discover our latest summer styles featuring breathable fabrics and vibrant colors perfect for the season ahead.', 
          comingSoon: true, 
          url: null 
        },
        { 
          title: 'Sustainability Report 2024', 
          date: 'Coming Soon', 
          summary: 'Our environmental impact and future commitments',
          excerpt: 'Our commitment to sustainable fashion continues with new eco-friendly materials and ethical production practices.', 
          comingSoon: true, 
          url: null 
        },
        { 
          title: 'Customer Spotlight: Sarah M.', 
          date: 'Coming Soon', 
          summary: 'Featured customer stories and style inspiration',
          excerpt: 'Meet Sarah, a loyal customer who shares her favorite pieces and styling tips from our collection.', 
          comingSoon: true, 
          url: null 
        },
        { 
          title: 'Behind the Scenes: Design Process', 
          date: 'Coming Soon', 
          summary: 'Inside look at our creative design journey',
          excerpt: 'Take a peek into our design studio and learn about the creative process behind our latest collection.', 
          comingSoon: true, 
          url: null 
        },
        { 
          title: 'Fall Preview Collection', 
          date: 'Coming Soon', 
          summary: 'Sneak peek at autumn fashion trends',
          excerpt: 'Get ready for autumn with our upcoming fall collection featuring cozy knits and rich textures.', 
          comingSoon: true, 
          url: null 
        },
        { 
          title: 'Exclusive Member Benefits', 
          date: 'Coming Soon', 
          summary: 'New perks for newsletter subscribers',
          excerpt: 'New perks and exclusive access for our newsletter subscribers. Stay tuned for exciting announcements.', 
          comingSoon: true, 
          url: null 
        },
        { 
          title: 'Holiday Gift Guide 2024', 
          date: 'Coming Soon', 
          summary: 'Curated gift selections for the holidays',
          excerpt: 'The perfect gifts for everyone on your list. Our curated selection will make holiday shopping effortless.', 
          comingSoon: true, 
          url: null 
        },
        { 
          title: 'Year-End Sale Preview', 
          date: 'Coming Soon', 
          summary: 'Early access to our biggest sale event',
          excerpt: 'Early access to our biggest sale of the year. Mark your calendars for exclusive deals and discounts.', 
          comingSoon: true, 
          url: null 
        }
      ];

      const allCards = [...blogArticles, ...placeholderCards].slice(0, 8);

      allCards.forEach((card, index) => {
        const cardElement = this.createCardElement(card, index);
        this.grid.appendChild(cardElement);
      });
    }

    createCardElement(cardData, index) {
      const card = document.createElement(cardData.url ? 'a' : 'div');
      card.className = `ai-newsletter-card-{{ ai_gen_id }} expanded-card ${cardData.comingSoon ? 'coming-soon' : 'has-article'}`;
      card.style.setProperty('--card-index', index);
      if (cardData.url) {
        card.href = cardData.url;
      }

      const imageContent = cardData.featured_image
        ? `<img src="${cardData.featured_image}" alt="${cardData.title}" class="ai-newsletter-card__image-{{ ai_gen_id }}" loading="lazy" width="400" height="300">`
        : `<div class="ai-newsletter-card__image-placeholder-{{ ai_gen_id }}"><svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg></div>`;

      const summaryContent = cardData.summary && !cardData.comingSoon ? `
        <div class="ai-newsletter-card__summary-{{ ai_gen_id }}">${cardData.summary}</div>
      ` : '';

      const readMoreContent = !cardData.comingSoon ? `
        <span class="ai-newsletter-card__read-more-{{ ai_gen_id }}">Read more</span>
      ` : '';

      const overlayContent = cardData.comingSoon ? `
        <div class="ai-newsletter-card__overlay-{{ ai_gen_id }}">
          <svg class="ai-newsletter-card__overlay-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12,6 12,12 16,14"/>
          </svg>
          <div class="ai-newsletter-card__overlay-text-{{ ai_gen_id }}">Coming Soon</div>
          <div class="ai-newsletter-card__overlay-subtext-{{ ai_gen_id }}">Stay tuned for updates</div>
        </div>
      ` : '';

      card.innerHTML = `
        <div class="ai-newsletter-card__image-wrapper-{{ ai_gen_id }}">
          ${imageContent}
        </div>
        <div class="ai-newsletter-card__content-{{ ai_gen_id }}">
          <div class="ai-newsletter-card__date-{{ ai_gen_id }}">${cardData.published_at || cardData.date}</div>
          <h3 class="ai-newsletter-card__title-{{ ai_gen_id }}">${cardData.title}</h3>
          ${summaryContent}
          <p class="ai-newsletter-card__excerpt-{{ ai_gen_id }}">${cardData.excerpt}</p>
          ${readMoreContent}
        </div>
        ${overlayContent}
      `;

      return card;
    }

    removeExpandedCards() {
      const expandedCards = this.grid.querySelectorAll('.expanded-card');
      expandedCards.forEach(card => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        setTimeout(() => {
          if (card.parentNode) {
            card.parentNode.removeChild(card);
          }
        }, 300);
      });
    }
  }

  customElements.define('newsletter-highlights-{{ ai_gen_id }}', NewsletterHighlights{{ ai_gen_id }});
})();
</script>

