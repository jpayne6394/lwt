{% doc %}
  @prompt
    Create a promo feature block similar to a product row layout. Include a large promotional image on one side (can be positioned left or right), feature content on the other side with heading, description text, and a prominent CTA button. The promo image should auto-fit its container with background color filling gaps. Include mobile swipe able functionality if multiple promo items are added. Style should be clean and modern with customizable colors, spacing, and border radius., this is for collection promo, the banner is over 3 product display, more than 3 auto rotate, stop rotate and display arrow controls with dots , make products smaller , make it smaller , make product cards and image banner smaller. center contents of the card, add vendor , vertically stack promo image and text , make the product cards way smaller , adjust spacing for <3 products, add a add to cart button on the card for cart pop out , move vendor below product title, ensure product card contents algin in a row, space three cards better to take up more space , smaller product cards if more than 3 cards , smaller product cards if more than 3 cards , ensure the product is added to the cart pop out when add add to cart is clicked, ensure sales are linked with sales badge, ensure sales price shows in cart , make product cards when there is only three cards smaller, only display 4 cards, if there are three cards or less adjust spacing evenly, ensure the card contents algin across , make product image smaller, fit product image to show all of the product image in the current size, sales badge should be a pill box, , ensure product card contents are the same size and align properly , ensure the add to cart button is all the same length , correct product card content spacing, ensure add to cart button is identical no matter the contents
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-promo-{{ ai_gen_id }}{width:100%;max-width:{{ block.settings.max_width }}px;margin:0 auto;padding:{{ block.settings.section_padding }}px 20px}
  .ai-collection-promo-banner-{{ ai_gen_id }}{position:relative;background:{{ block.settings.banner_background_color }};border-radius:{{ block.settings.border_radius }}px;overflow:hidden;margin-bottom:{{ block.settings.spacing_below_banner }}px}
  .ai-collection-promo-banner-container-{{ ai_gen_id }}{display:flex;flex-direction:column;gap:0}
  .ai-collection-promo-banner-image-wrapper-{{ ai_gen_id }}{width:100%;position:relative;background:{{ block.settings.image_background_color }};display:flex;align-items:center;justify-content:center;overflow:hidden;max-height:350px}
  .ai-collection-promo-banner-image-{{ ai_gen_id }}{width:100%;height:100%;object-fit:{{ block.settings.image_fit }};display:block}
  .ai-collection-promo-banner-image-placeholder-{{ ai_gen_id }}{width:100%;min-height:250px;display:flex;align-items:center;justify-content:center;background:{{ block.settings.image_background_color }};position:relative}
  .ai-collection-promo-banner-image-placeholder-{{ ai_gen_id }} svg{width:100%;height:100%;max-width:250px;max-height:250px;opacity:.3}
  .ai-collection-promo-empty-state-{{ ai_gen_id }}{position:absolute;bottom:20px;left:50%;transform:translateX(-50%);padding:12px 20px;font-size:14px;color:#666;text-align:center;pointer-events:none}
  .ai-collection-promo-banner-content-{{ ai_gen_id }}{padding:{{ block.settings.content_padding }}px;display:flex;flex-direction:column;gap:{{ block.settings.content_spacing }}px;text-align:{{ block.settings.text_alignment }};{% if block.settings.text_alignment == 'center' %}align-items:center{% elsif block.settings.text_alignment == 'right' %}align-items:flex-end{% else %}align-items:flex-start{% endif %}}
  .ai-collection-promo-banner-heading-{{ ai_gen_id }}{margin:0;font-size:{{ block.settings.heading_size }}px;color:{{ block.settings.heading_color }};font-weight:700;line-height:1.2}
  .ai-collection-promo-banner-description-{{ ai_gen_id }}{margin:0;font-size:{{ block.settings.description_size }}px;color:{{ block.settings.description_color }};line-height:1.6;max-width:600px}
  .ai-collection-promo-banner-button-{{ ai_gen_id }}{display:inline-block;padding:{{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;background:{{ block.settings.button_background_color }};color:{{ block.settings.button_text_color }};text-decoration:none;border-radius:{{ block.settings.button_border_radius }}px;font-size:{{ block.settings.button_font_size }}px;font-weight:600;transition:.3s;border:none;cursor:pointer}
  .ai-collection-promo-banner-button-{{ ai_gen_id }}:hover{background:{{ block.settings.button_hover_background_color }};color:{{ block.settings.button_hover_text_color }}}

  .ai-collection-promo-products-wrapper-{{ ai_gen_id }}{overflow:hidden;position:relative}
  .ai-collection-promo-products-track-{{ ai_gen_id }}{display:flex;gap:{{ block.settings.product_gap }}px;transition:transform .5s ease}
  .ai-collection-promo-products-track-{{ ai_gen_id }}.few-items{justify-content:space-evenly}

  .ai-collection-promo-product-card-{{ ai_gen_id }}{flex:0 0 calc((100% - ({{ block.settings.product_gap }}px * 3)) / 4);min-width:0;background:{{ block.settings.product_card_background }};border-radius:{{ block.settings.product_card_radius }}px;overflow:hidden;text-decoration:none;color:inherit;display:flex;flex-direction:column;transition:transform .3s;position:relative}
  .ai-collection-promo-products-track-{{ ai_gen_id }}.few-items .ai-collection-promo-product-card-{{ ai_gen_id }}{flex:0 0 auto;max-width:220px}
  .ai-collection-promo-product-card-{{ ai_gen_id }}:hover{transform:translateY(-4px)}

  .ai-collection-promo-product-image-wrapper-{{ ai_gen_id }}{position:relative;width:100%;padding-bottom:75%;background:{{ block.settings.product_image_background }};overflow:hidden}
  .ai-collection-promo-product-badge-{{ ai_gen_id }}{position:absolute;top:8px;left:8px;background:{{ block.settings.sale_badge_background }};color:{{ block.settings.sale_badge_text_color }};padding:6px 12px;border-radius:100px;font-size:11px;font-weight:700;text-transform:uppercase;z-index:1;letter-spacing:.5px}
  .ai-collection-promo-product-image-{{ ai_gen_id }}{position:absolute;inset:0;width:100%;height:100%;object-fit:contain}
  .ai-collection-promo-product-image-placeholder-{{ ai_gen_id }}{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:{{ block.settings.product_image_background }}}
  .ai-collection-promo-product-image-placeholder-{{ ai_gen_id }} svg{width:60%;height:60%;opacity:.3}

  .ai-collection-promo-product-info-{{ ai_gen_id }}{padding:{{ block.settings.product_card_padding }}px;text-align:center;flex-grow:1;display:flex;flex-direction:column;gap:8px}
  .ai-collection-promo-product-title-{{ ai_gen_id }}{font-size:{{ block.settings.product_title_size }}px;color:{{ block.settings.product_title_color }};margin:0;font-weight:600;line-height:1.3;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;min-height:calc({{ block.settings.product_title_size }}px * 1.3 * 2)}
  .ai-collection-promo-product-vendor-{{ ai_gen_id }}{font-size:{{ block.settings.product_vendor_size }}px;color:{{ block.settings.product_vendor_color }};margin:0;text-transform:uppercase;letter-spacing:.5px;font-weight:500;min-height:{{ block.settings.product_vendor_size }}px;line-height:{{ block.settings.product_vendor_size }}px}
  .ai-collection-promo-product-price-{{ ai_gen_id }}{font-size:{{ block.settings.product_price_size }}px;color:{{ block.settings.product_price_color }};font-weight:600;display:flex;align-items:center;gap:6px;justify-content:center;min-height:{{ block.settings.product_price_size }}px;line-height:{{ block.settings.product_price_size }}px}
  .ai-collection-promo-product-price-compare-{{ ai_gen_id }}{text-decoration:line-through;opacity:.6;font-weight:400}
  .ai-collection-promo-product-price-sale-{{ ai_gen_id }}{color:{{ block.settings.sale_price_color }}}
  .ai-collection-promo-product-button-wrapper-{{ ai_gen_id }}{margin-top:auto;padding-top:8px}
  .ai-collection-promo-add-to-cart-{{ ai_gen_id }}{width:100%;padding:10px 12px;background:{{ block.settings.add_to_cart_background }};color:{{ block.settings.add_to_cart_text_color }};border:none;border-radius:{{ block.settings.add_to_cart_border_radius }}px;font-size:{{ block.settings.add_to_cart_font_size }}px;font-weight:600;cursor:pointer;transition:.3s;min-height:40px;display:flex;align-items:center;justify-content:center}
  .ai-collection-promo-add-to-cart-{{ ai_gen_id }}:hover{background:{{ block.settings.add_to_cart_hover_background }}}
  .ai-collection-promo-add-to-cart-{{ ai_gen_id }}:disabled{opacity:.5;cursor:not-allowed}

  .ai-collection-promo-controls-{{ ai_gen_id }}{display:flex;align-items:center;justify-content:center;gap:20px;margin-top:{{ block.settings.controls_spacing }}px}
  .ai-collection-promo-arrow-{{ ai_gen_id }}{width:40px;height:40px;border-radius:50%;background:{{ block.settings.arrow_background_color }};color:{{ block.settings.arrow_color }};border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.3s;opacity:0;visibility:hidden}
  .ai-collection-promo-arrow-{{ ai_gen_id }}.active{opacity:1;visibility:visible}
  .ai-collection-promo-arrow-{{ ai_gen_id }}:hover{background:{{ block.settings.arrow_hover_background_color }}}
  .ai-collection-promo-arrow-{{ ai_gen_id }}:disabled{opacity:.3;cursor:not-allowed}
  .ai-collection-promo-arrow-{{ ai_gen_id }} svg{width:18px;height:18px}

  .ai-collection-promo-dots-{{ ai_gen_id }}{display:flex;gap:8px;opacity:0;visibility:hidden;transition:opacity .3s,visibility .3s}
  .ai-collection-promo-dots-{{ ai_gen_id }}.active{opacity:1;visibility:visible}
  .ai-collection-promo-dot-{{ ai_gen_id }}{width:8px;height:8px;border-radius:50%;background:{{ block.settings.dot_color }};border:none;cursor:pointer;padding:0;transition:.2s;opacity:.4}
  .ai-collection-promo-dot-{{ ai_gen_id }}.active{opacity:1;background:{{ block.settings.dot_active_color }}}

  .ai-collection-promo-empty-products-{{ ai_gen_id }}{text-align:center;padding:60px 20px;color:#666;font-size:16px}

  /* Consistent button height across all cards */
  .ai-collection-promo-{{ ai_gen_id }}{ --atc-h: 44px; }
  .ai-collection-promo-products-track-{{ ai_gen_id }}.few-items .ai-collection-promo-product-card-{{ ai_gen_id }}{flex:0 0 220px;width:220px;max-width:220px}
  .ai-collection-promo-add-to-cart-{{ ai_gen_id }}{
    inline-size:100%;block-size:var(--atc-h);min-height:0;padding:0 16px;box-sizing:border-box;background:{{ block.settings.add_to_cart_background }};color:{{ block.settings.add_to_cart_text_color }};border:none;border-radius:{{ block.settings.add_to_cart_border_radius }}px;font-size:{{ block.settings.add_to_cart_font_size }}px;font-weight:600;display:inline-flex;align-items:center;justify-content:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;transition:background-color .3s ease,opacity .2s ease
  }
  .ai-collection-promo-add-to-cart-{{ ai_gen_id }}:hover{background:{{ block.settings.add_to_cart_hover_background }}}
  .ai-collection-promo-add-to-cart-{{ ai_gen_id }}:disabled{opacity:.5;cursor:not-allowed}

  /* Mobile: 2x2 grid, show first 4 items, carousel off */
@media (max-width:768px){
  .ai-collection-promo-banner-image-wrapper-{{ ai_gen_id }}{max-height:200px}
  .ai-collection-promo-banner-image-placeholder-{{ ai_gen_id }}{min-height:200px}
  .ai-collection-promo-banner-content-{{ ai_gen_id }}{padding:{{ block.settings.content_padding | times: 0.75 }}px}
  .ai-collection-promo-banner-heading-{{ ai_gen_id }}{font-size:{{ block.settings.heading_size | times: 0.8 }}px}
  .ai-collection-promo-banner-description-{{ ai_gen_id }}{font-size:{{ block.settings.description_size | times: 0.9 }}px}

  /* 2 columns on phones */
  .ai-collection-promo-products-track-{{ ai_gen_id }}{
    display:grid !important;
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:16px;
    transform:none !important; /* disable carousel translate */
  }
  .ai-collection-promo-product-card-{{ ai_gen_id }}{
    flex:unset !important;
    width:auto !important;
    max-width:unset !important;
  }

  /* show only first 4 cards in the 2x2 grid */
  .ai-collection-promo-product-card-{{ ai_gen_id }}:nth-child(n+5){
    display:none !important;
  }

  /* hide arrows/dots on mobile grid */
  .ai-collection-promo-arrow-{{ ai_gen_id }},
  .ai-collection-promo-controls-{{ ai_gen_id }},
  .ai-collection-promo-dots-{{ ai_gen_id }}{
    display:none !important;
  }
}

  }
{% endstyle %}

<collection-promo-{{ ai_gen_id }} class="ai-collection-promo-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-promo-banner-{{ ai_gen_id }}">
    <div class="ai-collection-promo-banner-container-{{ ai_gen_id }}">
      <div class="ai-collection-promo-banner-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.banner_image %}
          <img src="{{ block.settings.banner_image | image_url: width: 1000 }}" alt="{{ block.settings.banner_image.alt | escape }}" loading="lazy" width="{{ block.settings.banner_image.width }}" height="{{ block.settings.banner_image.height }}" class="ai-collection-promo-banner-image-{{ ai_gen_id }}">
        {% else %}
          <div class="ai-collection-promo-banner-image-placeholder-{{ ai_gen_id }}">
            {{ 'collection-1' | placeholder_svg_tag }}
            <div class="ai-collection-promo-empty-state-{{ ai_gen_id }}">Next, add a banner image</div>
          </div>
        {% endif %}
      </div>

      <div class="ai-collection-promo-banner-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-collection-promo-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-collection-promo-banner-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-collection-promo-banner-button-{{ ai_gen_id }}">{{ block.settings.button_text }}</a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="ai-collection-promo-products-{{ ai_gen_id }}">
    {% if block.settings.collection != blank and block.settings.collection.products.size > 0 %}
      <div class="ai-collection-promo-products-wrapper-{{ ai_gen_id }}">
        <div class="ai-collection-promo-products-track-{{ ai_gen_id }} {% if block.settings.collection.products.size <= 3 %}few-items{% endif %}" data-total-products="{{ block.settings.collection.products.size }}">
          {% for product in block.settings.collection.products limit: 16 %}
            <div class="ai-collection-promo-product-card-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-collection-promo-product-link-{{ ai_gen_id }}">
                <div class="ai-collection-promo-product-image-wrapper-{{ ai_gen_id }}">
                  {% if product.compare_at_price > product.price %}
                    <div class="ai-collection-promo-product-badge-{{ ai_gen_id }}">{{ block.settings.sale_badge_text }}</div>
                  {% endif %}
                  {% if product.featured_image %}
                    <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="300" height="300" class="ai-collection-promo-product-image-{{ ai_gen_id }}">
                  {% else %}
                    <div class="ai-collection-promo-product-image-placeholder-{{ ai_gen_id }}">{{ 'product-1' | placeholder_svg_tag }}</div>
                  {% endif %}
                </div>
              </a>

              <div class="ai-collection-promo-product-info-{{ ai_gen_id }}">
                <h3 class="ai-collection-promo-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                {% if block.settings.show_vendor %}
                  <div class="ai-collection-promo-product-vendor-{{ ai_gen_id }}">{% if product.vendor != blank %}{{ product.vendor }}{% else %}&nbsp;{% endif %}</div>
                {% endif %}
                <div class="ai-collection-promo-product-price-{{ ai_gen_id }}">
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-collection-promo-product-price-compare-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
                    <span class="ai-collection-promo-product-price-sale-{{ ai_gen_id }}">{{ product.price | money }}</span>
                  {% else %}
                    {{ product.price | money }}
                  {% endif %}
                </div>
                <div class="ai-collection-promo-product-button-wrapper-{{ ai_gen_id }}">
                  <button class="ai-collection-promo-add-to-cart-{{ ai_gen_id }}" data-product-id="{{ product.id }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}" {% unless product.available %}disabled{% endunless %}>
                    {% if product.available %}{{ block.settings.add_to_cart_text }}{% else %}Sold Out{% endif %}
                  </button>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="ai-collection-promo-controls-{{ ai_gen_id }}">
        <button class="ai-collection-promo-arrow-{{ ai_gen_id }} ai-collection-promo-arrow-prev-{{ ai_gen_id }}" aria-label="Previous products">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <div class="ai-collection-promo-dots-{{ ai_gen_id }}"></div>
        <button class="ai-collection-promo-arrow-{{ ai_gen_id }} ai-collection-promo-arrow-next-{{ ai_gen_id }}" aria-label="Next products">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
    {% else %}
      <div class="ai-collection-promo-empty-products-{{ ai_gen_id }}">Next, select a collection to display products</div>
    {% endif %}
  </div>
</collection-promo-{{ ai_gen_id }}>

<script>
  (function(){
    class CollectionPromo{{ ai_gen_id }} extends HTMLElement{
      constructor(){
        super();
        this.currentIndex = 0;           // single-card index (desktop)
        this.autoRotateInterval = null;
        this.isAutoRotating = false;
      }

      connectedCallback(){
        this.track = this.querySelector('.ai-collection-promo-products-track-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-collection-promo-product-card-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-collection-promo-arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-collection-promo-arrow-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-collection-promo-dots-{{ ai_gen_id }}');
        if(!this.track || this.cards.length === 0) return;

        this.init();
        this.setupAddToCart();
      }

      init(){
        this.updateLayout();
        this.setupControls();
        this.setupEventListeners();
        window.addEventListener('resize', ()=>this.updateLayout());
      }

      /* turn grid mode on/off (mobile vs desktop) */
      setGridMode(isGrid){
        if(!this.track) return;
        if(isGrid){
          this.stopAutoRotate();
          this.track.style.transform = 'none';
          this.prevButton?.classList.remove('active');
          this.nextButton?.classList.remove('active');
          this.dotsContainer?.classList.remove('active');
        }
      }

      /* AJAX ATC + section refresh to sync cart drawer + bubble */
      setupAddToCart(){
        const buttons = this.querySelectorAll('.ai-collection-promo-add-to-cart-{{ ai_gen_id }}');

        const refreshCartUI = async () => {
          try{
            const sections = ['cart-drawer','cart-icon-bubble'];
            const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
            const res = await fetch(`${root}?sections=${sections.join(',')}`, { headers:{ Accept:'application/json' }});
            const json = await res.json();

            const drawerEl = document.querySelector('cart-drawer');
            if(drawerEl){
              const drawerSectionId = drawerEl.closest('[data-section-id]')?.dataset.sectionId || 'cart-drawer';
              const html = json[drawerSectionId] || json['cart-drawer'];
              if(html){
                const tmp = document.createElement('div');
                tmp.innerHTML = html;
                const fresh = tmp.querySelector('cart-drawer') || tmp.firstElementChild;
                if(fresh) drawerEl.replaceWith(fresh);
              }
              (document.querySelector('cart-drawer')||drawerEl)?.open?.();
            }

            const bubbleEl = document.querySelector('cart-icon-bubble');
            if(bubbleEl){
              const bubbleSectionId = bubbleEl.closest('[data-section-id]')?.dataset.sectionId || 'cart-icon-bubble';
              const bubbleHtml = json[bubbleSectionId] || json['cart-icon-bubble'];
              if(bubbleHtml) bubbleEl.outerHTML = bubbleHtml;
            }
          }catch(e){
            document.dispatchEvent(new CustomEvent('cart:refresh'));
            document.querySelector('cart-drawer')?.open?.();
            document.querySelector('cart-notification')?.open?.();
          }
        };

        buttons.forEach(btn=>{
          btn.addEventListener('click', async (e)=>{
            e.preventDefault(); e.stopPropagation();
            const variantId = btn.getAttribute('data-variant-id');
            if(!variantId) return;
            const original = btn.textContent;
            btn.disabled = true; btn.textContent = 'Adding…';
            try{
              const r = await fetch('/cart/add.js', {
                method:'POST',
                headers:{ 'Content-Type':'application/json', Accept:'application/json' },
                body: JSON.stringify({ items:[{ id: variantId, quantity:1 }] })
              });
              if(!r.ok) throw new Error('add_failed');
              btn.textContent = 'Added ✓';
              document.querySelector('cart-drawer')?.open?.();
              document.querySelector('cart-notification')?.open?.();
              document.dispatchEvent(new CustomEvent('cart:refresh'));
              await refreshCartUI();
            }catch(err){
              console.error(err);
              btn.textContent = 'Error';
            }finally{
              setTimeout(()=>{ btn.textContent = original; btn.disabled = false; }, 1200);
            }
          });
        });
      }

      updateLayout(){
        this.isMobile = window.innerWidth <= 768;

        /* MOBILE = GRID MODE, disable carousel behavior */
        if(this.isMobile){
          this.setGridMode(true);
          return;
        }

        /* DESKTOP = 4-across carousel */
        this.setGridMode(false);
        this.itemsPerView = 4;
        this.lastStartIndex = Math.max(0, this.cards.length - this.itemsPerView);
        this.currentIndex = Math.min(this.currentIndex, this.lastStartIndex);
        this.updateControls();
        this.goToIndex(this.currentIndex);
      }

      setupControls(){
        /* skip controls/dots/autoplay entirely on mobile grid */
        if(this.isMobile){
          this.stopAutoRotate();
          this.prevButton?.classList.remove('active');
          this.nextButton?.classList.remove('active');
          this.dotsContainer?.classList.remove('active');
          return;
        }

        if(this.cards.length > 1){
          this.dotsContainer.classList.add('active');
          this.createDots();
          this.prevButton?.classList.add('active');
          this.nextButton?.classList.add('active');
          if(this.cards.length > this.itemsPerView) this.startAutoRotate();
        }
      }

      /* Single-card dots (desktop) */
      createDots(){
        this.dotsContainer.innerHTML = '';
        for(let i=0;i<this.cards.length;i++){
          const dot = document.createElement('button');
          dot.classList.add('ai-collection-promo-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Go to item ' + (i+1));
          dot.addEventListener('click', ()=>{ this.stopAutoRotate(); this.goToIndex(i); });
          this.dotsContainer.appendChild(dot);
        }
        this.updateDots();
      }

      updateDots(){
        const dots = this.dotsContainer.querySelectorAll('.ai-collection-promo-dot-{{ ai_gen_id }}');
        dots.forEach((d,i)=>d.classList.toggle('active', i === this.currentIndex));
      }

      setupEventListeners(){
        this.prevButton?.addEventListener('click', ()=>{ this.stopAutoRotate(); this.prev(); });
        this.nextButton?.addEventListener('click', ()=>{ this.stopAutoRotate(); this.next(); });

        this.track.addEventListener('mouseenter', ()=>this.stopAutoRotate());
        this.track.addEventListener('mouseleave', ()=>{ if(!this.isMobile && this.cards.length > this.itemsPerView) this.startAutoRotate(); });

        let sx = 0;
        this.track.addEventListener('touchstart', e=>{ sx = e.changedTouches[0].screenX; this.stopAutoRotate(); }, { passive:true });
        this.track.addEventListener('touchend', e=>{
          const dx = sx - e.changedTouches[0].screenX;
          if(Math.abs(dx) > 50) (dx>0)?this.next():this.prev();
        });
      }

      goToIndex(i){
        this.currentIndex = Math.max(0, Math.min(i, this.lastStartIndex));
        const cardW = this.cards[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap)||0;
        const offset = this.currentIndex * (cardW + gap);
        this.track.style.transform = `translateX(-${offset}px)`;
        this.updateButtons();
        this.updateDots();
      }

      next(){
        if(this.currentIndex < this.lastStartIndex) this.goToIndex(this.currentIndex + 1);
        else this.goToIndex(0);
      }
      prev(){
        if(this.currentIndex > 0) this.goToIndex(this.currentIndex - 1);
        else this.goToIndex(this.lastStartIndex);
      }

      updateButtons(){
        this.prevButton && (this.prevButton.disabled = false);
        this.nextButton && (this.nextButton.disabled = false);
      }

      updateControls(){
        if(this.cards.length <= 1){
          this.prevButton?.classList.remove('active');
          this.nextButton?.classList.remove('active');
          this.dotsContainer.classList.remove('active');
          this.stopAutoRotate();
        }else{
          this.dotsContainer.classList.add('active');
          this.createDots();
          this.prevButton?.classList.add('active');
          this.nextButton?.classList.add('active');
          if(!this.isAutoRotating && this.cards.length > this.itemsPerView) this.startAutoRotate();
        }
      }

      startAutoRotate(){
        this.stopAutoRotate();
        this.isAutoRotating = true;
        this.autoRotateInterval = setInterval(()=>this.next(), 5000);
      }
      stopAutoRotate(){
        if(this.autoRotateInterval) clearInterval(this.autoRotateInterval);
        this.autoRotateInterval = null;
        this.isAutoRotating = false;
      }

      disconnectedCallback(){ this.stopAutoRotate(); }
    }

    customElements.define('collection-promo-{{ ai_gen_id }}', CollectionPromo{{ ai_gen_id }});
  })();
</script>

