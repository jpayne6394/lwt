{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign promo_overlay_alpha = block.settings.promo_overlay_opacity | default: 35 | times: 0.01 %}

{% style %}
  .ai-product-row-{{ ai_gen_id }}{padding:{{ block.settings.section_padding }}px 20px;background:{{ block.settings.background_color }}}
  .ai-product-row-container-{{ ai_gen_id }}{
    max-width:1200px;margin:0 auto;display:grid;
    grid-template-columns:{% if block.settings.image_position == 'left' %}400px 1fr{% else %}1fr 400px{% endif %};
    gap:30px;align-items:stretch
  }

  /* === PROMO BANNER (background-image panel) === */
  .ai-product-row-promo-{{ ai_gen_id }}{% if block.settings.image_position == 'right' %}{ order:2 }{% endif %}

  .ai-product-row-promo-panel-{{ ai_gen_id }}{
    position:relative;border-radius:{{ block.settings.image_border_radius }}px;overflow:hidden;
    min-height:500px;background-size:cover;background-position:center;
    background-color:{{ block.settings.promo_background_color }};
    box-shadow:0 16px 48px rgba(0,0,0,.08)
  }
  .ai-product-row-promo-overlay-{{ ai_gen_id }}{
    position:absolute;inset:0;border-radius:{{ block.settings.image_border_radius }}px;
    background: {{ block.settings.promo_overlay_color | default: '#000000' | color_modify: 'alpha', promo_overlay_alpha }};
  }
  .ai-product-row-promo-placeholder-{{ ai_gen_id }}{
    width:100%;height:500px;background:#f4f4f4;border-radius:{{ block.settings.image_border_radius }}px;
    display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden
  }
  .ai-product-row-empty-state-{{ ai_gen_id }}{
    position:absolute;bottom:20px;left:50%;transform:translateX(-50%);padding:12px 20px;font-size:14px;color:#666;text-align:center;pointer-events:none
  }

  /* === CONTENT (products + CTA) === */
  .ai-product-row-content-{{ ai_gen_id }}{display:flex;flex-direction:column;gap:32px;padding-top:30px}
  .ai-product-row-products-{{ ai_gen_id }}{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}

  .ai-product-card-link-{{ ai_gen_id }}{text-decoration:none;color:inherit;display:block;height:100%}
  .ai-product-card-{{ ai_gen_id }}{
    background:{{ block.settings.card_background_color }};border-radius:{{ block.settings.card_border_radius }}px;padding:12px;
    display:grid;grid-template-rows:auto auto auto 1fr auto;gap:8px;box-shadow:0 2px 6px rgba(0,0,0,.08);
    text-align:center;align-items:center;height:100%;transition:transform .2s, box-shadow .2s;position:relative
  }
  .ai-product-card-link-{{ ai_gen_id }}:hover .ai-product-card-{{ ai_gen_id }}{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.12)}

  .ai-product-card-image-wrapper-{{ ai_gen_id }}{width:100%;max-width:140px;margin:0 auto;aspect-ratio:1/1;overflow:hidden;border-radius:6px;background:#f4f4f4;position:relative}
  .ai-product-card-image-{{ ai_gen_id }}{width:100%;height:100%;object-fit:contain;display:block}
  .ai-product-card-image-placeholder-{{ ai_gen_id }}{width:100%;height:100%;background:#f4f4f4;display:flex;align-items:center;justify-content:center}
  .ai-product-card-image-placeholder-{{ ai_gen_id }} svg{width:100%;height:100%;object-fit:contain}

  .ai-product-card-sale-badge-{{ ai_gen_id }}{
    position:absolute;top:8px;left:8px;background:{{ block.settings.sale_badge_color }};
    color:{{ block.settings.sale_badge_text_color }};padding:4px 10px;border-radius:20px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;z-index:1
  }

  .ai-product-card-title-{{ ai_gen_id }}{font-size:12px;font-weight:600;color:{{ block.settings.text_color }};margin:0;line-height:1.3}
  .ai-product-card-vendor-{{ ai_gen_id }}{font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:#999;margin:0;min-height:14px}
  .ai-product-card-price-{{ ai_gen_id }}{font-size:14px;font-weight:700;color:{{ block.settings.price_color }};display:flex;gap:6px;align-items:center;justify-content:center;flex-wrap:wrap;min-height:20px}
  .ai-product-card-compare-price-{{ ai_gen_id }}{font-size:11px;text-decoration:line-through;color:#999;font-weight:400}
  .ai-product-card-sale-price-{{ ai_gen_id }}{color:{{ block.settings.sale_price_color }}}

  .ai-product-card-add-to-cart-{{ ai_gen_id }}{
    padding:8px 14px;background:{{ block.settings.button_color }};color:{{ block.settings.button_text_color }};
    border:none;border-radius:{{ block.settings.button_border_radius }}px;cursor:pointer;font-size:11px;font-weight:600;transition:background .3s;width:100%
  }
  .ai-product-card-add-to-cart-{{ ai_gen_id }}:hover{background:{{ block.settings.button_hover_color }}}
  .ai-product-card-add-to-cart-{{ ai_gen_id }}:disabled{background:#ccc;cursor:not-allowed}

  .ai-product-row-cta-{{ ai_gen_id }}{text-align:center;margin-top:8px}
  .ai-product-row-cta-button-{{ ai_gen_id }}{
    display:inline-block;padding:{{ block.settings.cta_button_size }}px {{ block.settings.cta_button_size | times: 2 }}px;
    background:{{ block.settings.cta_button_color }};color:{{ block.settings.cta_button_text_color }};
    text-decoration:none;border-radius:{{ block.settings.cta_button_border_radius }}px;
    font-size:{{ block.settings.cta_button_size | times: 0.9 }}px;font-weight:600;transition:background .3s
  }
  .ai-product-row-cta-button-{{ ai_gen_id }}:hover{background:{{ block.settings.cta_button_hover_color }}}

  .ai-product-row-empty-products-{{ ai_gen_id }}{grid-column:1 / -1;text-align:center;padding:40px;color:#999;font-style:italic}

  /* Mobile */
  @media (max-width:990px){
    .ai-product-row-container-{{ ai_gen_id }}{grid-template-columns:1fr;gap:24px}
    .ai-product-row-promo-{{ ai_gen_id }}{order:0 !important}
    .ai-product-row-content-{{ ai_gen_id }}{padding-top:0}
    .ai-product-row-promo-panel-{{ ai_gen_id }}, .ai-product-row-promo-placeholder-{{ ai_gen_id }}{min-height:320px}
    .ai-product-row-products-{{ ai_gen_id }}{grid-template-columns:repeat(2,1fr)}
  }
  @media (max-width:749px){
    .ai-product-row-products-{{ ai_gen_id }}{
      display:flex;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;gap:14px;padding-bottom:10px
    }
    .ai-product-row-products-{{ ai_gen_id }}::-webkit-scrollbar{display:none}
    .ai-product-row-products-{{ ai_gen_id }} > *{flex:0 0 85%;scroll-snap-align:center}
    .ai-product-row-{{ ai_gen_id }}{padding:{{ block.settings.section_padding | times: 0.6 }}px 16px}

    .swipe-dots-{{ ai_gen_id }}{display:flex;justify-content:center;gap:8px;margin-top:16px}
    .swipe-dot-{{ ai_gen_id }}{width:8px;height:8px;border-radius:50%;background:#ddd;transition:background .3s}
    .swipe-dot-{{ ai_gen_id }}.active{background:{{ block.settings.button_color }}}
  }
{% endstyle %}

<product-row-{{ ai_gen_id }} class="ai-product-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-row-container-{{ ai_gen_id }}">
    <!-- PROMO COLUMN -->
    <div class="ai-product-row-promo-{{ ai_gen_id }}">
      {% if block.settings.promo_image %}
        <div class="ai-product-row-promo-panel-{{ ai_gen_id }}"
             style="background-image:url({{ block.settings.promo_image | image_url: width: 1200 }});">
          <div class="ai-product-row-promo-overlay-{{ ai_gen_id }}"></div>
        </div>
      {% else %}
        <div class="ai-product-row-promo-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-product-row-empty-state-{{ ai_gen_id }}">Next, add a promotional image</div>
        </div>
      {% endif %}
    </div>

    <!-- PRODUCTS + CTA -->
    <div class="ai-product-row-content-{{ ai_gen_id }}">
      <div class="ai-product-row-products-{{ ai_gen_id }}">
        {% liquid
          assign product_1 = block.settings.product_1
          assign product_2 = block.settings.product_2
          assign product_3 = block.settings.product_3
        %}
        {% if product_1 == blank and product_2 == blank and product_3 == blank %}
          <div class="ai-product-row-empty-products-{{ ai_gen_id }}">Next, add up to 3 products to display</div>
        {% else %}
          {% for i in (1..3) %}
            {% liquid
              assign product_key = 'product_' | append: i
              assign product = block.settings[product_key]
            %}
            {% if product != blank %}
              {% liquid
                assign variant = product.selected_or_first_available_variant
                assign on_sale = false
                if variant.compare_at_price > variant.price
                  assign on_sale = true
                endif
              %}
              <!-- IMPORTANT: this wrapper div is a "slide" on mobile -->
              <div class="ai-product-slide-{{ ai_gen_id }}">
                <a href="{{ product.url }}" class="ai-product-card-link-{{ ai_gen_id }}">
                  <div class="ai-product-card-{{ ai_gen_id }}">
                    <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
                      {% if on_sale %}<span class="ai-product-card-sale-badge-{{ ai_gen_id }}">Sale</span>{% endif %}
                      {% if product.featured_image %}
                        <img src="{{ product.featured_image | image_url: width: 200 }}"
                             alt="{{ product.featured_image.alt | escape }}"
                             loading="lazy" width="200" height="200"
                             class="ai-product-card-image-{{ ai_gen_id }}">
                      {% else %}
                        <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">{{ 'product-1' | placeholder_svg_tag }}</div>
                      {% endif %}
                    </div>
                    <h3 class="ai-product-card-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                    <p class="ai-product-card-vendor-{{ ai_gen_id }}">{% if product.vendor != blank %}{{ product.vendor }}{% endif %}</p>
                    <div class="ai-product-card-price-{{ ai_gen_id }}">
                      {% if on_sale %}
                        <span class="ai-product-card-compare-price-{{ ai_gen_id }}">{{ variant.compare_at_price | money }}</span>
                        <span class="ai-product-card-sale-price-{{ ai_gen_id }}">{{ variant.price | money }}</span>
                      {% else %}
                        <span>{{ variant.price | money }}</span>
                      {% endif %}
                    </div>

                    <button
                      class="ai-product-card-add-to-cart-{{ ai_gen_id }}"
                      data-product-id="{{ product.id }}"
                      data-variant-id="{{ variant.id }}"
                      {% unless product.available %}disabled{% endunless %}
                    >
                      {% if product.available %}{{ block.settings.add_to_cart_text }}{% else %}Sold out{% endif %}
                    </button>
                  </div>
                </a>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>

      <!-- Mobile swipe dots (auto-built by JS so it scales to any number of products) -->
      <div class="swipe-dots-{{ ai_gen_id }}" style="display:none;"></div>

      {% if block.settings.show_cta_button and block.settings.cta_button_text != blank %}
        <div class="ai-product-row-cta-{{ ai_gen_id }}">
          <a href="{{ block.settings.cta_button_link }}" class="ai-product-row-cta-button-{{ ai_gen_id }}">{{ block.settings.cta_button_text }}</a>
        </div>
      {% endif %}
    </div>
  </div>
</product-row-{{ ai_gen_id }}>

<script>
  (function() {
    const TAG = 'product-row-{{ ai_gen_id }}';
    if (customElements.get(TAG)) return;

    class ProductRow{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        if (this._mounted) return;
        this._mounted = true;

        this.addToCartButtons = this.querySelectorAll('.ai-product-card-add-to-cart-{{ ai_gen_id }}');
        this.setupATC();
        this.setupDots();
      }

      disconnectedCallback() {
        this._mounted = false;

        if (this._dotsTrack && this._onTrackScroll) {
          this._dotsTrack.removeEventListener('scroll', this._onTrackScroll);
        }
        if (this._onResize) window.removeEventListener('resize', this._onResize);

        if (this._raf) cancelAnimationFrame(this._raf);

        this._dotsTrack = null;
        this._dotsWrap = null;
        this._dots = [];
        this._slides = [];
        this._onTrackScroll = null;
        this._onResize = null;
        this._raf = 0;
      }

      setupATC() {
        const refreshCartBits = async () => {
          try {
            const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
            const sections = ['cart-drawer','cart-icon-bubble'];
            const res = await fetch(`${root}?sections=${sections.join(',')}`, { headers:{Accept:'application/json'} });
            const json = await res.json();

            const drawer = document.querySelector('cart-drawer');
            if (drawer) {
              const drawerSectionId = drawer.closest('[data-section-id]')?.dataset.sectionId || 'cart-drawer';
              const html = json[drawerSectionId] || json['cart-drawer'];
              if (html) {
                const tmp = document.createElement('div'); tmp.innerHTML = html;
                const fresh = tmp.querySelector('cart-drawer') || tmp.firstElementChild;
                if (fresh) drawer.replaceWith(fresh);
              }
              (document.querySelector('cart-drawer')||drawer)?.open?.();
            }

            const bubble = document.querySelector('cart-icon-bubble');
            if (bubble) {
              const bubbleSectionId = bubble.closest('[data-section-id]')?.dataset.sectionId || 'cart-icon-bubble';
              const bhtml = json[bubbleSectionId] || json['cart-icon-bubble'];
              if (bhtml) bubble.outerHTML = bhtml;
            }
          } catch(e) {
            document.dispatchEvent(new CustomEvent('cart:refresh'));
            document.querySelector('cart-drawer')?.open?.();
            document.querySelector('cart-notification')?.open?.();
          }
        };

        this.addToCartButtons.forEach(btn=>{
          btn.addEventListener('click', async (e)=>{
            e.preventDefault(); e.stopPropagation();
            const variantId = btn.getAttribute('data-variant-id');
            if(!variantId || btn.disabled) return;

            const original = btn.textContent;
            btn.disabled = true; btn.textContent = 'Adding...';

            try{
              const r = await fetch((window.Shopify?.routes?.root || '/') + 'cart/add.js', {
                method:'POST',
                headers:{'Content-Type':'application/json','Accept':'application/json'},
                body: JSON.stringify({ items:[{ id: variantId, quantity:1 }] })
              });
              if(!r.ok) throw new Error('add_failed');

              btn.textContent = 'Added!';
              document.querySelector('cart-drawer')?.open?.();
              document.querySelector('cart-notification')?.open?.();
              document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles:true }));
              await refreshCartBits();
            }catch(err){
              console.error(err);
              btn.textContent = 'Error';
            }finally{
              setTimeout(()=>{ btn.textContent = original; btn.disabled = false; }, 1500);
            }
          });
        });
      }

      setupDots() {
        const mq = window.matchMedia('(max-width: 749px)');
        if (!mq.matches) return;

        const track = this.querySelector('.ai-product-row-products-{{ ai_gen_id }}');
        const dotsWrap = this.querySelector('.swipe-dots-{{ ai_gen_id }}');
        if (!track || !dotsWrap) return;

        // Slides are direct children (your wrapper div per product)
        const slides = Array.from(track.children).filter(el => el.nodeType === 1);
        if (slides.length <= 1) return;

        // Build dots from actual rendered slides (scales to any number)
        dotsWrap.innerHTML = '';
        slides.forEach((_, i) => {
          const d = document.createElement('div');
          d.className = 'swipe-dot-{{ ai_gen_id }}';
          d.dataset.index = String(i);
          dotsWrap.appendChild(d);
        });

        const dots = Array.from(dotsWrap.querySelectorAll('.swipe-dot-{{ ai_gen_id }}'));
        dotsWrap.style.display = 'flex';

        const update = () => {
          const trackRect = track.getBoundingClientRect();
          const trackCenter = trackRect.left + (trackRect.width / 2);

          let activeIndex = 0;
          let minDist = Infinity;

          slides.forEach((slide, i) => {
            const r = slide.getBoundingClientRect();
            const center = r.left + (r.width / 2);
            const dist = Math.abs(trackCenter - center);
            if (dist < minDist) {
              minDist = dist;
              activeIndex = i;
            }
          });

          dots.forEach((dot, i) => dot.classList.toggle('active', i === activeIndex));
        };

        const onScroll = () => {
          if (this._raf) return;
          this._raf = requestAnimationFrame(() => {
            this._raf = 0;
            update();
          });
        };

        track.addEventListener('scroll', onScroll, { passive: true });

        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const i = Number(dot.dataset.index || 0);
            if (slides[i]) {
              slides[i].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
            }
          });
        });

        const onResize = () => {
          if (!mq.matches) {
            dotsWrap.style.display = 'none';
            return;
          }
          dotsWrap.style.display = 'flex';
          update();
        };

        window.addEventListener('resize', onResize, { passive: true });

        // Save refs for cleanup
        this._dotsTrack = track;
        this._dotsWrap = dotsWrap;
        this._slides = slides;
        this._dots = dots;
        this._onTrackScroll = onScroll;
        this._onResize = onResize;

        update();
      }
    }

    customElements.define(TAG, ProductRow{{ ai_gen_id }});
  })();
</script>




{% schema %}
{
  "name": "Product row",
  "tag": null,
  "settings": [
    { "type":"header","content":"Promotional image" },
    { "type":"image_picker","id":"promo_image","label":"Image" },
    { "type":"select","id":"image_position","label":"Image position","options":[{"value":"left","label":"Left"},{"value":"right","label":"Right"}],"default":"left" },
    { "type":"range","id":"image_border_radius","min":0,"max":40,"step":2,"unit":"px","label":"Border radius","default":12 },

    { "type":"color","id":"promo_background_color","label":"Banner fallback background","default":"#e8e4dc" },
    { "type":"color","id":"promo_overlay_color","label":"Overlay color","default":"#000000" },
    { "type":"range","id":"promo_overlay_opacity","min":0,"max":90,"step":5,"unit":"%","label":"Overlay opacity","default":35 },

    { "type":"header","content":"Products" },
    { "type":"product","id":"product_1","label":"Product 1" },
    { "type":"product","id":"product_2","label":"Product 2" },
    { "type":"product","id":"product_3","label":"Product 3" },
    { "type":"text","id":"add_to_cart_text","label":"Add to cart button text","default":"Add to cart" },

    { "type":"header","content":"CTA button" },
    { "type":"checkbox","id":"show_cta_button","label":"Show CTA button","default": true },
    { "type":"text","id":"cta_button_text","label":"Button text","default":"View all products" },
    { "type":"url","id":"cta_button_link","label":"Button link" },
    { "type":"range","id":"cta_button_size","min":10,"max":24,"step":2,"unit":"px","label":"Button size","default":14 },
    { "type":"range","id":"cta_button_border_radius","min":0,"max":40,"step":2,"unit":"px","label":"Button border radius","default":40 },

    { "type":"header","content":"Colors" },
    { "type":"color","id":"background_color","label":"Section background","default":"#ffffff" },
    { "type":"color","id":"card_background_color","label":"Card background","default":"#ffffff" },
    { "type":"color","id":"text_color","label":"Text","default":"#121212" },
    { "type":"color","id":"price_color","label":"Price","default":"#4b3f82" },
    { "type":"color","id":"sale_price_color","label":"Sale price","default":"#b43333" },
    { "type":"color","id":"sale_badge_color","label":"Sale badge background","default":"#b43333" },
    { "type":"color","id":"sale_badge_text_color","label":"Sale badge text","default":"#ffffff" },
    { "type":"color","id":"button_color","label":"Add to cart button","default":"#4b3f82" },
    { "type":"color","id":"button_hover_color","label":"Add to cart hover","default":"#3a2f66" },
    { "type":"color","id":"button_text_color","label":"Add to cart text","default":"#ffffff" },

    { "type":"color","id":"cta_button_color","label":"CTA button","default":"#4b3f82" },
    { "type":"color","id":"cta_button_hover_color","label":"CTA button hover","default":"#3a2f66" },
    { "type":"color","id":"cta_button_text_color","label":"CTA button text","default":"#ffffff" },

    { "type":"header","content":"Style" },
    { "type":"range","id":"section_padding","min":0,"max":100,"step":4,"unit":"px","label":"Section padding","default":60 },
    { "type":"range","id":"card_border_radius","min":0,"max":40,"step":2,"unit":"px","label":"Card border radius","default":12 },
    { "type":"range","id":"button_border_radius","min":0,"max":40,"step":2,"unit":"px","label":"Add to cart border radius","default":40 }
  ],
  "presets":[{ "name":"Product row" }]
}
{% endschema %}
