{% doc %}
  @prompt
    Create a premium collection promotional block that uses GraphQL to efficiently fetch collection data. The block should query a collection by handle using GraphQL and display the collection title, featured image, and link. Include schema settings for: collection handle picker, heading text, button text, image aspect ratio (square, portrait, landscape), text overlay position (top-left, top-right, bottom-left, bottom-right, center), and color scheme. Use modern CSS with flexbox/grid, implement lazy loading for images, use Shopify image filters for responsive sizing, and include hover effects. The design should be luxury/editorial with clean typography and smooth transitions. Make it fully responsive with mobile-first approach.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign collection_handle = block.settings.collection_handle
  assign collection_query = 'query($handle: String!) { collection(handle: $handle) { id title handle image { url altText width height } } }'
  assign collection_result = collection_query | graphql: handle: collection_handle
  assign collection = collection_result.data.collection
%}

{% style %}
  .ai-collection-promo-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-collection-promo-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-promo-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-collection-promo-image-wrapper-{{ ai_gen_id }}--square {
    aspect-ratio: 1 / 1;
  }

  .ai-collection-promo-image-wrapper-{{ ai_gen_id }}--portrait {
    aspect-ratio: 3 / 4;
  }

  .ai-collection-promo-image-wrapper-{{ ai_gen_id }}--landscape {
    aspect-ratio: 16 / 9;
  }

  .ai-collection-promo-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-collection-promo-link-{{ ai_gen_id }}:hover .ai-collection-promo-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-collection-promo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-collection-promo-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-collection-promo-overlay-{{ ai_gen_id }} {
    position: absolute;
    padding: {{ block.settings.overlay_padding }}px;
    z-index: 2;
  }

  .ai-collection-promo-overlay-{{ ai_gen_id }}--top-left {
    top: 0;
    left: 0;
    text-align: left;
  }

  .ai-collection-promo-overlay-{{ ai_gen_id }}--top-right {
    top: 0;
    right: 0;
    text-align: right;
  }

  .ai-collection-promo-overlay-{{ ai_gen_id }}--bottom-left {
    bottom: 0;
    left: 0;
    text-align: left;
  }

  .ai-collection-promo-overlay-{{ ai_gen_id }}--bottom-right {
    bottom: 0;
    right: 0;
    text-align: right;
  }

  .ai-collection-promo-overlay-{{ ai_gen_id }}--center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
  }

  .ai-collection-promo-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-collection-promo-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.2;
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-style: {{ settings.type_header_font.style }};
  }

  .ai-collection-promo-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.3;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }};
    font-style: {{ settings.type_body_font.style }};
  }

  .ai-collection-promo-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 32px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: {{ settings.buttons_radius }}px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: {{ settings.buttons_border_thickness }}px solid;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
  }

  .ai-collection-promo-link-{{ ai_gen_id }}:hover .ai-collection-promo-button-{{ ai_gen_id }} {
    transform: translateY(-2px);
  }

  .ai-collection-promo-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-promo-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-collection-promo-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }

    .ai-collection-promo-button-{{ ai_gen_id }} {
      padding: 10px 24px;
      font-size: calc({{ block.settings.button_text_size }}px * 0.9);
    }

    .ai-collection-promo-overlay-{{ ai_gen_id }} {
      padding: {{ block.settings.overlay_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div
  class="ai-collection-promo-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}"
  {{ block.shopify_attributes }}
>
  {% if collection %}
    <a
      href="/collections/{{ collection.handle }}"
      class="ai-collection-promo-link-{{ ai_gen_id }}"
      aria-label="View {{ collection.title }} collection"
    >
      <div class="ai-collection-promo-image-wrapper-{{ ai_gen_id }} ai-collection-promo-image-wrapper-{{ ai_gen_id }}--{{ block.settings.image_aspect_ratio }}">
        {% if collection.image %}
          <img
            src="{{ collection.image.url | image_url: width: 1500 }}"
            srcset="
              {{ collection.image.url | image_url: width: 375 }} 375w,
              {{ collection.image.url | image_url: width: 750 }} 750w,
              {{ collection.image.url | image_url: width: 1100 }} 1100w,
              {{ collection.image.url | image_url: width: 1500 }} 1500w
            "
            sizes="(min-width: 1200px) 1100px, (min-width: 750px) calc(100vw - 10rem), calc(100vw - 3rem)"
            alt="{{ collection.image.altText | escape }}"
            loading="lazy"
            width="{{ collection.image.width }}"
            height="{{ collection.image.height }}"
            class="ai-collection-promo-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-collection-promo-placeholder-{{ ai_gen_id }}">
            {{ 'collection-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        <div class="ai-collection-promo-overlay-{{ ai_gen_id }} ai-collection-promo-overlay-{{ ai_gen_id }}--{{ block.settings.text_position }}">
          <div class="ai-collection-promo-content-{{ ai_gen_id }}">
            {% if block.settings.heading != blank %}
              <h3 class="ai-collection-promo-heading-{{ ai_gen_id }}">
                {{ block.settings.heading }}
              </h3>
            {% endif %}

            {% if block.settings.show_collection_title %}
              <p class="ai-collection-promo-title-{{ ai_gen_id }}">
                {{ collection.title }}
              </p>
            {% endif %}

            {% if block.settings.button_text != blank %}
              <span class="ai-collection-promo-button-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </span>
            {% endif %}
          </div>
        </div>
      </div>
    </a>
  {% else %}
    <div class="ai-collection-promo-image-wrapper-{{ ai_gen_id }} ai-collection-promo-image-wrapper-{{ ai_gen_id }}--{{ block.settings.image_aspect_ratio }}">
      <div class="ai-collection-promo-placeholder-{{ ai_gen_id }}">
        {{ 'collection-1' | placeholder_svg_tag }}
        <div class="ai-collection-promo-empty-state-{{ ai_gen_id }}">
          Next, select a collection
        </div>
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Collection promo",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "text",
      "id": "collection_handle",
      "label": "Collection handle",
      "info": "Enter the collection handle (e.g., 'all' or 'featured-products')"
    },
    {
      "type": "checkbox",
      "id": "show_collection_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Discover"
    },
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "square",
          "label": "Square (1:1)"
        },
        {
          "value": "portrait",
          "label": "Portrait (3:4)"
        },
        {
          "value": "landscape",
          "label": "Landscape (16:9)"
        }
      ],
      "default": "landscape"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text position",
      "options": [
        {
          "value": "top-left",
          "label": "Top left"
        },
        {
          "value": "top-right",
          "label": "Top right"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "bottom-left",
          "label": "Bottom left"
        },
        {
          "value": "bottom-right",
          "label": "Bottom right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "overlay_padding",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Overlay padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Content gap",
      "default": 16
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 72,
      "step": 4,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Collection title size",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Button text size",
      "default": 12
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Collection promo"
    }
  ]
}
{% endschema %}
