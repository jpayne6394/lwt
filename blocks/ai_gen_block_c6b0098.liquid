{% doc %}
  @prompt
    Create a luxury-styled 3-button CTA section with elegant buttons for "Book Appointment", "Homepage", and "Shopping Page". Use premium design elements with sophisticated styling, refined typography, elegant spacing, and luxury visual effects. Each button should have distinct but cohesive styling with hover effects and smooth transitions. Ensure it integrates seamlessly with the theme's design language and maintains a high-end, professional appearance., more styled like the site theme , break it up more three cards with image insert , make the buttons in line with one another
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-cta-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
    {% if block.settings.background_gradient != blank %}background: {{ block.settings.background_gradient }};{% endif %}
  }
  .ai-luxury-cta-container-{{ ai_gen_id }} { max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 {{ settings.spacing_grid_horizontal }}px; }

  .ai-luxury-cta-header-{{ ai_gen_id }} { text-align: {{ block.settings.text_alignment }}; margin-bottom: {{ block.settings.content_spacing }}px; }
  .ai-luxury-cta-heading-{{ ai_gen_id }}{
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }}; font-style: {{ settings.type_header_font.style }};
    font-size: calc({{ block.settings.heading_size }}px * {{ settings.heading_scale | divided_by: 100.0 }}); line-height:1.2;
    color: {{ block.settings.heading_color }}; margin: 0 0 {{ block.settings.heading_spacing }}px; letter-spacing: {{ block.settings.heading_letter_spacing }}px;
  }
  .ai-luxury-cta-subheading-{{ ai_gen_id }}{
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }}; font-style: {{ settings.type_body_font.style }};
    font-size: calc({{ block.settings.subheading_size }}px * {{ settings.body_scale | divided_by: 100.0 }}); line-height:1.4;
    color: {{ block.settings.subheading_color }}; margin:0; opacity:.9;
  }

  /* ===== Cards grid (desktop/tablet) ===== */
  .ai-luxury-cta-cards-{{ ai_gen_id }}{
    display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr));
    gap: {{ settings.spacing_grid_horizontal }}px; margin-top: {{ block.settings.cards_spacing }}px; align-items:stretch;
  }

  .ai-luxury-cta-card-{{ ai_gen_id }}{
    background: {{ block.settings.card_background }}; border-radius: {{ settings.card_corner_radius }}px;
    padding: {{ block.settings.card_padding }}px; text-align:center; transition: all .3s ease;
    border: {{ settings.card_border_thickness | default: settings.card_border_thickness }}px solid rgba({{ settings.color_schemes.scheme-1.settings.text | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.text | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.text | color_extract: 'blue' }}, {{ settings.card_border_opacity | divided_by: 100.0 }});
    box-shadow:
      {% if settings.card_shadow_opacity > 0 %}
        {{ settings.card_shadow_horizontal_offset }}px {{ settings.card_shadow_vertical_offset }}px {{ settings.card_shadow_blur }}px rgba({{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'blue' }}, {{ settings.card_shadow_opacity | divided_by: 100.0 }})
      {% else %}0 2px 8px rgba(0,0,0,.1){% endif %};
    display:flex; flex-direction:column; height:100%;
  }
  .ai-luxury-cta-card-{{ ai_gen_id }}:hover{
    {% if settings.animations_hover_elements == 'vertical-lift' %}transform: translateY(-4px);
    {% elsif settings.animations_hover_elements == '3d-lift' %}transform: translateY(-4px) scale(1.02);
    {% endif %}
    box-shadow:
      {% if settings.card_shadow_opacity > 0 %}
        {{ settings.card_shadow_horizontal_offset }}px {{ settings.card_shadow_vertical_offset | plus: 4 }}px {{ settings.card_shadow_blur | plus: 8 }}px rgba({{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'blue' }}, {{ settings.card_shadow_opacity | plus: 15 | divided_by: 100.0 }})
      {% else %}0 8px 24px rgba(0,0,0,.15){% endif %};
  }

  .ai-luxury-cta-card-content-{{ ai_gen_id }}{ flex-grow:1; display:flex; flex-direction:column; }
  .ai-luxury-cta-card-image-{{ ai_gen_id }}{
    width: {{ block.settings.image_size }}px; height: {{ block.settings.image_size }}px; margin: 0 auto {{ block.settings.image_spacing }}px;
    border-radius: {{ settings.media_radius }}px; overflow:hidden; position:relative;
  }
  .ai-luxury-cta-card-image-{{ ai_gen_id }} img{ width:100%; height:100%; object-fit:cover; transition: transform .3s ease; }
  .ai-luxury-cta-card-{{ ai_gen_id }}:hover .ai-luxury-cta-card-image-{{ ai_gen_id }} img{ transform: scale(1.05); }
  .ai-luxury-cta-card-image-placeholder-{{ ai_gen_id }}{ width:100%; height:100%; background:#f4f4f4; display:flex; align-items:center; justify-content:center; border-radius: {{ settings.media_radius }}px; }
  .ai-luxury-cta-card-image-placeholder-{{ ai_gen_id }} svg{ width:60%; height:60%; opacity:.3; }

  .ai-luxury-cta-card-title-{{ ai_gen_id }}{
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }}; font-style: {{ settings.type_header_font.style }};
    font-size: calc({{ block.settings.card_title_size }}px * {{ settings.heading_scale | divided_by: 100.0 }}); line-height:1.3;
    color: {{ block.settings.card_title_color }}; margin:0 0 {{ block.settings.card_title_spacing }}px; letter-spacing:.5px;
  }
  .ai-luxury-cta-card-description-{{ ai_gen_id }}{
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }}; font-style: {{ settings.type_body_font.style }};
    font-size: calc({{ block.settings.card_description_size }}px * {{ settings.body_scale | divided_by: 100.0 }}); line-height:1.5;
    color: {{ block.settings.card_description_color }}; margin:0 0 {{ block.settings.card_description_spacing }}px; opacity:.8; flex-grow:1;
  }

  .ai-luxury-cta-card-button-wrapper-{{ ai_gen_id }}{ margin-top:auto; }
  .ai-luxury-cta-card-button-{{ ai_gen_id }}{
    display:inline-flex; align-items:center; justify-content:center; width:100%;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight:500; font-size: calc({{ block.settings.button_font_size }}px * {{ settings.body_scale | divided_by: 100.0 }});
    text-decoration:none; border-radius: {{ settings.buttons_radius }}px; cursor:pointer; transition: all .3s ease;
    letter-spacing: {{ block.settings.button_letter_spacing }}px; text-transform: {{ block.settings.button_text_transform }};
    min-width: {{ block.settings.button_min_width }}px; border: {{ settings.buttons_border_thickness }}px solid transparent; box-sizing:border-box;
  }

  .ai-luxury-cta-card-button-primary-{{ ai_gen_id }}{
    background: {{ settings.color_schemes.scheme-1.settings.button }};
    color: {{ settings.color_schemes.scheme-1.settings.button_label }};
    border-color: rgba({{ settings.color_schemes.scheme-1.settings.button | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.button | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.button | color_extract: 'blue' }}, {{ settings.buttons_border_opacity | divided_by: 100.0 }});
  }
  .ai-luxury-cta-card-button-primary-{{ ai_gen_id }}:hover{
    background: {{ block.settings.primary_button_hover_bg | default: settings.color_schemes.scheme-1.settings.button }};
    color: {{ block.settings.primary_button_hover_text | default: settings.color_schemes.scheme-1.settings.button_label }};
    filter:brightness(.9);
  }

  .ai-luxury-cta-card-button-secondary-{{ ai_gen_id }}{
    background: {{ settings.color_schemes.scheme-1.settings.background }};
    color: {{ settings.color_schemes.scheme-1.settings.secondary_button_label }};
    border-color: rgba({{ settings.color_schemes.scheme-1.settings.secondary_button_label | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.secondary_button_label | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.secondary_button_label | color_extract: 'blue' }}, {{ settings.buttons_border_opacity | divided_by: 100.0 }});
  }
  .ai-luxury-cta-card-button-secondary-{{ ai_gen_id }}:hover{
    background: {{ settings.color_schemes.scheme-1.settings.button }}; color: {{ settings.color_schemes.scheme-1.settings.button_label }}; border-color: {{ settings.color_schemes.scheme-1.settings.button }};
  }

  /* === 3rd card button – now configurable === */
  .ai-luxury-cta-card-button-tertiary-{{ ai_gen_id }}{
    background: {{ block.settings.card_3_button_bg | default: settings.color_schemes.scheme-4.settings.background }};
    color: {{ block.settings.card_3_button_text | default: settings.color_schemes.scheme-4.settings.text }};
    border-color: {{ block.settings.card_3_button_bg | default: settings.color_schemes.scheme-4.settings.background }};
  }
  .ai-luxury-cta-card-button-tertiary-{{ ai_gen_id }}:hover{
    background: {{ block.settings.tertiary_button_hover_bg | default: settings.color_schemes.scheme-4.settings.button }};
    color: {{ block.settings.tertiary_button_hover_text | default: settings.color_schemes.scheme-4.settings.button_label }};
    filter:brightness(1.06);
  }

  /* ===== Mobile swipe carousel ===== */
  @media (max-width: 749px){
    .ai-luxury-cta-container-{{ ai_gen_id }}{ padding: 0 {{ settings.spacing_grid_horizontal | times: 0.75 }}px; }

    /* turn grid into horizontal scroller with snap */
    .ai-luxury-cta-cards-{{ ai_gen_id }}{
      display:flex; overflow-x:auto; -webkit-overflow-scrolling:touch;
      scroll-snap-type:x mandatory; gap: {{ settings.spacing_grid_horizontal | times: 0.75 }}px;
      padding: 6px 4px 10px;
    }
    .ai-luxury-cta-cards-{{ ai_gen_id }}::-webkit-scrollbar{ display:none; }
    .ai-luxury-cta-card-{{ ai_gen_id }}{
      flex:0 0 86%; scroll-snap-align:start; padding: {{ block.settings.card_padding | times: 0.85 }}px;
    }
    .ai-luxury-cta-card-image-{{ ai_gen_id }}{
      width: {{ block.settings.image_size | times: 0.85 }}px; height: {{ block.settings.image_size | times: 0.85 }}px;
    }

    /* dots */
    .ai-luxury-cta-dots-{{ ai_gen_id }}{ display:flex; justify-content:center; gap:8px; margin-top:12px; }
    .ai-luxury-cta-dot-{{ ai_gen_id }}{
      width:8px; height:8px; border-radius:999px; border:none; background: rgba({{ settings.color_schemes.scheme-1.settings.text | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.text | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.text | color_extract: 'blue' }}, .25);
      cursor:pointer; transition:all .25s ease;
    }
    .ai-luxury-cta-dot-{{ ai_gen_id }}.active{ width:22px; background: {{ settings.color_schemes.scheme-1.settings.button }}; }
  }

  /* ===== Equal heights for all cards ===== */
.ai-luxury-cta-section-{{ ai_gen_id }}{
  /* tweak these once and all cards follow */
  --card-h-desktop: 520px;
  --card-h-tablet: 520px;
  --card-h-mobile: 460px;
}

/* same height + keep internal layout */
.ai-luxury-cta-card-{{ ai_gen_id }}{
  height: var(--card-h-desktop);
  overflow: hidden;                 /* prevents spillover */
}
@media (max-width: 990px){
  .ai-luxury-cta-card-{{ ai_gen_id }}{ height: var(--card-h-tablet); }
}
@media (max-width: 749.98px){
  .ai-luxury-cta-card-{{ ai_gen_id }}{ height: var(--card-h-mobile); }
}

/* clamp text so titles/descriptions don’t push height */
.ai-luxury-cta-card-title-{{ ai_gen_id }}{
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden;
}
.ai-luxury-cta-card-description-{{ ai_gen_id }}{
  display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical;
  overflow: hidden;
}
@media (max-width: 749.98px){
  .ai-luxury-cta-card-description-{{ ai_gen_id }}{ -webkit-line-clamp: 5; }
}

/* keep buttons aligned at the bottom inside the fixed height */
.ai-luxury-cta-card-button-wrapper-{{ ai_gen_id }}{ margin-top: auto; }

{% endstyle %}



<div class="ai-luxury-cta-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-cta-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-luxury-cta-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-luxury-cta-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-luxury-cta-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-luxury-cta-cards-{{ ai_gen_id }}">
      <!-- Card 1 -->
      <div class="ai-luxury-cta-card-{{ ai_gen_id }}">
        <div class="ai-luxury-cta-card-content-{{ ai_gen_id }}">
          <div class="ai-luxury-cta-card-image-{{ ai_gen_id }}">
            {% if block.settings.card_1_image %}
              <img src="{{ block.settings.card_1_image | image_url: width: 400 }}" alt="{{ block.settings.card_1_image.alt | escape }}" loading="lazy" width="{{ block.settings.image_size }}" height="{{ block.settings.image_size }}">
            {% else %}
              <div class="ai-luxury-cta-card-image-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
            {% endif %}
          </div>
          {% if block.settings.card_1_title != blank %}
            <h3 class="ai-luxury-cta-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
          {% endif %}
          {% if block.settings.card_1_description != blank %}
            <p class="ai-luxury-cta-card-description-{{ ai_gen_id }}">{{ block.settings.card_1_description }}</p>
          {% endif %}
        </div>
        {% if block.settings.card_1_button_label != blank %}
          <div class="ai-luxury-cta-card-button-wrapper-{{ ai_gen_id }}">
            <a href="{{ block.settings.card_1_button_link }}" class="ai-luxury-cta-card-button-{{ ai_gen_id }} ai-luxury-cta-card-button-primary-{{ ai_gen_id }}" {% if block.settings.card_1_button_link == blank %}aria-disabled="true"{% endif %}>{{ block.settings.card_1_button_label }}</a>
          </div>
        {% endif %}
      </div>

      <!-- Card 2 -->
      <div class="ai-luxury-cta-card-{{ ai_gen_id }}">
        <div class="ai-luxury-cta-card-content-{{ ai_gen_id }}">
          <div class="ai-luxury-cta-card-image-{{ ai_gen_id }}">
            {% if block.settings.card_2_image %}
              <img src="{{ block.settings.card_2_image | image_url: width: 400 }}" alt="{{ block.settings.card_2_image.alt | escape }}" loading="lazy" width="{{ block.settings.image_size }}" height="{{ block.settings.image_size }}">
            {% else %}
              <div class="ai-luxury-cta-card-image-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
            {% endif %}
          </div>
          {% if block.settings.card_2_title != blank %}
            <h3 class="ai-luxury-cta-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
          {% endif %}
          {% if block.settings.card_2_description != blank %}
            <p class="ai-luxury-cta-card-description-{{ ai_gen_id }}">{{ block.settings.card_2_description }}</p>
          {% endif %}
        </div>
        {% if block.settings.card_2_button_label != blank %}
          <div class="ai-luxury-cta-card-button-wrapper-{{ ai_gen_id }}">
            <a href="{{ block.settings.card_2_button_link }}" class="ai-luxury-cta-card-button-{{ ai_gen_id }} ai-luxury-cta-card-button-secondary-{{ ai_gen_id }}" {% if block.settings.card_2_button_link == blank %}aria-disabled="true"{% endif %}>{{ block.settings.card_2_button_label }}</a>
          </div>
        {% endif %}
      </div>

      <!-- Card 3 -->
      <div class="ai-luxury-cta-card-{{ ai_gen_id }}">
        <div class="ai-luxury-cta-card-content-{{ ai_gen_id }}">
          <div class="ai-luxury-cta-card-image-{{ ai_gen_id }}">
            {% if block.settings.card_3_image %}
              <img src="{{ block.settings.card_3_image | image_url: width: 400 }}" alt="{{ block.settings.card_3_image.alt | escape }}" loading="lazy" width="{{ block.settings.image_size }}" height="{{ block.settings.image_size }}">
            {% else %}
              <div class="ai-luxury-cta-card-image-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
            {% endif %}
          </div>
          {% if block.settings.card_3_title != blank %}
            <h3 class="ai-luxury-cta-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
          {% endif %}
          {% if block.settings.card_3_description != blank %}
            <p class="ai-luxury-cta-card-description-{{ ai_gen_id }}">{{ block.settings.card_3_description }}</p>
          {% endif %}
        </div>
        {% if block.settings.card_3_button_label != blank %}
          <div class="ai-luxury-cta-card-button-wrapper-{{ ai_gen_id }}">
            <a href="{{ block.settings.card_3_button_link }}" class="ai-luxury-cta-card-button-{{ ai_gen_id }} ai-luxury-cta-card-button-tertiary-{{ ai_gen_id }}" {% if block.settings.card_3_button_link == blank %}aria-disabled="true"{% endif %}>{{ block.settings.card_3_button_label }}</a>
          </div>
        {% endif %}
      </div>
    </div>

    <!-- Swipe dots (mobile) -->
    <div class="ai-luxury-cta-dots-{{ ai_gen_id }}" aria-hidden="true"></div>
  </div>
</div>

<script>
  (function(){
    const root = document.querySelector('.ai-luxury-cta-section-{{ ai_gen_id }}');
    if(!root) return;

    const scroller = root.querySelector('.ai-luxury-cta-cards-{{ ai_gen_id }}');
    const cards = scroller ? Array.from(scroller.querySelectorAll('.ai-luxury-cta-card-{{ ai_gen_id }}')) : [];
    const dotsWrap = root.querySelector('.ai-luxury-cta-dots-{{ ai_gen_id }}');

    // Build dots (mobile only)
    if (window.matchMedia('(max-width: 749px)').matches && scroller && cards.length > 1) {
      // Create dots
      cards.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'ai-luxury-cta-dot-{{ ai_gen_id }}';
        dot.setAttribute('aria-label', 'Slide ' + (i+1));
        dot.addEventListener('click', () => {
          scroller.scrollTo({ left: cards[i].offsetLeft, behavior: 'smooth' });
        });
        dotsWrap.appendChild(dot);
      });

      const dots = Array.from(dotsWrap.querySelectorAll('.ai-luxury-cta-dot-{{ ai_gen_id }}'));

      // Set active dot based on scroll position
      const update = () => {
        let idx = 0; let min = Infinity; const left = scroller.scrollLeft;
        cards.forEach((card, i) => {
          const d = Math.abs(card.offsetLeft - left);
          if (d < min) { min = d; idx = i; }
        });
        dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      };

      scroller.addEventListener('scroll', update, { passive: true });
      // Initial
      update();
    }
  })();
</script>

{% schema %}
{
  "name": "Luxury CTA cards",
  "settings": [
    { "type": "header", "content": "Section header" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Experience Luxury" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Discover our premium collection and elevate your lifestyle" },

    { "type": "header", "content": "Card 1" },
    { "type": "image_picker", "id": "card_1_image", "label": "Image" },
    { "type": "text", "id": "card_1_title", "label": "Title", "default": "Book Appointment" },
    { "type": "textarea", "id": "card_1_description", "label": "Description", "default": "Schedule your personalized consultation with our experts" },
    { "type": "text", "id": "card_1_button_label", "label": "Button text", "default": "Book Now" },
    { "type": "url", "id": "card_1_button_link", "label": "Button link" },

    { "type": "header", "content": "Card 2" },
    { "type": "image_picker", "id": "card_2_image", "label": "Image" },
    { "type": "text", "id": "card_2_title", "label": "Title", "default": "Homepage" },
    { "type": "textarea", "id": "card_2_description", "label": "Description", "default": "Explore our complete range of premium products and services" },
    { "type": "text", "id": "card_2_button_label", "label": "Button text", "default": "Visit Homepage" },
    { "type": "url", "id": "card_2_button_link", "label": "Button link" },

    { "type": "header", "content": "Card 3" },
    { "type": "image_picker", "id": "card_3_image", "label": "Image" },
    { "type": "text", "id": "card_3_title", "label": "Title", "default": "Shopping Page" },
    { "type": "textarea", "id": "card_3_description", "label": "Description", "default": "Browse our curated collection of luxury items and accessories" },
    { "type": "text", "id": "card_3_button_label", "label": "Button text", "default": "Shop Now" },
    { "type": "url", "id": "card_3_button_link", "label": "Button link" },

    /* New color controls for Card 3 button */
    { "type": "color", "id": "card_3_button_bg", "label": "Card 3 button background" },
    { "type": "color", "id": "card_3_button_text", "label": "Card 3 button text" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "min": 20, "max": 80, "step": 2, "unit": "px", "label": "Section heading size", "default": 48 },
    { "type": "range", "id": "subheading_size", "min": 12, "max": 32, "step": 1, "unit": "px", "label": "Section subheading size", "default": 18 },
    { "type": "range", "id": "card_title_size", "min": 16, "max": 36, "step": 1, "unit": "px", "label": "Card title size", "default": 24 },
    { "type": "range", "id": "card_description_size", "min": 12, "max": 20, "step": 1, "unit": "px", "label": "Card description size", "default": 14 },
    { "type": "range", "id": "button_font_size", "min": 12, "max": 20, "step": 1, "unit": "px", "label": "Button font size", "default": 14 },
