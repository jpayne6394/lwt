{% doc %}
  @prompt
    Create a luxury booking call-to-action section with elegant styling that matches premium wellness consultation branding, featuring a prominent "Book a Session" button with sophisticated typography and refined design elements, move button above the heading, add button spacing controls it is too close to the top

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-booking-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 40px;
    background: {{ block.settings.background_color }};
    {% if block.settings.background_gradient != blank %}
      background: {{ block.settings.background_gradient }};
    {% endif %}
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .ai-luxury-booking-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%);
    pointer-events: none;
  }

  .ai-luxury-booking__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .ai-luxury-booking__badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 24px;
    background: rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.1);
    border: 1px solid {{ block.settings.accent_color }};
    border-radius: 50px;
    color: {{ block.settings.accent_color }};
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: {{ block.settings.badge_bottom_spacing }}px;
  }

  .ai-luxury-booking__button-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.button_bottom_spacing }}px;
  }

  .ai-luxury-booking__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 48px;
    background: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 8px 32px rgba({{ block.settings.button_color | color_extract: 'red' }}, {{ block.settings.button_color | color_extract: 'green' }}, {{ block.settings.button_color | color_extract: 'blue' }}, 0.3);
    position: relative;
    overflow: hidden;
  }

  .ai-luxury-booking__button-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s ease;
  }

  .ai-luxury-booking__button-{{ ai_gen_id }}:hover::before {
    left: 100%;
  }

  .ai-luxury-booking__button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba({{ block.settings.button_color | color_extract: 'red' }}, {{ block.settings.button_color | color_extract: 'green' }}, {{ block.settings.button_color | color_extract: 'blue' }}, 0.4);
  }

  .ai-luxury-booking__button-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .ai-luxury-booking__button-{{ ai_gen_id }}:hover .ai-luxury-booking__button-icon-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-luxury-booking__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, serif;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_font.weight }};
    color: {{ block.settings.text_color }};
    line-height: 1.2;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .ai-luxury-booking__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    line-height: 1.5;
    margin: 0 0 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-luxury-booking__features-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .ai-luxury-booking__feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    font-size: 14px;
  }

  .ai-luxury-booking__feature-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    color: {{ block.settings.accent_color }};
  }

  .ai-luxury-booking__decorative-line-{{ ai_gen_id }} {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, {{ block.settings.accent_color }}, transparent);
    margin: 32px auto 0;
    opacity: 0.6;
  }

  @media screen and (max-width: 768px) {
    .ai-luxury-booking-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px 20px;
    }

    .ai-luxury-booking__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-luxury-booking__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-luxury-booking__button-{{ ai_gen_id }} {
      padding: 16px 36px;
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
    }

    .ai-luxury-booking__features-{{ ai_gen_id }} {
      gap: 24px;
    }

    .ai-luxury-booking__badge-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.badge_bottom_spacing | times: 0.8 }}px;
    }

    .ai-luxury-booking__button-wrapper-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.button_bottom_spacing | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-luxury-booking__features-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 16px;
    }
  }
{% endstyle %}

<div class="ai-luxury-booking-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-booking__container-{{ ai_gen_id }}">
    {% if block.settings.badge_text != blank %}
      <div class="ai-luxury-booking__badge-{{ ai_gen_id }}">
        {{ block.settings.badge_text }}
      </div>
    {% endif %}

    <div class="ai-luxury-booking__button-wrapper-{{ ai_gen_id }}">
      <a 
        href="{{ block.settings.button_link }}" 
        class="ai-luxury-booking__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
        <svg
          class="ai-luxury-booking__button-icon-{{ ai_gen_id }}" 
          viewBox="0 0 24 24" 
          fill="none" 
          stroke="currentColor" 
          stroke-width="2"
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    {% if block.settings.heading != blank %}
      <h2 class="ai-luxury-booking__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-luxury-booking__subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </div>
    {% endif %}

    {% if block.settings.show_features %}
      <div class="ai-luxury-booking__features-{{ ai_gen_id }}">
        <div class="ai-luxury-booking__feature-{{ ai_gen_id }}">
          <svg class="ai-luxury-booking__feature-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/>
          </svg>
          {{ block.settings.feature_1 }}
        </div>
        <div class="ai-luxury-booking__feature-{{ ai_gen_id }}">
          <svg class="ai-luxury-booking__feature-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          {{ block.settings.feature_2 }}
        </div>
        <div class="ai-luxury-booking__feature-{{ ai_gen_id }}">
          <svg class="ai-luxury-booking__feature-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22,4 12,14.01 9,11.01"/>
          </svg>
          {{ block.settings.feature_3 }}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_decorative_line %}
      <div class="ai-luxury-booking__decorative-line-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Luxury booking CTA",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Premium Wellness"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Book a Session"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Transform Your Wellness Journey</p>"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Experience personalized wellness consultation with our certified experts. Begin your journey to optimal health and vitality.</p>"
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "checkbox",
      "id": "show_features",
      "label": "Show features",
      "default": true
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "Expert Guidance"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Premium Experience"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "Proven Results"
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fdf2f6"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#4b3f82"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#4b3f82"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#4b3f82"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#3d3366"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_decorative_line",
      "label": "Show decorative line",
      "default": true
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "playfair_display_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 18
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Button text size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "badge_bottom_spacing",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Badge bottom spacing",
      "default": 32
    },
    {
      "type": "range",
      "id": "button_bottom_spacing",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Button bottom spacing",
      "default": 48
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 800
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Section padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "button_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Button border radius",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Luxury booking CTA"
    }
  ],
  "tag": null
}
{% endschema %}