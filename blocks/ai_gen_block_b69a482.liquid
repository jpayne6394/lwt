{% doc %}
  @prompt
    Create a luxury footer section with comprehensive features including company information, navigation links, social media icons, contact details, newsletter signup with call-to-action, and a preview section showcasing recent blog articles. The design should be elegant and premium with proper spacing, typography, and visual hierarchy suitable for a luxury brand., Match site theme, add image scroll of different blog articles with an overlay on hover of article image that says Read more, have the latest articles about the About Us, Quick Links, contact Us, we the articles on the left and the sing cta on the right, articles and sign up should horizontal atthe top

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-footer-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    border-top: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: calc({{ settings.body_scale }}% * 1rem);
  }

  .ai-luxury-footer__container-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 calc({{ settings.spacing_grid_horizontal }}px / 2);
  }

  .ai-luxury-footer__top-section-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: {{ settings.spacing_grid_horizontal | times: 2 }}px;
    margin-bottom: {{ settings.spacing_grid_vertical | times: 2 }}px;
  }

  .ai-luxury-footer__main-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: {{ settings.spacing_grid_horizontal }}px;
  }

  .ai-luxury-footer__section-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ settings.spacing_grid_vertical }}px;
  }

  .ai-luxury-footer__heading-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-size: calc({{ settings.heading_scale }}% * {{ block.settings.heading_size }}px / 100);
    font-weight: {{ settings.type_header_font.weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ settings.spacing_grid_vertical }}px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .ai-luxury-footer__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-luxury-footer__nav-list-{{ ai_gen_id }} {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: {{ settings.spacing_grid_vertical | divided_by: 2 }}px;
  }

  .ai-luxury-footer__nav-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.text_size }}px;
    transition: color 0.3s ease;
    display: inline-block;
  }

  .ai-luxury-footer__nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-luxury-footer__contact-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ settings.spacing_grid_horizontal | divided_by: 2 }}px;
    margin-bottom: {{ settings.spacing_grid_vertical }}px;
  }

  .ai-luxury-footer__contact-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    color: {{ block.settings.accent_color }};
    flex-shrink: 0;margin-top: 2px;
  }

  .ai-luxury-footer__social-links-{{ ai_gen_id }} {
    display: flex;
    gap: {{ settings.spacing_grid_horizontal | divided_by: 2 }}px;
    margin-top: {{ settings.spacing_grid_vertical }}px;
  }

  .ai-luxury-footer__social-link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: {{ block.settings.social_bg_color }};
    color: {{ block.settings.social_icon_color }};
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.3s ease;
    border: {{ settings.buttons_border_thickness }}px solid rgba({{ block.settings.social_icon_color | color_extract: 'red' }}, {{ block.settings.social_icon_color | color_extract: 'green' }}, {{ block.settings.social_icon_color | color_extract: 'blue' }}, {{ settings.buttons_border_opacity | divided_by: 100.0 }});
    box-shadow: {{ settings.buttons_shadow_horizontal_offset }}px {{ settings.buttons_shadow_vertical_offset }}px {{ settings.buttons_shadow_blur }}px rgba({{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'blue' }}, {{ settings.buttons_shadow_opacity | divided_by: 100.0 }});}

  .ai-luxury-footer__social-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.social_hover_bg_color }};
    color: {{ block.settings.social_hover_icon_color }};
    {% if settings.animations_hover_elements == 'vertical-lift' %}
      transform: translateY(-2px);
    {% elsif settings.animations_hover_elements == '3d-lift' %}
      transform: translateY(-2px) scale(1.05);
    {% endif %}
  }

  .ai-luxury-footer__social-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
  }

  .ai-luxury-footer__newsletter-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.newsletter_bg_color }};
    padding: {{ settings.spacing_grid_vertical | times: 1.5 }}px;
    border-radius: {{ settings.text_boxes_radius }}px;
    border: {{ settings.text_boxes_border_thickness }}px solid rgba({{ block.settings.newsletter_border_color | color_extract: 'red' }}, {{ block.settings.newsletter_border_color | color_extract: 'green' }}, {{ block.settings.newsletter_border_color | color_extract: 'blue' }}, {{ settings.text_boxes_border_opacity | divided_by: 100.0 }});
    box-shadow: {{ settings.text_boxes_shadow_horizontal_offset }}px {{ settings.text_boxes_shadow_vertical_offset }}px {{ settings.text_boxes_shadow_blur }}px rgba({{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'blue' }}, {{ settings.text_boxes_shadow_opacity | divided_by: 100.0 }});
  }

  .ai-luxury-footer__newsletter-form-{{ ai_gen_id }} {
    margin-top: {{ settings.spacing_grid_vertical }}px;
  }

  .ai-luxury-footer__newsletter-input-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ settings.spacing_grid_horizontal | divided_by: 2 }}px;
    margin-top: {{ settings.spacing_grid_vertical | divided_by: 2 }}px;
  }

  .ai-luxury-footer__newsletter-input-{{ ai_gen_id }} {
    padding: 14px 16px;
    border: {{ settings.inputs_border_thickness }}px solid rgba({{ block.settings.input_border_color | color_extract: 'red' }}, {{ block.settings.input_border_color | color_extract: 'green' }}, {{ block.settings.input_border_color | color_extract: 'blue' }}, {{ settings.inputs_border_opacity | divided_by: 100.0 }});
    background-color: {{ block.settings.input_bg_color }};
    color: {{ block.settings.newsletter_text_color }};
    border-radius: {{ settings.inputs_radius }}px;
    font-size: 14px;
    box-shadow: {{ settings.inputs_shadow_horizontal_offset }}px {{ settings.inputs_shadow_vertical_offset }}px {{ settings.inputs_shadow_blur }}px rgba({{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'blue' }}, {{ settings.inputs_shadow_opacity | divided_by: 100.0 }});
    width: 100%;
  }

  .ai-luxury-footer__newsletter-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
  }

  .ai-luxury-footer__newsletter-button-{{ ai_gen_id }} {
    padding: 14px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ settings.buttons_border_thickness }}px solid rgba({{ block.settings.button_bg_color | color_extract: 'red' }}, {{ block.settings.button_bg_color | color_extract: 'green' }}, {{ block.settings.button_bg_color | color_extract: 'blue' }}, {{ settings.buttons_border_opacity | divided_by: 100.0 }});
    border-radius: {{ settings.buttons_radius }}px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
    white-space: nowrap;
    box-shadow: {{ settings.buttons_shadow_horizontal_offset }}px {{ settings.buttons_shadow_vertical_offset }}px {{ settings.buttons_shadow_blur }}px rgba({{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'blue' }}, {{ settings.buttons_shadow_opacity | divided_by: 100.0 }});
    width: 100%;
  }

  .ai-luxury-footer__newsletter-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    {% if settings.animations_hover_elements == 'vertical-lift' %}
      transform: translateY(-1px);
    {% elsif settings.animations_hover_elements == '3d-lift' %}
      transform: translateY(-1px) scale(1.02);
    {% endif %}
  }

  .ai-luxury-footer__blog-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.blog_section_bg_color }};
    padding: {{ settings.spacing_grid_vertical | times: 1.5 }}px;
    border-radius: {{ settings.text_boxes_radius }}px;
    border: {{ settings.text_boxes_border_thickness }}px solid rgba({{ block.settings.blog_section_border_color | color_extract: 'red' }}, {{ block.settings.blog_section_border_color | color_extract: 'green' }}, {{ block.settings.blog_section_border_color | color_extract: 'blue' }}, {{ settings.text_boxes_border_opacity | divided_by: 100.0 }});
    box-shadow: {{ settings.text_boxes_shadow_horizontal_offset }}px {{ settings.text_boxes_shadow_vertical_offset }}px {{ settings.text_boxes_shadow_blur }}px rgba({{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'blue' }}, {{ settings.text_boxes_shadow_opacity | divided_by: 100.0 }});
  }

  .ai-luxury-footer__blog-scroll-container-{{ ai_gen_id }} {
    margin-top: {{ settings.spacing_grid_vertical }}px;
    overflow: hidden;
  }

  .ai-luxury-footer__blog-scroll-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ settings.spacing_grid_vertical }}px;
    max-height: 400px;
    overflow-y: auto;
    padding-right: 10px;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.accent_color }} transparent;
  }

  .ai-luxury-footer__blog-scroll-{{ ai_gen_id }}::-webkit-scrollbar {
    width: 6px;
  }

  .ai-luxury-footer__blog-scroll-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: rgba({{ block.settings.blog_text_color | color_extract: 'red' }}, {{ block.settings.blog_text_color | color_extract: 'green' }}, {{ block.settings.blog_text_color | color_extract: 'blue' }}, 0.1);
    border-radius: 3px;
  }

  .ai-luxury-footer__blog-scroll-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background: {{ block.settings.accent_color }};
    border-radius: 3px;
  }

  .ai-luxury-footer__blog-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ settings.card_corner_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease;
    border: {{ settings.card_border_thickness }}px solid rgba({{ block.settings.card_bg_color | color_extract: 'red' }}, {{ block.settings.card_bg_color | color_extract: 'green' }}, {{ block.settings.card_bg_color | color_extract: 'blue' }}, {{ settings.card_border_opacity | divided_by: 100.0 }});
    box-shadow: {{ settings.card_shadow_horizontal_offset }}px {{ settings.card_shadow_vertical_offset }}px {{ settings.card_shadow_blur }}px rgba({{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'red' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'green' }}, {{ settings.color_schemes.scheme-1.settings.shadow | color_extract: 'blue' }}, {{ settings.card_shadow_opacity | divided_by: 100.0 }});
    display: flex;
    align-items: center;
    gap: {{ settings.spacing_grid_horizontal | divided_by: 2 }}px;
  }

  .ai-luxury-footer__blog-card-{{ ai_gen_id }}:hover {
    {% if settings.animations_hover_elements == 'vertical-lift' %}
      transform: translateY(-2px);
    {% elsif settings.animations_hover_elements == '3d-lift' %}
      transform: translateY(-2px) scale(1.02);
    {% endif %}
  }

  .ai-luxury-footer__blog-image-container-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.blog_image_width }}px;
    height: {{ block.settings.blog_image_height }}px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ai-luxury-footer__blog-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-luxury-footer__blog-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-luxury-footer__blog-placeholder-{{ ai_gen_id }} svg {
    width: 30px;
    height: 30px;
    color: #999;
  }

  .ai-luxury-footer__blog-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, {{ block.settings.overlay_color_1 }}, {{ block.settings.overlay_color_2 }});
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-luxury-footer__blog-card-{{ ai_gen_id }}:hover .ai-luxury-footer__blog-overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-luxury-footer__blog-card-{{ ai_gen_id }}:hover .ai-luxury-footer__blog-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-luxury-footer__blog-overlay-text-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: {{ block.settings.overlay_text_size }}px;
    font-weight: 600;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 6px 12px;
    border: 2px solid {{ block.settings.overlay_text_color }};
    border-radius: {{ settings.buttons_radius }}px;
    background: rgba({{ block.settings.overlay_text_color | color_extract: 'red' }}, {{ block.settings.overlay_text_color | color_extract: 'green' }}, {{ block.settings.overlay_text_color | color_extract: 'blue' }},0.1);
    backdrop-filter: blur(4px);
    transform: translateY(10px);
    transition: transform 0.3s ease;
  }

  .ai-luxury-footer__blog-card-{{ ai_gen_id }}:hover .ai-luxury-footer__blog-overlay-text-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  .ai-luxury-footer__blog-content-{{ ai_gen_id }} {
    padding: {{ settings.spacing_grid_vertical | divided_by: 2 }}px;
    flex-grow: 1;
  }

  .ai-luxury-footer__blog-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.blog_title_size }}px;
    font-weight:600;
    color: {{ block.settings.blog_text_color }};
    margin: 0 0 4px;line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-luxury-footer__blog-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.blog_excerpt_size }}px;
    color: {{ block.settings.blog_meta_color }};
    margin: 0 0 4px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-luxury-footer__blog-date-{{ ai_gen_id }} {
    font-size: 11px;
    color: {{ block.settings.blog_meta_color }};
    margin: 0;text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-luxury-footer__blog-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-luxury-footer__newsletter-heading-{{ ai_gen_id }} {
    color: {{ block.settings.newsletter_heading_color }};
  }

  .ai-luxury-footer__newsletter-text-{{ ai_gen_id }} {
    color: {{ block.settings.newsletter_text_color }};
  }

  .ai-luxury-footer__blog-heading-{{ ai_gen_id }} {
    color: {{ block.settings.blog_heading_color }};
  }

  .ai-luxury-footer__bottom-{{ ai_gen_id }} {
    border-top: 1px solid {{ block.settings.divider_color }};
    padding-top: {{ settings.spacing_grid_vertical | times: 1.5 }}px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: {{ settings.spacing_grid_horizontal }}px;
  }

  .ai-luxury-footer__copyright-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.meta_color }};
  }

  .ai-luxury-footer__payment-icons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ settings.spacing_grid_horizontal | divided_by: 4 }}px;
    align-items: center;
  }

  .ai-luxury-footer__payment-icon-{{ ai_gen_id }} {
    width: 32px;
    height: 20px;
    background-color: #f4f4f4;
    border-radius: {{ settings.buttons_radius | divided_by: 2 }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #666;
  }

  .ai-luxury-footer__success-message-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    font-size:14px;
    margin-top: {{ settings.spacing_grid_vertical | divided_by: 2 }}px;
  }

  .ai-luxury-footer__error-message-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    font-size: 14px;
    margin-top: {{ settings.spacing_grid_vertical | divided_by: 2 }}px;
  }

  @media screen and (max-width: 768px) {
    .ai-luxury-footer__top-section-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ settings.spacing_grid_vertical | times: 2 }}px;
    }

    .ai-luxury-footer__main-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ settings.spacing_grid_vertical | times: 1.5 }}px;
    }

    .ai-luxury-footer__bottom-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;
    }

    .ai-luxury-footer__container-{{ ai_gen_id }} {
      padding: 0 {{ settings.spacing_grid_horizontal | divided_by: 2 }}px;
    }

    .ai-luxury-footer__blog-image-container-{{ ai_gen_id }} {
      width: {{ block.settings.blog_image_width | times: 0.8 }}px;
      height: {{ block.settings.blog_image_height | times: 0.8 }}px;
    }
  }

  {% if settings.animations_reveal_on_scroll %}
    @media (prefers-reduced-motion: no-preference) {
      .ai-luxury-footer__section-{{ ai_gen_id }} {
        opacity: 0;
        transform: translateY(20px);
        animation: ai-luxury-footer-reveal-{{ ai_gen_id }} 0.6s ease-out forwards;
      }

      .ai-luxury-footer__section-{{ ai_gen_id }}:nth-child(1) { animation-delay: 0.1s; }
      .ai-luxury-footer__section-{{ ai_gen_id }}:nth-child(2) { animation-delay: 0.2s; }
      .ai-luxury-footer__section-{{ ai_gen_id }}:nth-child(3) { animation-delay: 0.3s; }

      .ai-luxury-footer__newsletter-section-{{ ai_gen_id }} {
        opacity: 0;
        transform: translateY(20px);
        animation: ai-luxury-footer-reveal-{{ ai_gen_id }} 0.6s ease-out forwards;animation-delay: 0.4s;
      }

      .ai-luxury-footer__blog-section-{{ ai_gen_id }} {
        opacity: 0;
        transform: translateY(20px);
        animation: ai-luxury-footer-reveal-{{ ai_gen_id }} 0.6s ease-out forwards;
        animation-delay: 0.5s;
      }

      @keyframes ai-luxury-footer-reveal-{{ ai_gen_id }} {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    }
  {% endif %}
{% endstyle %}<footer class="ai-luxury-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-footer__container-{{ ai_gen_id }}">
    <div class="ai-luxury-footer__top-section-{{ ai_gen_id }}">
      {% if block.settings.show_blog_preview and block.settings.blog != blank %}
        <div class="ai-luxury-footer__blog-section-{{ ai_gen_id }}">
          <h3 class="ai-luxury-footer__heading-{{ ai_gen_id }} ai-luxury-footer__blog-heading-{{ ai_gen_id }}">{{ block.settings.blog_heading }}</h3>
          <div class="ai-luxury-footer__blog-scroll-container-{{ ai_gen_id }}">
            <div class="ai-luxury-footer__blog-scroll-{{ ai_gen_id }}">
              {% for article in block.settings.blog.articles limit: block.settings.blog_articles_count %}
                <a href="{{ article.url }}" class="ai-luxury-footer__blog-link-{{ ai_gen_id }}">
                  <div class="ai-luxury-footer__blog-card-{{ ai_gen_id }}">
                    <div class="ai-luxury-footer__blog-image-container-{{ ai_gen_id }}">
                      {% if article.image %}
                        <img
                          src="{{ article.image | image_url: width: 200}}"
                          alt="{{ article.image.alt | escape }}"
                          width="200"
                          height="{{ block.settings.blog_image_height }}"
                          loading="lazy"
                          class="ai-luxury-footer__blog-image-{{ ai_gen_id }}"
                        >
                      {% else %}
                        <div class="ai-luxury-footer__blog-placeholder-{{ ai_gen_id }}">
                          {{'image' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                      <div class="ai-luxury-footer__blog-overlay-{{ ai_gen_id }}">
                        <div class="ai-luxury-footer__blog-overlay-text-{{ ai_gen_id }}">
                          {{ block.settings.overlay_text }}
                        </div>
                      </div>
                    </div>
                    <div class="ai-luxury-footer__blog-content-{{ ai_gen_id }}">
                      <h4 class="ai-luxury-footer__blog-title-{{ ai_gen_id }}">{{ article.title }}</h4>
                      {% if block.settings.show_blog_excerpt and article.excerpt != blank %}
                        <p class="ai-luxury-footer__blog-excerpt-{{ ai_gen_id }}">{{ article.excerpt | strip_html | truncate: 60 }}</p>
                      {% endif %}
                      <p class="ai-luxury-footer__blog-date-{{ ai_gen_id }}">{{ article.published_at | date: '%b %d, %Y' }}</p>
                    </div>
                  </div>
                </a>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_newsletter %}
        <div class="ai-luxury-footer__newsletter-section-{{ ai_gen_id }}">
          <h3 class="ai-luxury-footer__heading-{{ ai_gen_id }} ai-luxury-footer__newsletter-heading-{{ ai_gen_id }}">{{ block.settings.newsletter_heading }}</h3>
          {% if block.settings.newsletter_description != blank %}
            <div class="ai-luxury-footer__text-{{ ai_gen_id }} ai-luxury-footer__newsletter-text-{{ ai_gen_id }}">{{ block.settings.newsletter_description }}</div>
          {% endif %}
          {%- form 'customer' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="ai-luxury-footer__newsletter-form-{{ ai_gen_id }}">
              <div class="ai-luxury-footer__newsletter-input-wrapper-{{ ai_gen_id }}">
                <input
                  type="email"
                  name="contact[email]"
                  class="ai-luxury-footer__newsletter-input-{{ ai_gen_id }}"
                  value="{{ form.email }}"
                  placeholder="{{ block.settings.newsletter_placeholder }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}
                    aria-invalid="true"
                    aria-describedby="ai-luxury-footer-newsletter-error-{{ ai_gen_id }}"
                  {% endif %}
                  {% if form.posted_successfully? %}
                    aria-describedby="ai-luxury-footer-newsletter-success-{{ ai_gen_id }}"
                  {% endif %}
                  required
                >
                <button
                  type="submit"
                  class="ai-luxury-footer__newsletter-button-{{ ai_gen_id }}"
                >
                  {{ block.settings.newsletter_button_text }}
                </button>
              </div>
              {%- if form.errors -%}
                <div
                  id="ai-luxury-footer-newsletter-error-{{ ai_gen_id }}"
                  class="ai-luxury-footer__error-message-{{ ai_gen_id }}"
                >
                  {{ form.errors.messages.email }}
                </div>
              {%- endif -%}{%- if form.posted_successfully? -%}
                <div
                  id="ai-luxury-footer-newsletter-success-{{ ai_gen_id }}"
                  class="ai-luxury-footer__success-message-{{ ai_gen_id }}"
                >
                  {{ block.settings.newsletter_success_message }}
                </div>
              {%- endif -%}
            </div>
          {%- endform -%}
        </div>
      {% endif %}
