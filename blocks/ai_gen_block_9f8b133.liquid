    .ai-company-bio-stat-number-{{ ai_gen_id }} { font-size: {{ block.settings.stat_number_font_size | times: 0.7 }}px; }
    .ai-company-bio-stat-label-{{ ai_gen_id }} { font-size: {{ block.settings.stat_label_font_size | times: 0.9 }}px; }
    .ai-company-bio-card-title-{{ ai_gen_id }} { font-size: {{ block.settings.card_title_font_size | times: 0.85 }}px; }
    .ai-company-bio-card-text-{{ ai_gen_id }} { font-size: {{ block.settings.card_text_font_size | times: 0.85 }}px; }
  }
